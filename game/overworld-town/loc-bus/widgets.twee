:: Widgets Bus [widget]

<<widget "buswait">>
	<<add_link "<<busicon>><<link [[버스를 기다린다 (0:02)|Bus]]>><<pass 2>><</link>><br>">><<hideDisplay>>
<</widget>>

:: Widget Passout Bus [widget]

<<widget "passoutbus">>
	<<if isPregnancyEnding()>>
		<<pregnancyPassout "bus">>
	<<else>>
		<<link [[모든 게 깜깜해진다...|Passout bus]]>><</link>>
	<</if>>
<</widget>>

:: Widgets Destination [widget]

<<widget "destination">>
	<<switch $bus>>
	<<case "nightingale">><<nightingalequick>>
		<<case "domus">><<domusquick>>
		<<case "elk">><<elkquick>>
		<<case "high">><<highquick>>
		<<case "starfish">><<starfishquick>>
		<<case "barb">><<barbquick>>
		<<case "connudatus">><<connudatusquick>>
		<<case "wolf">><<wolfquick>>
		<<case "harvest">><<harvestquick>>
		<<case "oxford">><<oxfordquick>>
		<<case "danube">><<danubequick>>
		<<case "mer">><<merquick>>
		<<case "cliff">><<cliffquick>>
		<<case "industrial">><<industrialquick>>
		<<case "residential">><<residentialquick>>
		<<case "commercial">><<commercialquick>>
		<<case "park">><<parkquick>>
		<<case "industrialdrain">><<industrialdrainquick>>
		<<case "residentialdrain">><<residentialdrainquick>>
		<<case "commercialdrain">><<commercialdrainquick>>
		<<case "seabeach">><<seabeachquick>>
		<<case "searocks">><<searocksquick>>
		<<case "seadocks">><<seadocksquick>>
		<<case "seacliffs">><<seacliffsquick>>
		<<case "drainexit">><<drainexitquick>>
		<<case "lakebus">><<lakequick>>
		<<case "sea">><<seamovequick>>
	<</switch>>
	<br><br>
<</widget>>

<<widget "destinationbusrandom">>
	<<rng 13>>
	<<switch $rng>>
		<<case 1>><<if $bus isnot "nightingale">><<set $bus to "nightingale">><<else>><<set $bus to "domus">><</if>>
		<<case 2>><<if $bus isnot "domus">><<set $bus to "domus">><<else>><<set $bus to "elk">><</if>>
		<<case 3>><<if $bus isnot "elk">><<set $bus to "elk">><<else>><<set $bus to "high">><</if>>
		<<case 4>><<if $bus isnot "high">><<set $bus to "high">><<else>><<set $bus to "starfish">><</if>>
		<<case 5>><<if $bus isnot "starfish">><<set $bus to "starfish">><<else>><<set $bus to "barb">><</if>>
		<<case 6>><<if $bus isnot "barb">><<set $bus to "barb">><<else>><<set $bus to "connudatus">><</if>>
		<<case 7>><<if $bus isnot "connudatus">><<set $bus to "connudatus">><<else>><<set $bus to "wolf">><</if>>
		<<case 8>><<if $bus isnot "wolf">><<set $bus to "wolf">><<else>><<set $bus to "harvest">><</if>>
		<<case 9>><<if $bus isnot "harvest">><<set $bus to "harvest">><<else>><<set $bus to "oxford">><</if>>
		<<case 10>><<if $bus isnot "oxford">><<set $bus to "oxford">><<else>><<set $bus to "danube">><</if>>
		<<case 11>><<if $bus isnot "danube">><<set $bus to "danube">><<else>><<set $bus to "mer">><</if>>
		<<case 12>><<if $bus isnot "mer">><<set $bus to "mer">><<else>><<set $bus to "cliff">><</if>>
		<<case 13>><<if $bus isnot "cliff">><<set $bus to "cliff">><<else>><<set $bus to "nightingale">><</if>>
	<</switch>>
	<<destination>>
<</widget>>

