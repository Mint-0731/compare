				<br><br>

				<<link [[도와준다 (0:01)|Maths Drugged Help]]>><<pass 1>><<famegood 5>><<detention -6>><<trauma -6>><</link>><<ldelinquency>><<ltrauma>>
				<br>
				<<link [[옮겨 적는다 (0:03)|Maths Drugged Copy]]>><<pass 3>><<set $mathsinfo += 1>><</link>><<note "+ Mathematical Insight" "green">>
				<br>
				<<link [[훔친다|Maths Drugged Rob]]>><<detention 6>><<set $mathsstim += 1>><</link>><<ggdelinquency>><<note "+ Stimulant" "green">>
				<br>
			<</addinlineevent>>
