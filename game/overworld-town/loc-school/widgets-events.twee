/* _args[0] - Alt text, _args[1] - altVersionCheck */
<<widget "whitneyRoofRuleBreak">>
	<<set _maleClothes to Object.keys($worn).filter((slot) => {
		return $worn[slot].gender is "m" and !["genitals", "under_upper", "under_lower"].includes(slot);
	})>>

	<<set $_wearingSkirt to (clothingData('lower', $worn.lower, "skirt") is 1)>>
	<<set $_whitneyMadAtUnderwear to _args[1] is "panties" and $_wearingSkirt and !$worn.under_lower.type.includes("naked") and
		($whitneypantiescheck is 1 or ($whitneypantiescheck is 2 and $worn.under_lower.gender isnot "f" and $settings.forcedCrossdressingEnabled))>>
	<<set $_whitneyMadAtSkirt to $settings.forcedCrossdressingEnabled and $whitneyskirtcheck gte 1 and (!$_wearingSkirt or ($worn.lower.reveal lte 200))>>
	<<set $_whitneyMadAtClothes to $settings.forcedCrossdressingEnabled and $whitneyCrossdressSchool gte 1 and _maleClothes.length>>

	<<if $_whitneyMadAtUnderwear or $_whitneyMadAtSkirt or $_whitneyMadAtClothes>>
		<<if _args[0]>>
			<<print _args[0]>>
		<<else>>
			휘트니의 찡그린 표정에 반응할 틈도 없이, <<he_ ga>> 당신의 손목을 붙잡는다.
		<</if>>

		<<if _args[1] is "skipFirstComment">>
		<<elseif $_whitneyMadAtSkirt and !$_wearingSkirt>>
			"내 규칙을 어겼으면 좀 자랑이라도 하고 다니지 그러냐? 치마조차 안 입었군."
		<<elseif $_whitneyMadAtUnderwear>>
			<<if $whitneypantiescheck is 1>>
				"내 규칙을 어겼다고 자랑하는 거냐? <<if $player.gender_appearance is "f">>팬티<<else>>속옷<</if>> 입지 말라고 했잖아. 농담 아니었는데."
			<<elseif $whitneypantiescheck is 2 and $worn.under_lower.gender isnot "f">>
				"내 규칙을 어겼다고 자랑하는 거냐? 속옷 입으라고 했잖아. 농담 아니었는데."
			<</if>>
		<<elseif $_whitneyMadAtSkirt>>
			"그 치마는 전혀 짧지 않잖아."
			<<set $_skipNextSkirtComment to true>>
		<<else>>
			"내 규칙을 어겼다고 자랑하는 거냐?"
		<</if>>
		<<if $daily.whitney.punished>><<He_ ga>> 한숨을 쉰다. "몇 번을 말해야 하냐?"<<npcincr Whitney love -1>><<llove>><</if>>
		<br><br>
		<<He_ nun>> 당신을 계단 쪽으로 끌어당겨 복도로 이끈다.
		<<if $_whitneyMadAtClothes>>
			<<He_ nun>> 조소한다. "내가 장님이냐? 네가 남자 옷을 입은 걸 내가 모를 거라고 생각했어?"
		<<elseif $_whitneyMadAtSkirt and !$_wearingSkirt>>
			<<He_ nun>> 조소한다. "네가 속옷을 보여주는 걸 기대하고 있었는데 말이지."
		<<elseif $_whitneyMadAtSkirt and !$_skipNextSkirtComment>>
			<<He_ nun>> 조소한다. "그 치마는 전혀 짧지 않잖아."
		<<else>>
			침묵은 당신이 복도에 도착한 순간 깨진다.
		<</if>>
		<br><br>
		<<whitneyRulePunishment true>>
		<<exitAll>>
	<</if>>
<</widget>>
