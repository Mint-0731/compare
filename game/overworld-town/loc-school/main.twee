<<if $fightstart is 1>>
	<<set $fightstart to 0>>
	<<neutral 1>>
	<<maninit>>
	<<set $enemytrust -= 100>>
	<<set $enemyanger += 200>>
	<<npcidlegenitals>>

	<<enableSchoolRescue "Leighton">>

	당신은 <<person1>>소년에게 달려들어 바닥에 함께 나동그라진다. <<person2>>다른 소년도 거기에 낀다.<<person1>>
