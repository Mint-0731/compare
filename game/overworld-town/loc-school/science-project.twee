		<<if $avery_mansion.schedule isnot "away" and $avery_mansion.schedule isnot "work">>
			<<set $_avery_present to true>>
		<</if>>
		<<if ($avery_mansion.schedule is "study" and !$avery_mansion.study_unlocked) or ($avery_mansion.study_unlocked is 1 and Time.hour is 23 and $_avery_present) or ["return", "party", "party_prepare", "date"].includes($avery_mansion.schedule)>>
			<<link [[다음|Mansion Study]]>><</link>>
		<<else>>
