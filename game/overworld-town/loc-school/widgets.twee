<</widget>>

<!-- "upperruined" doesn't take sets into account, so use "strip" and destroy the carried towel parts -->
<<widget "droptowel">>
	<<if _toweldrop is "both">>
		<<generalStrip "upper">>
		<<generalStrip "lower">>
	<<elseif _toweldrop is "lower">>
		<<generalStrip "lower">>
	<<elseif _toweldrop is "upper">>
		<<generalStrip "upper">>
	<</if>>
<</widget>>

<!-- Will check if the pc can drop a towel to expose themselves. Returns its result in "_exlevel" and "_toweldrop".-->
<<widget "checkdroptowel">>
	<<set _bottom to "nothing">>
	<<set _top to "nothing">>
	<<if hasSexStat("exhibitionism", 4)>>
		<<if ($worn.lower.name is "towel skirt" or $worn.lower.name is "large towel bottom") and $worn.over_lower.exposed gte 2>>
			<<if $worn.under_lower.exposed lt 1 or hasSexStat("exhibitionism", 5)>>
				<<set _bottom to "strip">>
			<</if>>
		<</if>>
		<<if ($worn.upper.name is "towel top" or $worn.upper.name is "large towel") and $worn.over_upper.exposed gte 2>>
			<<if $worn.upper.one_piece isnot 1 or _bottom is "strip">>
				<<set _top to "strip">>
			<</if>>
		<</if>>
	<</if>>

	<<if _bottom is "strip" and _top is "strip">>
		<<set _exlevel to ($worn.under_lower.exposed lt 1 ? 1 : 2)>>
		<<set _toweldrop to "both">>
	<<elseif _bottom is "strip">>
		<<set _exlevel to ($worn.under_lower.exposed lt 1 ? 1 : 2)>>
		<<set _toweldrop to "lower">>
	<<elseif _top is "strip">>
		<<set _exlevel to 1>>
		<<set _toweldrop to "upper">>
	<<else>>
		<<set _exlevel to 0>>
		<<set _toweldrop to "none">>
	<</if>>
<</widget>>

<<widget "school_infirmary_options">>
	<<if $passage isnot "School Infirmary Ask Painkiller">>
		<<schoolicon "infirmary">><<link [[진통제를 요청한다|School Infirmary Ask Painkiller]]>><</link>>
		<br>
	<</if>>
	<<if $passage isnot "School Infirmary Ask Bed">>
		<<bedroomicon>><<link [[침대 하나를 쓰게 해달라 요청한다|School Infirmary Ask Bed]]>><</link>>
		<br>
	<</if>>
	<<if $passage isnot "School Infirmary Cabinet">>
		<<pillicon>><<link [[캐비닛 안을 본다|School Infirmary Cabinet]]>><</link>>
		<br>
	<</if>>
	<br>
	<<getouticon>><<link [[떠난다|Hallways]]>><<endevent>><</link>>
	<br>
<</widget>>

<<widget "infirmary_excused">>
	<<switch $schoolstate>>
		<<case "first">>
			<<set $daily.school.scienceExcused to true>>
		<<case "second">>
			<<set $daily.school.mathsExcused to true>>
		<<case "third">>
			<<set $daily.school.englishExcused to true>>
		<<case "fourth">>
			<<set $daily.school.historyExcused to true>>
		<<case "fifth">>
			<<set $daily.school.swimmingExcused to true>>
	<</switch>>
<</widget>>

<<widget "enableSchoolRescue">>
	/* Call with all applicable conditions for a rescue in any order. ex: <<enableSchoolRescue "Whitney" "delinquency">> for scenes where Whitney or low delinquency can save you, or <<enableSchoolRescue "Leighton">> for scenes where just Leighton can save you. */
	/* Shouldn't be called without any arguments; just use the standard "enable_rescue" widget for those cases. */
	<<if $drugged lte 0>>
		<<set $_rescue to []>>

		<<if _args.includes("Whitney") and C.npc.Whitney.dom gte random(10, 25) and C.npc.Whitney.state is "active" and $whitneyromance is 1>>
			<<set $_rescue.push("Whitney")>>
		<</if>>

		/* There are no cases where Leighton being present and low delinquency are separate conditions for rescue, but there are some where both are required. ex: "Maths Note Molestation" */
		<<if _args.includesAll("delinquency", "Leighton") and $delinquency lt 400 and $pillory.tenant.special.name isnot "Leighton">>
			<<set $_rescue.push("Leighton")>>
		<<elseif _args.includes("delinquency") and $delinquency lt 400>>
			<<set $_rescue.push("delinquency")>>
		<<elseif _args.includes("Leighton") and $pillory.tenant.special.name isnot "Leighton">>
			<<set $_rescue.push("Leighton")>>
		<</if>>

		<<if $_rescue.includes("Whitney") and $_rescue.includes("delinquency", "Leighton")>>
			/* Safe Whitney rescue */
			<<set $rescue to 3>>
		<<elseif $_rescue.includes("Whitney")>>
			/* Lone Whitney rescue */
			<<set $rescue to 2>>
		<<elseif $_rescue.length gt 0 or !_args[0]>>
			/* Safe rescue */
			<<set $rescue to 1>>
		<</if>>
	<</if>>
<</widget>>

:: School Vending Machine Widget [widget]
/*
	$weekly.theft.vendingMachine {
		broken: boolean
		stolen: boolean
	}
	$daily.vendingMachine {
		used: boolean
	}
 */
<<widget "schoolVendingMachine">>
	<<set $weekly.theft.vendingMachine to $weekly.theft.vendingMachine || {}>>
	<<set $daily.vendingMachine to $daily.vendingMachine || {}>>
	<br>
	콘돔 자판기가 있다. 정부 청소년 부서의 지원을 받고 있다.
	<br>
	<<if !$brothelVending>>
		<<if $brotheljob and $fame.business gte 100>>
			<<set $brothelVending to {status: "idea", products: 0, condoms: 0, lube: 0, condomsSold: 0, lubeSold: 0, condomsToRefill: 0, lubeToRefill: 0, weeksRent: 0, weeksEmpty: 0}>>
			/* $brothelVending.status
			idea - 1 PC has had the idea but not talked to Briar
			asked - 2 Talked with Briar But not bought the machine
			bought 2 - 4 Bought the vending machine but not installed it
			sold - Briar sold the machine since it was empty for so long
			set 3 - 8 Installed the vending machine
			BITS of $brothelVending.products
			bit 0 - 1 Talked to the pharmacy nurse about reselling condoms
			bit 1 - 2 Talked to Sirris about selling lube */
			<br>
			자판기를 보자, <span class="pink">좋은 생각이 떠오른다</span>. 창관의 분장실에 자판기를 설치하면, 직원들이 콘돔이나 일에 필요한 다른 물건을 구입할 수 있을 것이다. <span class="gold">당신은 브라이어와 상의해 보기로 마음먹는다.</span>
			<br><br>
		<</if>>
	<</if>>
	/* Suggestion:
		When broken, the machine can be completely inoperable for a week.
		When stolen, the machine can still be operated normally, but held cash is set to 0:
		Each day the machine's stored wealth can be reset, and held cash could be randomly incremented.
		If you purchase condoms, you could sneakily regain the cash you spent.
		Optional: There could be more than 2 condoms in the machine.
	*/
	<<if $weekly.theft.vendingMachine.broken or $weekly.theft.vendingMachine.stolen>>
		<span class="red">자판기는 부서져 있다.</span>
	<<else>>
		<<if $daily.vendingMachine.used>>
			붉은 디스플레이에 다음과 같이 표시되어 있다: "<span class="red">품절</span>".
		<<else>>
			<<if $money gte 2000>>
				<<condomicon "machine">><<link [[콘돔을 산다 (2팩에 £20)|Vending Machine Buy]]>><</link>>
			<<else>>
				당신은 그것을 구매할 돈이 없다.
			<</if>>
		<</if>>
		<<if !Time.schoolTime>>
			<br>
			<<condomicon "machine">><<link [[훔친다|Vending Machine Rob]]>><</link>>
		<</if>>
	<</if>>
<</widget>>

<<widget "classRoomEarSlime">>
	<<if _args[0] is $daily.earSlimeSkipLesson and $justEntered>>
		당신은 슬라임의 명령을 무시하려 하지만, <<if $daily.earSlimeSkipLesson is "swimming">>수영장<<else>>교실<</if>>에 들어갈 수 없는 자신을 발견하게 된다.
		<br><br>
		<<if $daily.earSlimeSkipLesson is "swimming">>
			<<link [[다음|$lastChangingRoom]]>><<endevent>><</link>>
		<<else>>
			<<link [[다음|Hallways]]>><<endevent>><</link>>
		<</if>>
		<<unset $justEntered>>
		<<exitAll>>
	<<elseif _args[0] and !$daily.earSlimeSkipLesson and _args[0] isnot $weekly.earSlimeSkipLesson and numberOfEarSlime() and earSlimeMakingMundaneRequests() and $justEntered and random(0,200) gte 175 - $earSlime.corruption>>
		<<set $daily.earSlimeSkipLesson to _args[0]>>
		<<set $weekly.earSlimeSkipLesson to _args[0]>>
		<span @class="$earSlime.startedThreats ? 'lewd' : 'lblue'">당신의 머릿속에 있는 슬라임이 수업을 빠지라고 명령하는 것이 느껴진다.</span> 그것은 당신의 복종에 대한 보상을 약속한다<<if $earSlime.startedThreats>>. 동시에, 불복종에는 결과가 따를 것이라고 위협한다<</if>>.
		<br><br>
		<<link [[복종한다|School Lesson Slime]]>><<set $phase to 0>><<set $lessonPassage to $passage>><<corruption 1>><<pain -4>><<stress -6>><<trauma -12>><<sub 2>><</link>><<gcorruption>><<lpain>><<lltrauma>><<lstress>>
		<br>
		<<if $earSlime.startedThreats>>
			<<link [[반항한다|School Lesson Slime]]>><<set $phase to 2>><<set $lessonPassage to $passage>><<corruption -1>><<pain 8>><<stress 6>><<trauma 6>><<def 1>><</link>><<lcorruption>><<ggpain>><<ggtrauma>><<ggstress>>
		<<else>>
			<<link [[무시한다|School Lesson Slime]]>><<set $phase to 1>><<set $lessonPassage to $passage>><</link>>
		<</if>>
		<br>
		<<unset $justEntered>>
		<<exitAll>>
	<<elseif _args[0] and !$daily.earSlimeSkipLesson and _args[0] isnot $weekly.earSlimeSkipLesson and numberOfEarSlime() and $justEntered and random(0,100) gte 95 - ($earSlime.growth / 25) and $earSlime.exhibitionism gte 2>>
		<<if $earSlime.growth gte 200 and $earSlime.promiscuity gte 4>>
			<span class="lewd">당신 머릿속의 슬라임이 수업을 빠지고, 복도에서 자위하며 모여든 사람들에게 강간해달라고 말하기를 명령하는 것이 느껴진다.</span> <span class="red">그것은 복종을 기대하고 있다.</span>
		<<else>>
			<span class="lewd">당신 머릿속의 슬라임이 수업을 빠지고 복도에서 자위하라고 명령하는 것이 느껴진다.</span> 그것은 당신의 복종에 대한 보상을 약속하며, 불복종에는 결과가 따를 것이라고 위협한다.
		<</if>>
		<br><br>
		<<link [[복종한다|School Lesson 2 Slime]]>><<set $phase to 0>><<set $lessonPassage to $passage>><<corruption 1>><<pain -4>><<stress -6>><<trauma -12>><<sub 2>><</link>><<gcorruption>><<lpain>><<lltrauma>><<lstress>>
		<br>
		<<link [[반항한다|School Lesson 2 Slime]]>><<set $phase to 1>><<set $lessonPassage to $passage>><<corruption -1>><<pain 8>><<stress 6>><<trauma 6>><<def 1>><</link>><<lcorruption>><<ggpain>><<ggtrauma>><<ggstress>>
		<br>
		<<unset $justEntered>>
		<<exitAll>>
	<</if>>
<</widget>>

<<widget "eventshousekeeping">>
	<<cleareventpool>>

	<<addinlineevent "housekeeping_vacuum">>
		리버는 학생들에게 진공청소기의 작동법을 가르친다. 학생들은 각자 청소기를 하나씩 들고, 주방 구역의 먼지를 청소하는 일을 맡는다.
		<br><br>

		<<if $housekeeping gte 1000>>
			<<set _event_selection to random(1, 4)>>
		<<elseif $housekeeping gte 700>>
			<<set _event_selection to random(1, 3)>>
		<<elseif $housekeeping gte 400>>
			<<set _event_selection to random(1, 2)>>
		<<else>>
			<<set _event_selection to 1>>
		<</if>>
		<<if _event_selection is 4>>
			<<generatey1>><<npc "River" 2>><<person1>>
			<<person_ ga>> 교실 건너편에서 당신을 쳐다본다. 당신이 그쪽을 바라보자, <<his_ nun>> 자신의 청소기로 시선을 돌린다. <<His_ yi>> 얼굴에 미소가 번진다. <<He_ nun>> 당신을 향해 성큼성큼 다가온다.
			<br><br>

			<<He_ nun>> 당신과 몇 걸음 떨어진 곳에 멈춰서, 청소기를 당신에게 향한 채 전윈을 켠다.
			<br><br>

			청소기 소리에 귀가 먹먹해진다. 청소기의 흡입력 탓에 당신은 거의 넘어질 뻔한다. 리버가 소리치는 모습이 보이지만, 아무 소리도 들리지 않는다. <<person_ nun>> 패널 옆쪽을 두드려서 출력을 더욱 높인다.

			<<set $worn.upper.integrity -= 20>>
			<<set $worn.lower.integrity -= 20>>
			<<set $worn.under_lower.integrity -= 20>>
			<<set $worn.under_upper.integrity -= 20>>

			<<integritycheck>>
			<<exposure>>
			<br><br>
			<<if $exposed gte 1>>
				<<person_ nun>> 당신의 옷이 청소기에 빨려드는 것을 보며 만족스러운 미소를 짓는다. <<covered>> 리버의 얼굴이 창백해지고, <<person2>><<he_ nun>> 자신의 눈을 가린다. <<He_ nun>> <<person1>><<person_ rul>> 향해 손짓한다. <<he_ yi>> 의도를 알아차린 몇몇 학생들이, 더 큰 피해가 발생하기 전에 <<person1>><<person_ rul>> 제지한다.
				<br><br>
				<<link [[다음|Housekeeping Vacuum Heavy 2]]>><</link>>
				<br>
			<<else>>
				당신은 옷이 찢어지는 것을 느끼지만, 그것은 리버가 <<personPost>>에게 다가가 청소기를 끄고, <<him_ yi>> 귀를 잡아당기며 복도로 끌어내는 동안에도 찢어지지 않는다.
				<br><br>

				나머지 수업은 아무 일 없이 지나간다.
				<br><br>

				<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
				<br>
			<</if>>

		<<elseif _event_selection is 3>>
			<<generatey1>><<generatey2>><<person1>>
			당신은 <<person_ gwa>> <<person2>><<person_ ga>> 교실 건너편에서 당신을 쳐다보는 것을 알아차린다. <<person1>><<person_ ga>> 씩 웃더니, 그들은 당신 쪽으로 걸어오기 시작한다.
			<br><br>

			<<link [[무시한다|Housekeeping Vacuum Heavy Ignore]]>><</link>><<difficulty 50>>
			<br>
			<<link [[그들을 피한다|Housekeeping Vacuum Heavy Avoid]]>><<detention 1>><</link>><<gdelinquency>>
			<br>
		<<elseif _event_selection is 2>>
			<<generatey1>><<person1>>
			지루한 작업에 싫증이 난 듯한 <<person_ ga>>, 진공청소기의 출력을 최대치로 작동시키며 당신에게 달려든다. 기계가 당신의 셔츠 앞부분을 빨아들이며 앞쪽으로 팽팽하게 당긴다.<<gstress>><<stress 6>>
			<br><br>

			<<link [[견딘다|Housekeeping Vacuum Medium Endure]]>><<trauma 6>><</link>><<gtrauma>>
			<br>
			<<link [[선생님을 부른다|Housekeeping Vacuum Medium Call]]>><<status -1>><</link>><<lcool>>
			<br>
			<<link [[밀친다|Housekeeping Vacuum Medium Shove]]>><<detention 2>><</link>><<gdelinquency>>
			<br>
		<<else>>
			<<generatey1>><<person1>>
			당신은 <<worn_upper_name_ ga>> 잡아당겨지는 느낌을 받는다. <<person_ ga>> 당신의 옷자락을 청소기로 빨아들이고 있다. <<Hes_ nun>> 청소기를 카운터 아래쪽에 숨겨서 리버와 학생들 대부분에게 보이지 않도록 한다.
			<br><br>

			<<link [[견딘다|Housekeeping Vacuum Light Endure]]>><<trauma 6>><</link>><<gtrauma>>
			<br>
			<<link [[자리를 옮긴다|Housekeeping Vacuum Light Move]]>><</link>><<difficulty 80>>
			<br>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_pans">>
		<<if $delinquency gte 800>>
			<<set _event_selection to random(1, 4)>>
		<<elseif $delinquency gte 600>>
			<<set _event_selection to random(1, 3)>>
		<<elseif $delinquency gte 400>>
			<<set _event_selection to random(1, 2)>>
		<<else>>
			<<set _event_selection to 1>>
		<</if>>
		<<if _event_selection is 4>>
			<<npc "River">><<person1>>
			"너," 리버가 당신을 곧장 바라보며 말한다. <<He_ nun>> 더러운 냄비와 프라이팬 더미를 가리키며 말한다. "네 정리 실력을 좀 봐야겠다. 이것들을 닦거라. 혼자서." <<He_ nun>> 벽시계를 보며 말한다. "20분 주마."
			<br><br>

			<<link [[서두른다|Housekeeping Pans Hurry]]>><</link>><<housekeepingdifficulty 1 1000>>
			<br>
			<<link [[거절한다|Housekeeping Pans Refuse]]>><<detention 3>><</link>><<gdelinquency>>
			<br>
		<<elseif _event_selection is 3>>
			<<npc "River">><<person1>>
			리버는 학생들에게 냄비와 프라이팬을 깨끗이 닦으라고 시킨다. 아무렇게나 쌓여 있는 냄비와 프라이팬을 모아 개수대로 옮기는 것이 먼저다.
			<br><br>

			냄비 몇 개를 쌓아 올리고 돌아서자, 리버가 당신의 옆에 서 있다. <<He_ nun>> 잠깐 기다리라는 듯 손짓하더니, 더미에서 프라이팬 몇 개를 더 꺼내 당신의 냄비 위로 아무렇게나 내려놓는다.
			<br><br>
			"원래는 이렇게 한꺼번에 많이 드는 것은 현명하지 못한 일이지," <<he_ ga>> 말한다. "하지만 만일의 사태에도 대비해야지."
			<br><br>
			<<link [[최선을 다한다|Housekeeping Pans Best 2]]>><</link>><<housekeepingdifficulty 1 600>>
			<br>
			<<link [[항의한다|Housekeeping Pans Protest]]>><<detention 2>><</link>><<gdelinquency>>
			<br>
		<<elseif _event_selection is 2>>
			<<npc "River">><<person1>>
			리버의 눈이 교실을 훑는다. "냄비와 프라이팬을 설거지해야겠구나," <<he_ ga>> 교실의 한쪽 구석에 어지럽게 쌓인 것들을 가리키며 말한다. "다 같이 하겠지만, 먼저 누군가가 시범을 보여줬으면 좋겠는데."
			<br><br>

			선생님의 시선이 당신에게 멈춘다. "너. 어떻게 하는지 보여주렴."
			<br><br>

			<<link [[최선을 다한다|Housekeeping Pans Best]]>><<stress 6>><</link>><<gstress>><<housekeepingdifficulty 1 400>>
			<br>
			<<link [[무능한 척한다|Housekeeping Pans Feign]]>><<status 1>><<detention 1>><</link>><<gdelinquency>><<gcool>>
			<br>
		<<else>>
			리버는 학생들에게 냄비와 프라이팬을 깨끗이 닦는 것을 과제로 내 준다. 아무렇게나 쌓여 있는 냄비와 프라이팬을 모아 개수대로 옮기는 것이 먼저다.
			<br><br>

			<<link [[조심스럽게 움직인다|Housekeeping Pans Careful]]>><</link>>
			<br>
			<<link [[빠르게 움직인다|Housekeeping Pans Swift]]>><</link>><<housekeepingdifficulty 1 200>>
			<br>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_rubbish">>

		<<if $cool lte 40>>
			<<set _event_selection to random(1, 4)>>
		<<elseif $cool lte 80>>
			<<set _event_selection to random(1, 3)>>
		<<elseif $cool lte 120>>
			<<set _event_selection to random(1, 2)>>
		<<else>>
			<<set _event_selection to 1>>
		<</if>>
		리버는 학생들에게 쓰레기를 분리배출하는 것을 과제로 내 준다. 골판지, 종이, 유리, 금속, 플라스틱이 바퀴 달린 쓰레기통에 각각 담겨 있다. 범주의 예외에 속하는 일반 쓰레기를 담는 쓰레기통도 있다.
		<br><br>
		<<if _event_selection is 4>>
			<<npc "River">><<person1>>
			리버의 주머니에서 진동 소리가 난다. <<He_ nun>> 방해 운운하며 중얼거린다. "다들, 미안하구나," <<he_ ga>> 말한다. "몇 분만 자리를 비우마. 내가 없는 동안 얌전히 있도록."
			<br><br>
			<<him_ ga>> 나가자마자, 몇몇 불량 학생들이 기회를 잡는다.
			<<endevent>>
			<<generatey1>><<generatey2>><<generatey3>><<generatey4>><<person1>>
			그들이 당신을 에워싼다.
			<br><br>
			"우린 너 같은 쓰레기랑 같은 교실을 쓰는 데 지쳤거든," <<person_ ga>> 당신의 <<worn_upper_name_ rul>> 움켜쥐며 말한다. "그래서 너를 밖으로 내보내려고."
			<br><br>
			사방에서 뻗어 나온 손들이 당신을 붙잡으려 한다.<<gtrauma>><<gstress>><<trauma 6>><<stress 6>>
			<br><br>

			<<link [[수동적으로 행동한다|Housekeeping Bin Passive]]>><</link>>
			<br>
			<<link [[스스로 옷을 벗는다|Housekeeping Bin Undress]]>><</link>>
			<br>
			<<link [[싸운다|Housekeeping Bin Fight]]>><<set $fightstart to 1>><</link>>
			<br>
		<<elseif _event_selection is 3>>
			<<generatey1>><<generatey2>><<generatey3>><<person1>>
			교실 문을 두드리는 소리가 들린다. "리버 선생님," 레이턴의 목소리다. "잠시만."
			<br><br>
			리버는 주의 깊게 교실을 살핀 후 밖으로 나간다. 문이 닫히자마자, 문가로 달려간 <<person3>><<person_ ga>> 의자를 문에 기대어 리버를 복도에 가둔다.
			<br><br>
			<<person1>><<person_ ga>> 당신의 팔을 잡는다. "선생님도 없는데," <<he_ nun>> 교실 전체에 선언한다. <<person2>><<person_ ga>> 당신의 반대쪽 팔을 잡는다. "재밌게 놀자."
			<br><br>
			그들은 당신의 옷을 찢으려고 한다. 학생들 중 일부는 섬뜩한 호기심과 함께 지켜보고, 다른 이들은 시선을 돌린다.
			<br><br>

			<<link [[견딘다|Housekeeping Rubbish Endure]]>><<trauma 6>><<stress 6>><</link>>
			<br>
			<<link [[싸운다|Housekeeping Rubbish Fight]]>><<set $fightstart to 1>><</link>>
			<br>
		<<elseif _event_selection is 2>>
			<<generatey1>><<generatey2>><<generatey3>><<person1>>
			세 명의 불량학생, <<personPost>>, <<person2>><<person_ gwa>>, <<person3>><<person_ ga>> 당신을 둘러싼다. "네
			<<if $player.gender_appearance is "m">>
				자지 좀 보여줘 봐,"
			<<else>>
				보지 좀 보여줘 봐,"
			<</if>>
			<<person1>><<person_ ga>> 말한다.
			<br><br>
			나머지 두 명이 당신을 양옆에서 에워싼다.
			<br><br>

			<<link [[요구에 따른다|Housekeeping Rubbish Bid]]>><<trauma 6>><<stress 6>><</link>><<gtrauma>><<gstress>>
			<br>
			<<link [[주먹질한다|Housekeeping Rubbish Punch]]>><<detention 1>><</link>><<gdelinquency>>
			<br>
			<<link [[리버를 부른다|Housekeeping Rubbish Call Self]]>><<status -1>><</link>><<lcool>>
			<br>
		<<else>>
			<<generateyv1>><<person1>>
			불량 학생 한 무리가 <<person_ rul>> 괴롭히면서 상황을 더욱 흥미진진하게 만든다. <<Hes_ nun>> 인기 없는 학생이다. 모두가 못 본 척하고, <<person_ nun>> 너무 겁을 먹어서 리버를 부르지 못한다.
			<br><br>

			<<link [[리버를 부른다|Housekeeping Rubbish Call]]>><<famegood 10>><<status -1>><</link>><<lcool>>
			<br>
			<<link [[무시한다|Housekeeping Lesson]]>><<endevent>><</link>>
			<br>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_trip">>
		<<generatey1>><<person1>>
		리버는 당신에게 학습지를 배부하는 일을 맡긴다. 책상 사이를 걸어 다니며 학생들에게 학습지를 나눠주던 당신은, <<person_ ga>> 내민 다리에 방해받는다. 당신은 발을 헛디딘다.<<gpain>><<pain 4>><<gstress>><<stress 6>>
		<br><br>

		당신은 본능적으로 근처의 카운터를 잡아 균형을 유지하려 하지만, 손에 잡힌 것은 카운터 위에 놓인 그릇뿐이다. 당신은 결국 그릇과 함께 엉덩방아를 찧는다. 그릇이 당신의 머리 위로 떨어진다.
		<br><br>

		<<if $worn.lower.skirt_down is 1>>
			몇몇 학생들이 당신을 쳐다본다. 당신의 특정 부위를 말이다. 당신의 치마가 말려 올라가 <<undies_ rul>> 드러내 보이고 있다.
			<<if $worn.under_lower.type.includes("naked")>>
				<<ggtrauma>><<trauma 12>><<schoolrep_naked>>
			<<else>>
				<<gtrauma>><<trauma 6>>
			<</if>>
			<br><br>
			<<link [[다리 사이로 치맛자락을 잡아당긴다|Housekeeping Trip Tug]]>><</link>>
			<br>
			<<link [[그들에게 중지를 치켜든다|Housekeeping Trip Finger]]>><</link>>
			<br>
			<<if $worn.under_lower.type.includes("naked")>>
				<<if hasSexStat("exhibitionism", 5)>>
					<<link [[몸을 드러낸다|Housekeeping Trip Show Naked]]>><<fameexhibitionism 5>><</link>><<exhibitionist5>>
					<br>
				<</if>>
			<<else>>
				<<if hasSexStat("exhibitionism", 2)>>
					<<link [[몸을 드러낸다|Housekeeping Trip Show Undies]]>><<fameexhibitionism 2>><</link>><<exhibitionist2>>
					<br>
				<</if>>
			<</if>>
		<<else>>
			<<link [[웃어넘긴다|Housekeeping Trip Laugh]]>><</link>>
			<br>
			<<link [[리버에게 알린다|Housekeeping Trip Inform]]>><<status -1>><</link>><<lcool>>
			<br>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_sink">>
		<<npc "River">><<person1>><<generatey2>>
		리버는 더러운 식기로 가득한 통을 끌고 온다. "소매들 걷어라," <<he_ ga>> 말한다. "수업이 끝날 때는 전부 깨끗이 닦여 있어야 한다. 어서 시작하도록. 나는 다른 학생들을 데려오마." 학생들은 일제히 신음 소리를 낸다.
		<br><br>
		당신은 개수대에 물을 채운다.

		<<if $rng gte 81>>
			<<person2>><<person_ ga>> 당신에게 슬며시 다가와서, 당신의 뒤통수를 잡아 물속에 얼굴을 처박으려 한다.<<gtrauma>><<trauma 6>><<gstress>><<stress 6>>
			<br><br>

			<<link [[발버둥친다|Housekeeping Sink Struggle]]>><</link>><<physiquedifficulty 1 16000>>
			<br>
			<<link [[숨을 참는다|Housekeeping Sink Breath]]>><</link>><<swimmingdifficulty 1 1000>>
			<br>
			<<link [[침착함을 유지한다|Housekeeping Sink Calm]]>><<stress 6>><</link>><<gstress>>
			<br>
		<<else>>
			<<generateyv3>>
			<<person2>><<person_ ga>> <<person3>><<persons_ yi>> 머리를 그 속에 들이밀려다가, 제때 도착한 리버에 의해 저지당한다.
			<br><br>

			학생들은 식기를 깨끗이 닦았지만, 리버는 결과에 만족하지 못한다.
			<br><br>

			<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
			<br>
		<</if>>
	<</addinlineevent>>

	<<runeventpool>>
<</widget>>

<<widget "eventshousekeepingsafe">>
	<<cleareventpool>>
	<<addinlineevent "housekeeping_safe_1">>
		<<npc "River">><<person1>>
		리버는 학생들이 가정관리에 대한 구식 비디오를 끝까지 보도록 한다. 몇몇 학생들은 그것을 비웃는다. <<he_ nun>> 영상과 학생들을 전부 보기 위해 교실 뒤쪽으로 자리를 옮긴다.
		<br><br>

		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_safe_2">>
		<<npc "River">><<person1>><<generatey2>>
		리버는 학생들이 교과서를 읽는 동안 책상 사이를 어슬렁거린다.
		<<if $rng gte 6>>
			<<He_ nun>> 당신을 지목해서 본문의 일부를 낭독하게 한다. 어려워 보이지는 않는다.
			<br><br>

			<<link [[평범하게 읽는다|Housekeeping Read Normal]]>><</link>>
			<br>
			<<link [[연극조로 읽는다|Housekeeping Read Theatric]]>><</link>><<difficulty 80>>
			<br>
		<<else>>
			<<He_ nun>> <<person2>><<person_ rul>> 골라서, 본문의 일부를 낭독해달라고 부탁한다. <<Hes_ nun>> 너무 긴장해서, 리버가 그만 읽으라고 할 때까지 계속 말을 더듬는다.
			<br><br>

			<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
			<br>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_safe_3">>
		<<npc "River">><<person1>>
		리버는 수업 시간에 레시피를 시연한다. <<He_ nun>> 위생과 청결을 특히 강조한다. 누구도 <<him_ rul>> 감히 방해하지 않는다.
		<br><br>

		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_safe_4">>
		<<npc "River">><<person1>>
		리버는 학생들이 레시피에 대한 계획서를 쓰게 한다. "시작하기 전에 무엇을 해야 하는지 아는 것이 중요하니 말이다," <<he_ nun>> 말한다. "예상치 못한 일이나 실수가 있어서는 안 돼."
		<br><br>

		<<He_ nun>> 학생들 한 명 한 명의 어깨 너머로 작업물을 살펴보면서 자주 첨삭을 해 준다.<<gstress>><<stress 6>>
		<br><br>

		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_safe_5">>
		<<npc "River">><<person1>>
		리버는 학생들에게 레시피 시연 영상을 보여준다. 영상이 재생되는 동안, <<He_ nun>> 부엌을 서성이며 먼지가 없는지 살핀다. 학생들은 선생님의 관심이 다른 곳으로 향하자 안도하는 표정을 짓는다.
		<br><br>

		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "housekeeping_safe_6">>
		<<npc "River">><<person1>>
		리버는 바느질 시범을 보이기 위해 학생들을 자신의 주위로 모은다.
		<br><br>
		"자리로 돌아가거라," <<he_ nun>> 시연이 끝나자 선언한다. "이제는 개인 연습 시간이니까."
		<br><br>
		모두가 자리에 앉자, 리버는 책상 사이를 돌아다니며 학생 한 명 한 명의 어깨 너머로 게으름을 피우지 않는지를 확인한다.
		<br><br>
		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
		<br>
	<</addinlineevent>>

	<<runeventpool>>
<</widget>>

<<widget "canteenlunchoptions">>
	<<if $exposed gte 1>>
		<<link [[복도로 달려나간다|Hallways]]>><<endevent>><<set $eventskip to 1>><</link>>
		<br>
	<<else>>
		<<historyicon>><<link [[역사 수업을 들으러 간다 (0:01)|History Classroom]]>><<endevent>><<set $justEntered to true>><<pass 1>><</link>>
		<br>
		<<if _args[0] is "Kylar">>
			<<set _kylarLocation to getKylarLocation()>>
			<<if _kylarLocation.area is "rear_courtyard">>
				<<schoolicon "courtyard">><<link [[카일라를 따라 학교 뒷마당으로 간다 (0:03)|School Rear Courtyard]]>><<endevent>><<pass 3>><</link>>
				<br>
			<</if>>
		<</if>>
		<<schoolicon "library">><<link [[도서관으로 간다 (0:02)|School Library]]>><<endevent>><<pass 2>><</link>>
		<br>
		<<foodicon "eat">><<link [[식당에 남아있는다|Canteen]]>><<endevent>><</link>>
		<br>
	<</if>>
<</widget>>

<<widget "schoolnightpoolpartyend">>
	<<set $weekly.schoolNightPoolParty to false>>

	비밀스러운 파티가 막바지에 접어든다. 이미 지치고 만족스러운 얼굴을 한 학생들은 수영장을 떠나 탈의실로 향하기 시작한다. 탈의실은 빈 맥주 캔과 체액으로 엉망진창이다. 청소부나 야간 경비원은 분명 이 광경을 좋아하지 않을 것이다.
	<br><br>
	뒤쳐지고 싶지 않기에, 당신도 수영장을 나서기로 한다.
	<br><br>

	<<maleicon>><<link [[남학생 탈의실|School Boy Changing Room]]>><<endevent>><</link>>
	<br>
	<<femaleicon>><<link [[여학생 탈의실|School Girl Changing Room]]>><<endevent>><</link>>
	<br>
<</widget>>

<<widget "eventshousekeepingsleep">>
	<<cleareventpool>>

	<<addinlineevent "housekeepingCaught">>
		<<npc River>><<person1>>
		당신은 큰 소리에 잠에서 깬다. 벌떡 일어나자, 당신을 노려보는 리버가 보인다. "수업 중에 잠들면 자동으로 징계라는 걸 알겠지." <<ltiredness>><<detention 2>><<gdelinquency>>
		<br><br>
		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
	<</addinlineevent>>

	<<addinlineevent "housekeepingNotCaught">>
		<<npc River>><<person1>>
		당신의 눈이 번쩍 뜨인다. 잠들었던 것 같다. 다행히, 리버는 잠든 학생을 알아차리기에는 자신의 말에 과하게 몰두하고 있다. 지금은 말이다. <<ltiredness>>
		<br><br>
		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
	<</addinlineevent>>

	<<if random(1, 400) gte $cool>>
		<<addinlineevent "housekeepingTattletale">>
			<<npc River>><<person1>>
			"선생님!" <<generates2>><<person2>><<person_ ga>> 지른 소리에 당신은 갑자기 깨어난다. "<<pShes_ ga>> 수업 중에 자고 있어요!"
			<br><br>
			고개를 들자, 당신을 빤히 쳐다보는 리버와 마주친다. "징계다," 리버가 말한다. "내게 널 직접적으로 혼낼 권한이 없다는 걸 다행인 줄로 알거라."
			<br><br>
			<<if $submissive gte 1150>>
				당신의 곤경을 너무나 기뻐하는 <<person_ ga>> 미소 짓는 동안, 당신은 부끄러움에 고개를 숙인다.
			<<elseif $submissive lte 850>>
				당신은 <<person_ rul>> 노려본다. <<His_ yi>> 미소가 당신의 차가운 시선 아래에서 흔들린다. <<He_ nun>> 고자질이 현명한 행동이 아니었을지도 모른다는 사실을 깨닫는다.
			<<else>>
				당신은 <<personPost>>에게 얼굴을 찡그려 보인다. <<He_ nun>> 당신의 곤경을 너무나 기뻐하며, 미소로 답한다.
			<</if>>
			<<ltiredness>><<detention 2>><<gdelinquency>>
			<br><br>
			<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
		<</addinlineevent>>
	<</if>>

	<<addinlineevent "housekeepingLearn">>
		<<npc River>><<person1>>
		당신은 리버의 목소리를 들으며 잠든다. 당신은 복잡한 레시피를 따라하는 꿈을 꾼다. 깨어나 보니, 리버가 칠판으로 꿈 속의 그 레시피를 설명해 주고 있다. 당신은 무언가를 배웠다고 느낀다. <<ltiredness>><<ghousekeeping>><<housekeeping 2>>
		<br><br>
		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
	<</addinlineevent>>

	<<addinlineevent "housekeepingSewn">>
		<<generatey1>><<person1>>
		당신의 눈이 번쩍 뜨인다. 잠들었던 것 같다. 펜을 찾으려고 주변을 더듬던 당신은, 소매가 꿰매져 있는 것을 알아차린다. 옆자리에 앉은 <<person_ ga>> 당신을 보고 씩 웃는다.
		<br><br>
		급하게 재봉된 바늘땀이 어설퍼서, 당신은 남은 실밥을 풀어낼 수 있었다. 하지만, 리버는 당신에게 '빈둥거린다'는 이유로 징계를 내린다.<<ltiredness>><<gdelinquency>><<detention 2>>
		<br><br>
		<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
	<</addinlineevent>>

	<<if $drunk gte 1>>
		<<addinlineevent "housekeepingDrunk">>
			<<npc River>><<person1>>
			"무슨 문제 있나? 평소보다 집중력이 떨어지는 것 같은데." 고개를 든 당신은, 책상 옆에 선 리버를 바라보며 신음한다.
			<br><br>

			"너 지금... 취한-" 리버는 차마 말을 잇지 못한다. <<He_ nun>> 경악한 얼굴로 못마땅하게 고개를 젓는다. "징계." <<ltiredness>><<detention 6>><<ggdelinquency>>
			<br><br>
			<<link [[다음|Housekeeping Lesson]]>><<endevent>><</link>>
		<</addinlineevent>>
	<</if>>

	<<runeventpool>>
<</widget>>