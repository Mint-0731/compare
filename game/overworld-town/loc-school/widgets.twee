:: Widgets School [widget]
<<widget "schooleffects">>
	<<if Time.schoolDay>>
		<<if Time.hour lte 6>>
			<<set $schoolstate to "early">><<set $schoollesson to 0>>
		<<elseif Time.hour lte 8>>
			<<set $schoolstate to "morning">><<set $schoollesson to 0>>
		<<elseif Time.hour is 9>>
			<<set $schoolstate to "first">><<set $schoollesson to 1>>
		<<elseif Time.hour is 10>>
			<<set $schoolstate to "second">><<set $schoollesson to 1>>
		<<elseif Time.hour is 11>>
			<<set $schoolstate to "third">><<set $schoollesson to 1>>
		<<elseif Time.hour is 12>>
			<<set $schoolstate to "lunch">><<set $schoollesson to 0>>
		<<elseif Time.hour is 13>>
			<<set $schoolstate to "fourth">><<set $schoollesson to 1>>
		<<elseif Time.hour is 14>>
			<<set $schoolstate to "fifth">><<set $schoollesson to 1>>
		<<elseif Time.hour lte 16>>
			<<set $schoolstate to "afternoon">><<set $schoollesson to 0>>
		<<elseif Time.hour gte 17>>
			<<set $schoolstate to "late">><<set $schoollesson to 0>>
		<</if>>

		<!-- changing room is in use a bit longer than school is in session. also include changing times before first, after fifth and during midday break -->
		<<set $changingroomstate to "empty">>
		<<if (Time.hour gt 8 or Time.hour is 8 and Time.minute gte 58) and (Time.hour lt 15 or Time.hour is 15 and Time.minute lte 4)>>
			<<if Time.minute lte 4 or Time.minute gte 58>>
				<<if Time.hour gte 14 and Time.minute gte 58>>
					<<set $changingroomstate to "own">>
				<<else>>
					<<set $changingroomstate to "other">>
				<</if>>
			<</if>>
		<</if>>

		<<if $schoolpoolundress isnot undefined>>
			<span class="yellow">당신의 옷은 <<print $schoolpoolundress is "wardrobe" ? "옷장으로" : "<<putpost `$schoolpoolundress.slice(0,-1)`>>" + " 탈의실로">> 옮겨졌다.</span>
			<br>
			<<unset $schoolpoolundress>>
		<</if>>

		<!-- pool room itself is in use during $schoolstate only -->
		<<if $schoolstate is "fifth">>
			<<set $poolroomstate to "own">>
		<<elseif $schoollesson is 1>>
			<<set $poolroomstate to "other">>
		<<else>>
			<<set $poolroomstate to "empty">>
		<</if>>
	<<else>>
		<<if Time.hour lte 6>>
			<<set $schoolstate to "earlynoschool">><<set $schoollesson to 0>>
		<<elseif Time.hour gte 17>>
			<<set $schoolstate to "daynoschool">><<set $schoollesson to 0>>
		<<else>>
			<<set $schoolstate to "latenoschool">><<set $schoollesson to 0>>
		<</if>>
		<<set $changingroomstate to "empty">>
		<<set $poolroomstate to "empty">>
	<</if>>
<</widget>>

<<widget "advancelesson">><!-- advances time during a lesson and sets $phase to 1 if the lesson has ended -->
	<<set _time_left to 59 - Time.minute>>
	<!-- the lesson ends at 59th minute to give time to walk to the next class -->
	<<set _state to $schoolstate>>
	<<schooleffects>>

	<<if _state isnot $schoolstate>>
		<!-- only happens if we somehow jumped into another lesson, abort! -->
		<<set $phase to 1>>
	<<elseif _time_left gte 23>>
		<!-- make sure that there's at least a couple of minutes left for the next phase of a lesson -->
		<<pass 20>>
	<<else>>
	<!-- end of the lesson -->
		<<set $phase to 1>>
		<<pass _time_left>>
	<</if>>
	<<schooleffects>>
	<!-- an extra variable for use in adding learning points, stress, etc.
		1 point per 5 minutes + 1 for being present at the end of the lesson -->
	<<set _lesson_progress to (_time_left gte 20 ? 4 : Math.trunc(_time_left / 5)) + $phase>>
<</widget>>

<<widget "lessonEnd">>
	<<endevent>>
	종이 울려, <<print _args[1] is "sleep" ? "당신은 깜짝 놀라 깨어난다. 당신은 게슴츠레한 눈으로" : "수업이 끝났다는 것을 알려준다. 당신은">>
	<<storeon _args[0] "check">>
	<<if _store_check is 1>>
		<<storeon _args[0]>>
		당신의 코트를 들고
	<</if>>
	교실을 떠난다.
	<br><br>
	<<delinquency -1 "bonus">>

	<<if $weekly.schoolNightPoolParty is undefined and $rng gte 96>>
		<<set $weekly.schoolNightPoolParty to "intro">>

		<<generates1>><<person1>>
		학생 둘이 복도에서 당신을 지나친다. 당신은 대화 일부를 엿듣는다.
		<br><br>
		"그래, <span class="gold">오늘 밤이야</span>," 한 소년이 친구에게 말한다. "그냥 울타리를 뛰어넘어. 그거면 돼."
		<br><br>
		그들이 떠나자, 말소리는 복도의 소음에 묻혀 사라진다.
		<br><br>
		<<endevent>>
	<</if>>

	<<if _args[0] is "mathsClassroom" and $whitneymaths isnot undefined>>
		<!-- set whitney's state to "absent" after the lesson ends so that we can use mathsWhitneyAttendChance to put them back in class on the next day -->
		<!-- Note: if you want to know whether or not Whitney attended maths class, but class has already ended, you'll need to change how this system works. -->
		<<set $whitneymaths to "absent">>
	<</if>>
	<<if _args[0] is "historyClassroom" and $robinhistory isnot "missing" and $robinReunionScene isnot undefined>>
		<<link [[다음|Robin After Class]]>><</link>>
	<<else>>
		<<link [[다음|Hallways]]>><</link>>
	<</if>>
<</widget>>

<<widget "lessonEvents">>
	<<set $_mod to _args[1] or 1>> <!-- $_mod multiplies the effect that allure has on your odds of getting an unsafe event -->

	<<if dangerEvent($_mod, 8900)>>
		<<switch _args[0]>>
			<<case "maths">><<eventsmaths>>
			<<case "science">><<eventsscience>>
			<<case "history">><<eventshistory>>
			<<case "english">><<eventsenglish>>
			<<case "housekeeping">><<eventshousekeeping>>
		<</switch>>
	<<else>>
		<<switch _args[0]>>
			<<case "maths">><<eventsmathssafe>>
			<<case "science">><<eventssciencesafe>>
			<<case "history">><<eventshistorysafe>>
			<<case "english">><<eventsenglishsafe>>
			<<case "housekeeping">><<eventshousekeepingsafe>>
		<</switch>>
	<</if>>
<</widget>>


<<widget "schoolperiod">>
	<<if $exposed lte 0>>
		<<if $schoolstate is "morning" or ($schoolstate is "first" and Time.minute lte 58)>>
			<<scienceicon>><<link [[과학 수업을 들으러 간다 (0:01)|Science Classroom]]>><<set $justEntered to true>><<pass 1>><</link>>
			<br><br>
		<<elseif $schoolstate is "first" or ($schoolstate is "second" and Time.minute lte 58)>>
			<<if Time.weekDay is 3 or Time.weekDay is 5>>
				<<icon "housekeeping.png">><<link [[가정 수업을 들으러 간다 (0:01)|Housekeeping Classroom]]>><<set $justEntered to true>><<pass 1>><</link>>
				<br><br>
			<<else>>
				<<mathicon>><<link [[수학 수업을 들으러 간다 (0:01)|Maths Classroom]]>><<set $justEntered to true>><<pass 1>><</link>>
				<br><br>
			<</if>>
		<<elseif $schoolstate is "second" or ($schoolstate is "third" and Time.minute lte 58)>>
			<<englishicon>><<link [[영어 수업을 들으러 간다 (0:01)|English Classroom]]>><<set $justEntered to true>><<pass 1>><</link>>
			<br><br>
		<<elseif $schoolstate is "third" or ($schoolstate is "lunch" and Time.minute lte 58)>>
			<<foodicon "eat">><<link [[학생들을 따라 식당에 간다 (0:01)|Canteen]]>><<pass 1>><</link>>
			<br>
			<<historyicon>><<link [[역사 교실에서 기다린다 (0:01)|History Classroom]]>><<set $justEntered to true>><<pass 1>><</link>>
			<br><br>
		<<elseif $schoolstate is "lunch" or ($schoolstate is "fourth" and Time.minute lte 58)>>
			<<historyicon>><<link [[역사 수업을 들으러 간다 (0:01)|History Classroom]]>><<set $justEntered to true>><<pass 1>><</link>>
			<br><br>
		<<elseif $schoolstate is "fourth" or ($schoolstate is "fifth" and Time.minute lte 58)>>
			<<swimmingicon>><<link [[수영 수업을 들으러 간다 (0:01)|School Pool Entrance]]>><<set $justEntered to true>><<pass 1>><</link>>
			<br><br>
		<</if>>
	<</if>>
<</widget>>

<<widget "schoolperiodtext">>
	<<if $schoolstate is "morning">>
		과학 수업은 <<ampm 9 00>>에 시작한다.
		<br><br>
	<<elseif $schoolstate is "first" and Time.minute lte 58>>
		과학 수업은 <<ampm 9 00>>에 시작했다!
		<br><br>
	<<elseif $schoolstate is "first">>
		<<if Time.weekDay is 3 or Time.weekDay is 5>>
			가정 수업은 <<ampm 10 00>>에 시작한다.
			<br><br>
		<<else>>
			수학 수업은 <<ampm 10 00>>에 시작한다.
			<br><br>
		<</if>>
	<<elseif $schoolstate is "second" and Time.minute lte 58>>
		<<if Time.weekDay is 3 or Time.weekDay is 5>>
			가정 수업은 <<ampm 10 00>>에 시작했다!
			<br><br>
		<<else>>
			수학 수업은 <<ampm 10 00>>에 시작했다!
			<br><br>
		<</if>>
	<<elseif $schoolstate is "second">>
		영어 수업은 <<ampm 11 00>>에 시작한다.
		<br><br>
	<<elseif $schoolstate is "third" and Time.minute lte 58>>
		영어 수업은 <<ampm 11 00>>에 시작했다!
		<br><br>
	<<elseif $schoolstate is "lunch">>
		역사 수업은 <<ampm 13 00>>에 시작한다.
		<br><br>
	<<elseif $schoolstate is "fourth" and Time.minute lte 58>>
		역사 수업은 <<ampm 13 00>>에 시작했다!
		<br><br>
	<<elseif $schoolstate is "fourth">>
		수영 수업은 <<ampm 14 00>>에 시작한다.
		<br><br>
	<<elseif $schoolstate is "fifth">>
		수영 수업은 <<ampm 14 00>>에 시작했다!
		<br><br>
	<</if>>
<</widget>>

<<widget "classgrades">>
	<<if $schoolstate is "morning" or ($schoolstate is "first" and Time.minute lte 58)>>
		<<if $sciencetrait gte 4>>
					당신의 현재 과학 성적은 <span class="green">A*</span>이다. 이 수업에서 당신이 배울 것은 더 이상 없다.
				<<elseif $sciencetrait gte 3>>
					당신의 현재 과학 성적은 <span class="teal">A</span>이다. 당신은 여기서 가장 뛰어난 학생들 중 하나지만 아직 더 배울 것이 있다.
				<<elseif $sciencetrait gte 2>>
					당신의 현재 과학 성적은 <span class="lblue">B</span>이다. 성적은 가장 뛰어나지는 않지만, 그렇다고 가장 나쁘지도 않다.
				<<elseif $sciencetrait gte 1>>
					당신의 현재 과학 성적은 <span class="blue">C</span>이다. 나름 진전을 이루었지만 아직 더 배울 것이 많다.
				<<elseif $sciencetrait gte 0>>
					당신의 현재 과학 성적은 <span class="purple">D</span>이다. 아직 가야 할 길이 멀다.
				<<else>>
					당신의 현재 과학 성적은 <span class="red">F</span>이다. 당신은 이 수업에서 최악의 학생이다.
			<</if>>
		<<elseif $schoolstate is "first" or ($schoolstate is "second" and Time.minute lte 58)>>
		<<if $mathstrait gte 4>>
					당신의 현재 수학 성적은 <span class="green">A*</span>이다. 이 수업에서 당신이 배울 것은 더 이상 없다.
				<<elseif $mathstrait gte 3>>
					당신의 현재 수학 성적은 <span class="teal">A</span>이다. 당신은 여기서 가장 뛰어난 학생들 중 하나지만 아직 더 배울 것이 있다.
				<<elseif $mathstrait gte 2>>
					당신의 현재 수학 성적은 <span class="lblue">B</span>이다. 성적은 가장 뛰어나지는 않지만, 그렇다고 가장 나쁘지도 않다.
				<<elseif $mathstrait gte 1>>
					당신의 현재 수학 성적은 <span class="blue">C</span>이다. 나름 진전을 이루었지만 아직 더 배울 것이 많다.
				<<elseif $mathstrait gte 0>>
					당신의 현재 수학 성적은 <span class="purple">D</span>이다. 아직 가야 할 길이 멀다.
				<<else>>
					당신의 현재 수학 성적은 <span class="red">F</span>이다. 당신은 이 수업에서 최악의 학생이다.
			<</if>>
		<<elseif $schoolstate is "second" or ($schoolstate is "third" and Time.minute lte 58)>>
		<<if $englishtrait gte 4>>
					당신의 현재 영어 성적은 <span class="green">A*</span>이다. 이 수업에서 당신이 배울 것은 더 이상 없다.
				<<elseif $englishtrait gte 3>>
					당신의 현재 영어 성적은 <span class="teal">A</span>이다. 당신은 여기서 가장 뛰어난 학생들 중 하나지만 아직 더 배울 것이 있다.
				<<elseif $englishtrait gte 2>>
					당신의 현재 영어 성적은 <span class="lblue">B</span>이다. 성적은 가장 뛰어나지는 않지만, 그렇다고 가장 나쁘지도 않다.
				<<elseif $englishtrait gte 1>>
					당신의 현재 영어 성적은 <span class="blue">C</span>이다. 나름 진전을 이루었지만 아직 더 배울 것이 많다.
				<<elseif $englishtrait gte 0>>
					당신의 현재 영어 성적은 <span class="purple">D</span>이다. 아직 가야 할 길이 멀다.
				<<else>>
					당신의 현재 영어 성적은 <span class="red">F</span>이다. 당신은 이 수업에서 최악의 학생이다.
			<</if>>
		<<elseif $schoolstate is "lunch" or ($schoolstate is "fourth" and Time.minute lte 58)>>
		<<if $historytrait gte 4>>
					당신의 현재 역사 성적은 <span class="green">A*</span>이다. 이 수업에서 당신이 배울 것은 더 이상 없다.
				<<elseif $historytrait gte 3>>
					당신의 현재 역사 성적은 <span class="teal">A</span>이다. 당신은 여기서 가장 뛰어난 학생들 중 하나지만 아직 더 배울 것이 있다.
				<<elseif $historytrait gte 2>>
					당신의 현재 역사 성적은 <span class="lblue">B</span>이다. 성적은 가장 뛰어나지는 않지만, 그렇다고 가장 나쁘지도 않다.
				<<elseif $historytrait gte 1>>
					당신의 현재 역사 성적은 <span class="blue">C</span>이다. 나름 진전을 이루었지만 아직 더 배울 것이 많다.
				<<elseif $historytrait gte 0>>
					당신의 현재 역사 성적은 <span class="purple">D</span>이다. 아직 가야 할 길이 멀다.
				<<else>>
					당신의 현재 역사 성적은 <span class="red">F</span>이다. 당신은 이 수업에서 최악의 학생이다.
		<</if>>
	<</if>>
		<br><br>
<</widget>>

<<widget "exhibitorgasm">>
	<<if $orgasmdown gte 1>><<set $orgasmdown to 0>>
		<<if $orgasmcurrent lte 0>>
		<<elseif $orgasmcurrent lte 1>>
			당신은 속박에 저항하며 경련한다.
			<<if $enemyno gte 2>>
				<<if $player.penisExist and $orgasmcount lte 23>>
					당신이 경련하자 그들의 눈이 빛난다. "<<pShes_ ga>> 가고 있어!" <<person_ ga>> 외치며, 당신의 정액을 피하기 위해 뒤로 물러나면서도 경외심 가득한 눈으로 바라본다.
				<<else>>
					당신이 경련하자 그들의 눈이 빛난다. "<<pShes_ ga>> 가고 있어!" <<person_ ga>> 외친다.
				<</if>>
			<<else>>
				<<if $player.penisExist and $orgasmcount lte 23>>
				<<else>>
				<</if>>
			<</if>>
		<<elseif $orgasmcurrent is 2>>
			당신은 속박에 저항하며 다시 경련한다.
			<<if $enemyno gte 2>>
				<<if $player.penisExist and $orgasmcount lte 23>>
					"한 번 이상 일어날 수 있는 일이었구나!" <<person_ ga>> 말한다.
				<<else>>
					"한 번 이상 일어날 수 있는 일이었구나!" <<person_ ga>> 말한다.
				<</if>>
			<<else>>
				<<if $player.penisExist and $orgasmcount lte 23>>
				<<else>>
				<</if>>
			<</if>>
		<<else>>
		<</if>>
		<br><br>
	<</if>>
<</widget>>

:: Widgets Events Science [widget]
<<widget "eventsscience">>
	<<cleareventpool>>

	<<if ($player.gender_appearance is "m" and $worn.legs.gender is "f") or ($player.gender_appearance is "f" and $worn.legs.gender is "m") and $worn.legs.name.includes("gym socks")>>
		<<addinlineevent "scienceSocks" 1>>
			<<generates1>><<person1>>한 소년이 당신의 발을 본다.
			<<if $worn.legs.name is "girl's gym socks">>
				"왜 여자애들 양말을 신고 있어?" 그가 큰 소리로 묻는다. "그러면 뭔가 예뻐진 느낌이 드는 거야?"
			<<else>>
				"왜 남자애들 양말을 신고 있어?" 그가 큰 소리로 묻는다. "그러면 사람들이 네가 걸레라는 것을 잊어버릴 거라고 생각해?"
			<</if>>
			그의 친구들이 웃기 시작한다.
			<br><br>

			<<link [[걷어찬다|Science Kick]]>><<stress -12>><<trauma -6>><<detention 3>><</link>><<gdelinquency>><<ltrauma>><<lstress>>
			<br>
			<<link [[무시한다|Science Lesson]]>><<stress 6>><<trauma 6>><<endevent>><</link>><<gtrauma>><<gstress>>
			<br>
		<</addinlineevent>>
	<</if>>

	<<addinlineevent "scienceChemicals" 1>>
		학생들은 화학 물질을 가지고 실험한다.
		<br><br>

		한 <<generates1>><<person1>>소년이 당신의 옷에 산성 용액을 끼얹는다!
		"미안, 미끄러졌어." 그는 <<print either("히죽거리며","히죽거리며","히죽거리며","헉 하는 소리를 내며","어쩔 줄 모르며")>> 말한다.
		<br><br>

		<<set $worn.upper.integrity -= 20>>
		<<set $worn.lower.integrity -= 20>>
		<<set $worn.under_lower.integrity -= 20>>

		<<integritycheck no_text>>
		<<exposure>>

		<<if !$worn.upper.type.includes("naked") and !$worn.lower.type.includes("naked")>>
			그렇게 강한 산은 아니지만, 옷을 좀 망가뜨렸다.
		<<else>>
			산은 당신의 옷을 부식시키고, 곧 당신은 다른 학생들 앞에서 발가벗은 상태가 되었다! 당신은 최선을 다해 음란한 모습을 가려보려 하고, 곧 시리스가 수건을 갖고 달려온다.
			<<if $exhibitionismaction is "excited">>
				당신은 모든 학생들이 알몸을 잘 볼 수 있도록 한다.<<nudityPostend>>
			<<else>>
				당신은 몸을 가려 노출된 신체부위를 가리려 하나, 이미 학생들은 당신의 몸을 다 본 뒤다.
			<</if>>
			<<if $worn.lower.type.includes("naked") and $worn.under_lower.type.includes("naked")>>
				<<schoolrep_naked>>
			<</if>>
			<<towelup>>

		<</if>>
		<br><br>

		<<link [[다음|Science Lesson]]>><<endevent>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "scienceFront" 2>>
		<<npc Sirris>><<person1>>시리스는 당신에게 교실 앞으로 나오라 한다.
		<br><br>

		<<link [[다음|Science Event3]]>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "scienceTerrarium" 2>>
		학생들은 교실 가장자리에 늘어선 테라리움 주변에 둘러선다. 당신은 그 안에 든 식물들을 관찰하며 어떤 종인지를 알아내려 한다.
		<br><br>

		<<link [[다음|Science Terrarium]]>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "scienceDelinquents" 2>>
		불량학생들이 당신을 괴롭히려 한다.
		<br><br>

		<<link [[선생님께 도움을 구한다|Science Pick]]>><<status -10>><</link>><<llcool>>
		<br>
		<<link [[견딘다|Science Pick]]>><<set $phase to 1>><</link>><<gtrauma>><<gstress>>
		<br>
		<<link [[맞선다|Science Pick]]>><<set $phase to 2>><<detention 2>><</link>><<gdelinquency>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "scienceGroup" 2>>
		시리스가 학생들에게 둘씩 짝을 지으라 한다.
		<br><br>
		<<rng>>

		<<if $cool gte 80>>
			당신은 파트너를 찾아 함께 <<print either("양의 눈을","곤충을","벌레를","개구리를")>> 해부한다.
			<br><br>

			<<link [[해부에 집중한다|Science Dissection]]>><<scienceskill>><</link>><<gscience>>
			<br>
			<<link [[파트너와 논다|Science Dissection]]>><<trauma -1>><<stress -2>><<status 1>><<set $phase to 1>><</link>><<ltrauma>><<lstress>><<gcool>>
			<br>
		<<else>>
			<<wearProp "box">>
			다른 학생들이 당신을 피하기에, 당신은 파트너를 구할 수 없다. 시리스는 플라스틱 상자를 들고 들어왔다가, 당신이 혼자 있는 것을 보고 당신에게 말하기 위해 멈춘다.
			<br><br>

			"네게 맡길 일이 있단다. 이거랑 같은 상자가 학교 정문 옆의 창고에 있어. 가져다줄 수 있겠니?"
			<br><br>

			당신은 창고로 간다. 창고는 잠겨있지 않고, 안에는 상자가 있다. 매우 무겁다! 상자를 들기는 엄청 힘이 들었으나, 당신은 어떻게든 그 상자를 들고 교실로 돌아간다.
			<<physique>>
			<br><br>
			<<if $rng gte 21>>
				교실로 돌아오자, 다른 학생들은 개구리를 해부하느라 바쁘다. 파트너가 없기에 당신은 혼자서 한 마리를 해부한다.
				<<gscience>><<scienceskill>>
				<br><br>

				<<link [[다음|Science Lesson]]>><<endevent>><</link>>
				<br>
			<<else>>
				<<generatey1>><<generatey2>><<generatey3>>
				당신은 복도에서 담배를 피고 있는 세 명의 불량학생 옆을 지나친다. 상자에 가려져 당신의 눈에는 그들이 보이지 않았다. 그들은 복도를 따라 당신을 쫓아온다.

				<<person1>>한 소년이 당신의 치맛단을 붙잡고는 끌어내리려 한다!

				<<if $worn.under_lower.type.includes("naked")>>
					<span class="lewd">당신은 속옷을 입고 있지 않다는 것을 상기하고는 몸을 떤다!</span>
				<</if>>
				<br><br>

				"그녀가 이 밑에 뭘 입고 있는지 한 번 볼까." 다른 두 소년도 거기에 동참하려는듯 가까이 다가온다.
				<br><br>

				상자를 든 상태에서는 몸을 보호할 수 없다. 안에 든 것을 망가뜨리지 않으려면 몸을 숙여 상자를 내려놓아야 하겠지만, 그렇게 하면 더더욱 취약해질 것이라는 직감이 든다.
				<br><br>

				<<link [[상자를 떨구고는 몸을 보호한다|Science Dissection]]>><<handheldon>><<set $phase to 2>><<detention 2>><</link>><<gdelinquency>>
				<br>
				<<link [[그냥 참는다|Science Dissection]]>><<set $phase to 3>><<stress 2>><<trauma 2>><</link>><<gtrauma>><<gstress>>
				<br>
				<<link [[몸을 숙여 살며시 상자를 내려놓는다|Science Dissection]]>><<handheldon>><<set $phase to 4>><</link>>
			<</if>>
		<</if>>
	<</addinlineevent>>

	<<runeventpool>>
<</widget>>

<<widget "eventssciencesafe">>
	<<if $settings.condomLevel isnot 0 and !$scienceCondomIntro>>
		<<scienceCondomIntro>>
		<<exit>>
	<</if>>
	<<if $scienceproject is "none" and Time.days gte 2 and $mathsprojectdays isnot (21 + (7 - Time.weekDay))>>
		<<scienceProject>>
		<<exit>>
	<</if>>
	<<cleareventpool>>
	<<set $_linkSkip to false>>

	<<addinlineevent "scienceBook" 2>>
		<<npc Sirris>><<person1>>
		시리스는 교과서 $rng쪽을 펼치라고 말한다.
		<<if $worn.handheld.name isnot "naked" and !$worn.handheld.type.includes("bookbag")>>
			당신은 책가방을 잊고 온 것을 너무 늦게 깨달았다.
			<<if C.npc.Sirris.love gte 10>>
			시리스가 당신을 점잖게 꾸짖지만, 여분의 교과서를 건네준다. "이번에는 봐주지만, 앞으로는 더 준비를 잘 해 오거라."
			<<else>>
				시리스가 그의 머리를 가로젓는다. "미안하지만, 다음 번에는 더 준비를 잘 해 와야 한다," 그가 당신에게 여분의 교과서를 건네주며 꾸짖는다. <<detention 1>><<gdelinquency>>
			<</if>>
		<<else>>
			교실은 느긋한 분위기다. 대부분의 학생들은 교과서를 읽기보단 수다를 떠는 데에 더 집중한다.
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceVideo" 1>>
		시리스는 <<print either("환경","우주","자기장","전자","화학 결합","아인슈타인","과학적 방법론의 선구자들","아이작 뉴턴","핵융합","효소의 역할", "DNA")>>에 대한 짧은 영상을 튼다. 교실은 느긋한 분위기다. 대부분의 학생은 영상을 보지만, 많은 이들이 계속해서 수다를 떨고 있다.
	<</addinlineevent>>

	<<addinlineevent "scienceExperiment" 1>>
		<<generates1>><<person1>>
		<<switch random(1,4)>>
			<<case 1 2>>
				<<wearProp "science flask">>
				학생들은 화학 물질을 가지고 실험한다. 당신은 조금이라도 흘리지 않으려 조심한다.
			<<case 3>>
				<<wearProp "science flask">>
				학생들은 화학 물질을 가지고 실험한다. 한 소년이 실수로 자기 옷에 화학 물질을 흘린다. 당황한 소년은 그의 옷이 녹기 시작하는 걸 보고는 교실에서 달아난다.
			<<case 4>>
				한 소년이 <<print (random(1,5) is 1 ? "실수로" : "'실수로'")>> <<generates2>><<person2>>다른 소녀의 옷에 화학 물질을 쏟는다. 당황한 소녀는 그의 옷이 녹기 시작하는 걸 보고는 교실에서 달아난다.
		<</switch>>
	<</addinlineevent>>

	<<addinlineevent "scienceDelinquents" 1>>
		불량학생 몇 명이 공부벌레 한 명을 놀리기 시작한다. 시리스는 그들을 교실 반대편으로 옮긴다.
	<</addinlineevent>>

	<<addinlineevent "scienceSexTape" 1>>
		시리스는 사람의 번식에 관한 영상을 튼다.
		<<if Time.days gte 25 and $rng % 3 is 0>>/*1 in 3 chance, and won't happen too early*/
			<br><br>
			전혀 교육용 영상처럼 보이지 않는다. 자세하다. 아주 자세하다. 간단히 말해서 14분짜리 홈메이드 섹스 영상이다. 여기서 유일하게 '교육적'인 부분은 시리스가 주기적으로 영상을 멈추고는 어떤 신체 부위가 핥아지고, 쓰다듬어지고, 빨리고, 물리거나 박히고 있는지에 대한 퀴즈를 낼 때 뿐이다.
			영상에는 한 번도 등장인물들의 얼굴이 나오지 않으나, 그 중 한 명이 시리스일 것 같다는 의심이 들기 시작한다.
			<br>
			두 커플이 헐떡이며 오르가즘을 느끼는 장면까지, 모든 학생이 완전히 몰입한 채로 지켜 본다.
			<<garousal>><<arousal 200>>
			<br><br>
			"꽤 노골적인 영상이었다는 건 알아." 시리스가 말한다. "하지만 좋은 과학자들은 비위가 강하지. 인간은 동물이야. 그리고 이건 순전히 동물의 행동을 관찰하는 것과 같지. 사실과 용어에 대해 아는 것만큼이나 실제 섹스가 무엇이고 어떤 식으로 진행되는지에 대해 이해하는 것도 중요해."
			<<awarenessup 200 1>>
		<<else>>
			아주 교육적인 내용이다. 성건강, 성병, <<if $settings.pregnancySpeechEnabled>>임신, <</if>>피임과 합의에 대해 광범위하게 이야기를 하고 있다.
			곧 신체 부위의 이름이 붙은 간단한 도식과 거기에 연관된 세포 종류 이야기를 첨가하여, 섹스의 기본 원리에 대한 이야기로 넘어간다.
			<<awarenessup 100 1>>
			<br><br>
			교실은 느긋한 분위기다. 대부분의 학생은 영상을 보지만, 많은 이들이 계속해서 수다를 떨고 있다.
			<<if playerBellyVisible() and $settings.pregnancySpeechEnabled>>당신은 당신이 처해있는 상황과, 당신 안의 귀중한 생명에 대해 끊임없이 상기되어지고 있다.<<lstress>><<stress -10>><</if>>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceQuestion" 1>>
		<<npc Sirris>><<person1>>
		시리스는 학생들에게 질문을 한다. 당신은 답을 알 것 같다.
		<<set $_linkSkip to true>>
		<br><br>
		<<link [[손을 든다|Science Event1]]>><<set $phase to 1>><<stress 1>><<scienceskill 1>><</link>><<gstress>><<gscience>>
		<br>
		<<link [[고개를 숙이고 있는다|Science Event1]]>><</link>>
		<br>
	<</addinlineevent>>

	<<addinlineevent "scienceAnatomy" 1>>
		<<if $player.gender_appearance is "m">><<generatesf1>><<else>><<generatesm1>><</if>>
		시리스는 교실을 돌아보다가, 당신을 잠깐 쳐다보고는 한 <<person1>>소년에게 교실 앞쪽으로 나오라 한다.
		<br><br>
		시리스는 그에게 미소 짓는다.
		<<rng>>
		<<if $scienceprogression gte 2>>
			그는 불안한 모습이다. "이번 수업은 인체 해부학에 관한 것이야. 그러니 옷을 전부 벗어주렴. 하나도 남기지 말고. 너무 부끄러워 하진 마렴. 수업에서 아주 중요한 부분이니 말이야."
			<br><br>
			<<if $rng lte 35>>
				<<set $_studentLeaves to true>>
			<<else>>
				그 소년은 <<print either("흥분한 듯 따른다.", "기꺼이 따른다.", "아무 생각 없이 따른다.", "마지못해 따른다.", "금방이라도 울음을 터트릴 것 같지만, 순순히 고개를 끄덕인다.", "울면서 따른다.")>>
				그는 옷을 벗고, 그 즉시 모두의 시선이 그에게로 향한다. 그는 교실 앞에 알몸으로 서서, 몸 이곳저곳을 손으로 가리킨다.
				<<if $scienceprogression gte 3>>
					그 뒤 시리스는 그에게 책상 위로 올라가 그의 다리를 벌리라고 한다. 시리스는 <<if $NPCList[0].penis isnot "none">>그의 페니스를 잡고는<<else>>질경을 사용해<</if>> 흥분한 학생들에게 더 자세하게 보여준다.
					<<if $scienceprogression gte 4>>
						마침내 상황은 걷잡을 수가 없게 된다. 일부 학생들이 '손을 대자' 그는 비명을 지른다. 곧 통제력을 되찾자,
					<</if>>
				<</if>>
				시리스는 수업을 마치며, 그에게 옷을 입게 시키고는 자리로 돌려보낸다.
				<br><br>

				당신은 그에게 약간 죄책감을 가지나, 수업이 더 흥미로워진 것은 분명하며 무언가를 배운 것 같다.
				<<gscience>><<scienceskill>>
			<</if>>
		<<elseif $scienceprogression gte 1>>
			"이 부분을 위해서는 옷을 벗어줘야 한단다. 너무 걱정하진 마렴. 속옷은 입고 있어도 되니까."
			<br><br>
			<<if $rng lte 25>>
				<<set $_studentLeaves to true>>
			<<elseif $rng lte 35>>
				<<set $_studentNotWearingUnderwear to true>>
			<<else>>
				그 소년은 <<print either("흥분한 듯 따른다.", "기꺼이 따른다.", "아무 생각 없이 따른다.", "마지못해 따른다.", "금방이라도 울음을 터트릴 것 같지만, 순순히 고개를 끄덕인다.", "울면서 따른다.")>>
				그는 속옷을 벗고, 그 즉시 모두의 시선이 그에게로 향한다.
				시리스는 수업을 계속하며, 그의 몸 이곳저곳을 가리키며 다양한 기능을 설명한다.
				시리스는 곧 설명을 끝내고, 그에게 옷을 입게 시키고는 자리로 돌려보내 수업을 재개한다.
				<br><br>

				당신은 그에게 약간 죄책감을 가지나, 수업이 더 흥미로워진 것은 분명하며 무언가를 배운 것 같다.
				<<gscience>><<scienceskill>>
			<</if>>
		<<else>>
			"걱정하지 마렴. 해부하거나 하진 않을 거니까."
			<br><br>
			몇 분동안 시리스는 여러 뼈와 장기들에 대한 얘기를 하며, 그의 몸 이곳저곳을 가리키며 그 위치를 설명한다. 흥미로운 내용이다.
			<<gscience>><<scienceskill>>
		<</if>>

		<<if $_studentNotWearingUnderwear>>
			그 소년은 시리스에게 뭔가를 속삭인다.
			<br><br>
			시리스는 얼굴을 새빨갛게 붉히고는 재빠르게 그에게 자리에 앉으라 한다. "다시 생각해보니, 얘들아, 어... 그냥 해부학 그림을 쓰자." 시리스가 말한다. "이게 더... 잘 보이거든."
		<<elseif $_studentLeaves>>
			<<print either(
				"그 소년은 곧바로 교실을 뛰쳐나가서는 돌아오지 않는다.",
				"그 소년은 중립적인 표정을 짓고는 말없이 교실을 나간다.",
				"그 소년은 걱정스러운 표정을 짓고는 화장실을 사용하고 싶다고 부탁하더니, 책상에서 그의 물건들을 챙겨 나간다. 그는 돌아오지 않는다."
			)>>
			<br><br>
			"그럼 전에 쓰던 해부학 그림을 써야겠구나." 시리스가 말한다. "미안하다, 얘들아."
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceHelp" 1>>
		<<set $_linkSkip to true>>
		<<if $dissociation gte 1>>
			<<npc Sirris>><<person1>>시리스가 다가온다. "괜찮니?" 그가 묻는다. "딱히...좋아 보이지 않아서 말이야."
			<br><br>

			<<link [[괜찮아요|Science Event2]]>><</link>>
			<br>
			<<link [[감정을 주체하지 못한다|Science Event2]]>><<set $phase to 1>><</link>>
			<br>
		<<else>>
			시리스가 다가온다. "뭔가 설명해줄 거라도 있을까?"
			<br><br>

			<<link [[네|Science Event2]]>><<set $phase to 2>><<scienceskill 1>><</link>><<gscience>>
			<br>
			<<link [[아니오|Science Event2]]>><<set $phase to 3>><</link>>
			<br>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceMetals" 1>>
		금속을 이용한 실험이 진행된다.
		<<if $science gte 600>>
			당신은 실험 절차를 쉽게 이해하고, 여유롭게 시간을 관리한다. <<stress -3>><<lstress>>
		<<else>>
			당신은 지시 사항을 이해하는 것에 어려움을 겪지만, 어떻게든 시간내에 실험을 마친다.  
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "sciencePlants" 1>>
		다양한 식물종을 이용한 실험이 진행된다.
		<<if $backgroundTraits.includes("plantlover")>>
			당신에게 있어 실험은 사소한 일이다. 당신은 더 큰 식물들의 줄기를 감상하는 것에 시간을 보낸다. <<stress -3>><<arousal 200>><<lstress>><<garousal>>
		<<elseif $science gte 600 or $tending gte 600>>
			당신은 실험 절차를 쉽게 이해하고, 다양한 식물들을 감상하며 시간을 보낸다. <<stress -2>><<trauma -2>><<lstress>><<ltrauma>>
		<<else>>
			당신은 지시 사항을 이해하는 것에 어려움을 겪지만, 어떻게든 시간내에 실험을 마친다.  
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceBird" 1>>
		<<npc Sirris>><<person1>>
		시리스는 조류의 습성과 번식에 대한 강의를 시작한다.
		<<if $harpy gte 6>>
			프레젠테이션 자료에 황무지의 사진이 등장하자, 당신은 꽥 소리를 간신히 참는다.
		<<elseif $syndromebird gte 1>>
			당신은 거대 매의 특이한 짝짓기 습성을 떠올리며 미소 짓는다. <<arousal 200>><<garousal>>
		<<elseif hasSexStat("deviancy", 3)>>
			당신은 이 강의에 묘한 매력을 느끼기 시작한다. <<arousal 200>><<garousal>>
		<<else>>
			당신은 총배설강에 대한 <<his_ yi>> 자세한 설명에 얼굴을 찌푸린다. <<trauma 3>><<gtrauma>>
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceWolf" 1>>
		<<npc Sirris>><<person1>>
		시리스는 개의 습성과 번식에 대한 강의를 시작한다.
		<<if $wolfgirl gte 6>>
			시리스가 개의 주식에 대한 부분을 설명할 무렵, 당신은 입술을 핥으며 입맛을 다신다.
		<<elseif $syndromewolves gte 1>>
			당신은 자신의 무리를 떠올리며, 그들과 함께 숲속을 달리는 것에 대해 상상하기 시작한다. <<stress -3>><<lstress>>
		<<elseif hasSexStat("deviancy", 3)>>
			당신은 이 강의에 묘한 매력을 느끼기 시작한다. <<arousal 200>><<garousal>>
		<<else>>
			당신은 최대한 집중하지만, 흥미로운 주제는 아니다 .
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceCat" 1>>
		<<npc Sirris>><<person1>>
		시리스는 고양이의 습성과 번식에 대한 강의를 시작한다.
		<<if $cat gte 6>>
			프레젠테이션 자료에 쥐 그림이 등장하자, 당신은 꼬리가 살랑거리고 눈이 날카로워지는 것을 느낀다.
		<<elseif hasSexStat("deviancy", 3)>>
			당신은 이 강의에 묘한 매력을 느끼기 시작한다. <<arousal 200>><<garousal>>
		<<else>>
			당신은 최대한 집중하지만, 흥미로운 주제는 아니다 .
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceCow" 1>>
		<<npc Sirris>><<person1>>
		시리스는 소의 습성과 번식에 대한 강의를 시작한다.
		<<if $cow gte 6>>
			프레젠테이션 자료에 부드럽고 푸른 풀밭이 등장하자, 당신은 '음메' 소리를 간신히 참는다.
		<<elseif $lactating gte 1 and $settings.breastFeedingEnabled and $milk_volume gte 1000>>
			당신은 자신에게 다른 학생들에 비해 더 많은 소와의 공통점이 있다는 생각을 갖기 시작한다. <<stress 3>><<gstress>>
		<<elseif $lactating gte 1 and $settings.breastFeedingEnabled>>
			당신은 자신에게 소와의 공통점이 있다는 생각을 갖기 시작한다.
		<<elseif hasSexStat("deviancy", 4)>>
			당신은 이 강의에 묘한 매력을 느끼기 시작한다. <<arousal 200>><<garousal>>
		<<else>>
			당신은 최대한 집중하지만, 흥미로운 주제는 아니다 .
		<</if>>
	<</addinlineevent>>

	<<addinlineevent "scienceFox" 1>>
		<<npc Sirris>><<person1>>
		시리스는 여우의 습성과 번식에 대한 강의를 시작한다.

		<<if $fox gte 6>>
			당신은 수업에 집중하기 위해 최선을 다하지만, 당신의 눈길은 끊임없이 다른 학생들의 학용품에 쏠린다. 당신은 그들의 소지품을 가져가고 싶은 강렬한 충동을 느낀다.
		<<elseif hasSexStat("deviancy", 3)>>
			당신은 이 강의에 묘한 매력을 느끼기 시작한다. <<arousal 200>><<garousal>>
		<<else>>
			당신은 최대한 집중하지만, 흥미로운 주제는 아니다 .
		<</if>>
	<</addinlineevent>>
	<<runeventpool>>

	<<if $_linkSkip is false>>
		<br><br>
		<<link [[다음|Science Lesson]]>><<endevent>><</link>>
	<</if>>
<</widget>>

<<widget "eventssciencesleep">>
	<<cleareventpool>>
	<<set $_linkSkip to false>>

	<<addinlineevent "scienceCaught">>
		<<npc Sirris>><<person1>>
		당신의 책상을 두드리는 날카로운 소리가 들린다. 놀라서 몸을 일으킨 당신은 시리스의 엄격한 시선과 마주친다. <<He_ nun>> 한숨을 쉰다. "징계." <<ltiredness>><<detention 2>><<gdelinquency>>
	<</addinlineevent>>

	<<addinlineevent "scienceNotCaught">>
		<<npc Sirris>><<person1>>
		당신은 눈을 번쩍 뜬다. 깜빡 잠든 것이 분명하다. 당신은 아무 일도 없었던 척하며 고개를 들고 하품을 참는다. 시리스는 여전히 수업을 이어가는 중이며, 당신을 눈치채지 못한 것 같다. <<ltiredness>>
	<</addinlineevent>>

	<<if random(1, 400) gte $cool and $worn.upper.name isnot "naked">>
		<<addinlineevent "scienceIce">>
			차가운 무언가가 등줄기를 타고 흘러내리며 당신을 놀라 깨어나게 한다. <<willpowerdifficulty 1 300 no_text>>

			<<if $willpowerSuccess>>
				<span class="green">당신은 비명을 간신히 억누르며 침착함을 유지한다</span>. 조심스럽게 <<worn_upper_name_ rul>> 탐색하자, 오늘 실험에서 쓰고 남은 얼음 조각이 하나 나온다. <<generates1>><<person1>><<person_ ga>> 침착한 반응에 실망한 듯 당신을 바라본다. 당신은 녹아가는 얼음 조각을 책상 위에 올려둔다. 수업은 중단되지 않고 이어진다.
				<<ltiredness>><<stress 6>><<gstress>>
			<<else>>
				<span class="red">당신은 책상에서 벌떡 일어나며 비명을 지른다</span>. 오늘 실험에서 쓰고 남은 얼음 조각 하나가 <<worn_upper_name_ yi>> 안쪽에서 떨어진다. <<gstress>><<stress 6>>
				<br><br>

				<<generates1>><<person1>><<person_ ga>> 웃음을 터뜨린다.
				<<if $submissive gte 1150>>
					모든 학생들이 당신을 쳐다보자, 당신은 새빨개진 얼굴로 황급히 제자리에 앉는다.
				<<elseif $submissive lte 850>>
					당신은 자리에 다시 앉기 전에 <<him_ rul>> 노려본다. 다른 학생들이 당신을 쳐다본다.
				<<else>>
					당신은 다시 자리에 앉아, 다른 학생들의 시선을 애써 무시한다.
				<</if>>
				<br><br>

				시리스가 걱정스러운 표정으로 달려온다. "무슨 일이니?"
				<br><br>

				당신과 <<person_ nun>> 서로를 동시에 손가락질한다. <br>
				"<<pShe_ nun>> 졸고 있었어요!" <br>
				"<<He_ ga>> 제 등에 얼음 조각을 집어넣었어요!"
				<br><br>

				<<if $delinquency gte 400>>
					시리스가 당신에게 말을 건다. "저 말이 사실이니?"
					<br><br>
					"네, 하지만..."
					<br><br>
					"'하지만'은 없어. 내 수업에서 조는 건 있을 수 없는 일이란다," 시리스는 당신에게 징계 처분을 내리고는 교실 앞으로 돌아간다. <<detention 6>><<gdelinquency>>

				<<elseif $delinquency gte 200>>
					시리스는 찌푸리며 당신과 <<personPost>> 모두를 조용히 시킨다. "됐다. 징계 시간에 반성하도록 하렴." <<nnpc_He_ nun Sirris>> 둘 모두에게 징계 처분을 내리고는 교실 앞으로 돌아간다.
					<<detention 4>><<gdelinquency>>

				<<else>>
					시리스가 <<personPost>>에게 말을 건다. "저 말이 사실이니?"
					<br><br>
					"맞아요, 하지만..."
					<br><br>
					"'하지만'은 없어. 이 수업에서 장난은 용납될 수 없단다. 그러다가 사고가 나는 법이니까," 시리스는 엄하게 말한다. <<nnpc_He_ nun Sirris>> <<personsimplePost>>에게 징계 처분을 내리고는 교실 앞으로 돌아간다.

				<</if>>
			<</if>>
		<</addinlineevent>>
	<</if>>

	<<if random(1, 400) gte $cool>>
		<<addinlineevent "scienceTattletale">>
			<<npc Sirris>><<person1>>
			"선생님," <<generates2>><<person2>><<person_ ga>> 말한다. "<<pShes_ ga>> 수업 중에 자고 있어요!"
			<br><br>
			<<personsimple_ yi>> 목소리가 당신을 깨운다. 책상에서 고개를 들자, 당신을 바라보는 선생님이 보인다. 시리스가 고개를 내젓는다. "징계."
			<br><br>
			<<person2>>
			<<if $submissive gte 1150>>
				당신의 곤경을 너무나 기뻐하는 <<person_ ga>> 미소 짓는 동안, 당신은 부끄러움에 고개를 숙인다.
			<<elseif $submissive lte 850>>
				당신은 <<person_ rul>> 노려본다. <<His_ yi>> 미소가 당신의 차가운 시선 아래에서 흔들린다. <<He_ nun>> 고자질이 현명한 행동이 아니었을지도 모른다는 사실을 깨닫는다.
			<<else>>
				당신은 <<personPost>>에게 얼굴을 찡그려 보인다. <<He_ nun>> 당신의 곤경을 너무나 기뻐하며, 미소로 답한다.
			<</if>>
			<<ltiredness>><<detention 2>><<gdelinquency>>
		<</addinlineevent>>
	<</if>>

	<<if $settings.watersportsEnabled>>
		<<addinlineevent "sciencePiss">>
			당신은 사타구니에서부터 따듯한 기운이 다리 아래로 퍼지는 것을 느낀다. 당신은 깜짝 놀라서 고개를 든다. 당신의 갑작스러운 움직임과 물방울 떨어지는 소리는 교실 전체의 주의를 끌기에 충분했다.<<underlowerwet 200>><<lowerwet 200>>
			<br><br>

			<<generates1>><<person1>><<person_ ga>> 당신 발밑의 물웅덩이를 가리키며 말한다. "세상에, <<pshe_ ga>> 오줌을 쌌어!" 모든 학생들이 당신의 실금에 교실이 떠나가라 웃음을 터뜨린다.
			<br><br>

			당신은 따듯한 물이 담긴 컵에서 손을 떼지만, 이미 늦었다. 당신 옆자리에 앉은 <<generates2>><<person2>><<person_ ga>> 자신의 친구를 팔꿈치로 툭 치며 말한다. "통할 거라고 했잖아."
			<br><br>

			시리스가 수건을 들고 달려와 당신의 노출된 몸을 가리고 뒷정리를 도와준다. <<nnpc_He_ nun Sirris>> <<personPost>>에게 곧바로 징계를 내려 상황을 안정시키려 하지만, 웃음소리와 그에 뒤따를 소문까지 멈추지는 못한다. <<ltiredness>><<llcool>><<status -15>><<gtrauma>><<trauma 6>><<gstress>><<stress 6>>
		<</addinlineevent>>
	<</if>>

	<<if $sydneyScience is 1>>
		<<addinlineevent "scienceSydneyWake">>
			<<npc Sydney>><<person1>>
			<<run statusCheck("Sydney")>>
			<<if _sydneyStatus.includes("corrupt")>>
				당신의 피부 위로 부드러운 압력이 느껴진다. 누군가가 그 위에 글씨를 쓰는 것 같다. 당신이 눈을 뜨고 하품하는 순간 그 감촉은 사라진다. 여전히 수업 중인 시리스는 상황을 눈치채지 못한다.
				<br><br>

				시드니는 미소 지으며, 펜을 쥔 채로 당신에게 손을 흔들어 보인다.
				<<if $settings.bodyWritingLevel gte 2>>
					<<sydneyBodywritingLocation>>
					<<if _writingFail isnot 1>>
						"일어나서 다행이야."
						<br><br>
						아래를 내려다본 당신은 <<bodypart _bodypart>>에 적힌 문구를 확인한다: <<sydneyBodywriting sleepyhead>>
						<br><br>
					<<else>>
						"일어나서 다행이야. 내가 뭔가를 적을 공간이 없던 건 아쉽지만."
					<</if>>
				<<else>>
					"일어나서 다행이야. 내 펜의 잉크가 다 떨어져 있었던 건 아쉽지만."
				<</if>>
			<<else>>
				당신은 무언가가 팔을 쿡쿡 찌르는 느낌에 눈을 뜬다. 시드니가 무심하게 당신을 펜으로 찌르고 있다. <<He_ nun>> 당신이 깨어난 것을 확인하자 찌르기를 멈추고 미소 짓는다.
				<br><br>

				당신은 아무 일도 없었다는 듯 고개를 들고, 하품을 참으며 시드니에게 고개를 끄덕인다. 시리스는 아무것도 모른 채 수업을 이어간다.
			<</if>>
		<</addinlineevent>>
	<</if>>

	<<if $drunk gte 1>>
		<<addinlineevent "scienceDrunk">>
			<<npc Sirris>><<person1>>
			당신의 책상을 두드리는 날카로운 소리가 들린다. 그 소리에 맞춰 머리가 울리자, 당신은 항의의 신음소리를 낸다. <<gpain>><<pain 6>>
			<br><br>

			당신은 고개를 들어 시리스를 올려본다. <<He_ nun>> 만취한 당신의 상태가 마음에 들지 않는 것 같다.
			<br><br>

			"수업 중에 배운 것이 없니? 술을 마실 생각이라면, 최소한 책임감 있게 행동하렴. 내가 널 수업에서 쫓아내지 않는 걸 다행으로 생각하고."
			<br><br>

			시리스는 실망한 듯 고개를 내저으며 교실 앞쪽으로 돌아간다.
		<</addinlineevent>>
	<</if>>

	<<runeventpool>>

	<<if $_linkSkip is false>>
		<br><br>
		<<link [[다음|Science Lesson]]>><<endevent>><</link>>
	<</if>>
<</widget>>

<<widget "scienceCondomIntro">>
	<<set $scienceCondomIntro to true>>
	<<npc Sirris>><<person1>>
	시리스가 작은 상자 더미를 교실 앞으로 나르고 있다. "너희들은 이제 모두 성인이 되었지만, 어떤 부모님은 여전히 너희들에게 이야기를 해주지 않았다고 확신한단다. 혹은, 너희들 중 몇몇은 내 <<if C.npc.Sydney.pronoun is "m">>아들<<else>>딸<</if>>처럼, 평생 금욕 생활을 하겠다고 생각하고 있겠지."
	그는 작은 상자를 앞에 있는 학생들에게 건네기 시작했고, 학생들은 차례로 상자를 뒤로 건네기 시작한다. 당신은 몇몇 학생들이 상자를 살펴보며 낄낄대는 것을 들었고, 다른 학생들은 당황한 기색을 역력하게 보이고 있다.
	<br><br>

	"이것은 콘돔이란다. 너희들은 인생의 전성기에 있고 호르몬이 왕성하게 분비되기 때문에, 너희들은 항상 이것을 몇 개 쯤은 가지고 다니기를 원할 거다. 이것들은 계획하지 않은 아이를 가질 가능성을 줄여줄 뿐만 아니라, 너희들을 안전하게 해 줄 거란다." 시리스는 그의 책상 아래에서 크고, 이상한 모양의 과일을 꺼냈다.
	<br><br>

	"착용 방법은 매우 간단해. 여기 포장지를 찢어서, 끝부분에 대고, 아래로 굴리면 되지. 하지만, 이 부분을 아래로 누르지 말거라. 이 부분을 저장팁이라고 하는데, 액체가 새는 것을 막아주니까." 시리스가 과일에 콘돔을 씌우는 동작에 일부 학생들은 얼굴이 붉어지는 듯하다. <<arousal 200>><<garousal>>
	<br><br>

	"너희들 중 누구도 계속 금욕할 거라고는 생각하지는 않지만, 너희들이 안전하게 지내길 기대하마. 때가 되면 이것들을 꼭 사용하고. 내가 직접 주머니에서 돈을 꺼내 샀으니, 이것들이 한번도 뜯기지 않은 채 쓰레기통에 있는 걸 볼일이 없었으면 좋겠구나. 콘돔이 다 떨어지면, <span class="gold">학교 화장실의 자판기에서 더 살 수 있단다. 나이팅게일 거리에 있는 병원 약국에서도 콘돔과 다른 피임약들을 팔고 있지</span>." 당신은 콘돔 상자를 내려다본다. <<awarenessup 200 5>><<gcondoms 3>>
	<br><br>

	<i>콘돔은 음란한 액체를 막아, 의도치 않은 수정을 방지하고, 안과 밖 모두를 청결하게 해줍니다. 또한 이것은 순수성의 손실을 줄이고, 흥분 상승을 낮추는데 도움이 될 것입니다. 하지만, 약간의 찢어질 가능성이 있습니다, 특히 격렬한 성관계 중에는 말이죠. 최상의 결과를 얻으려면 피임과 함께 사용하세요.</i>
	<br><br>
	<<link [[다음|Science Lesson]]>><<endevent>><</link>>
