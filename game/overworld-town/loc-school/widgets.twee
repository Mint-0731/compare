					<</if>>
				<</if>>

				<<if hasSexStat("promiscuity", 4)>>
					<<set _lines.push({text: `<<print either("인치베어","글렌라이딩","넛포드")>>라는 도시 출신의 교활한 <<pcGenderPost>>에 대한.`, lewdness: 2})>>
				<</if>>
			<</if>>

			<<set _picked = _lines.pluck()>>

