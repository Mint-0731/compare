:: Mansion Kitchen
<<set $location to "avery_mansion">><<set $bus to "avery_kitchen">><<set $avery_passage to $passage>><<set $outside to 0>><<effects>><<avery_mansion>>

<<avery_mansion_contents>>


:: Mansion Dining
<<set $location to "avery_mansion">><<set $bus to "avery_dining">><<set $avery_passage to $passage>><<set $outside to 0>><<effects>><<avery_mansion>>

<<avery_mansion_contents>>

:: Mansion Lounge
<<set $location to "avery_mansion">><<set $bus to "avery_lounge">><<set $avery_passage to $passage>><<set $outside to 0>><<effects>><<avery_mansion>>

<<avery_mansion_contents>>


:: Mansion Lounge Piano
<<set $location to "avery_mansion">><<set $bus to "avery_lounge">><<set $avery_passage to $passage>><<set $outside to 0>><<effects>><<avery_mansion>>
<<set $daily.pianoPlayed ||= 0>>
<<wearProp "piano">>
<<if currentSkillValue("handskill") gte 1000>>
	<<set _pianoSkill to 5>>
	<<if random(1, 5) is 5 and $seabird_lullaby>>
		On a whim, you play
		<<if $seabird_lullaby gte 2>>
			<span class="teal">Seabird's Lullaby</span>.
		<<else>>
			the <span class="teal">familiar melody</span>.
		<</if>>
		As if hearing it again would stir up some long-lost memory. No such revelation comes.
		<br><br>

		You hum it to yourself as you play.
		<br><br>

		Unsatisfied, you repeat the words you heard. They don't sound right coming out of your mouth. However, as you do, you find yourself adding new notes subconsciously.
	<<else>>
		<span class="green">You play the piano with masterful grace.</span>
	<</if>>
<<elseif currentSkillValue("handskill") gte 800>>
	<<set _pianoSkill to 4>>
	<span class="teal">You play some songs on the piano, expertly performing some more advanced compositions.</span>
<<elseif currentSkillValue("handskill") gte 600>>
	<<set _pianoSkill to 3>>
	<span class="blue">You play the piano with competence, managing a few full songs without error.</span>
<<elseif currentSkillValue("handskill") gte 400>>
	<<set _pianoSkill to 2>>
	<span class="purple">You play some simple songs, only hitting awkward notes occasionally.</span>
<<elseif currentSkillValue("handskill") gte 200>>
	<<set _pianoSkill to 1>>
	<span class="pink">You don't really know what you're doing, and send shrill notes throughout the mansion.</span>
<<else>>
	<<set _pianoSkill to 0>>
	<span class="red">You clumsily slam your fingers into the keys.</span>
<</if>>
<<set $daily.pianoPlayed++>>

<<if $avery_mansion.schedule is "lounge">>
	<<if _pianoSkill gte Math.floor(C.npc.Avery.rage / 20) and _pianoSkill gte 2>>
		<<if $averyragerevealed and C.npc.Avery.rage gte 60>>
			<span class="blue">Avery tolerates it.</span>
		<<else>>
			<<if _pianoSkill gte 3>>
				<span class="teal">Avery seems to enjoy your performance.</span>
			<<else>>
				<span class="teal">Avery laughs, seeming to think your attempts are endearing.</span>
			<</if>>
		<</if>>
	<<elseif $averyragerevealed>>
		<<set $daily.pianoPlayedRage ||= 0>>
		<<if $daily.pianoPlayedRage gte 3>>
			<<set $daily.pianoPlayBlocked to true>>
			Avery stomps over to the piano and <span class="red">slams the key cover shut on your fingers</span>. <<gggpain>><<pain 15>><<npcincr Avery rage 1>><<garage>>
		<<elseif $daily.pianoPlayedRage gte 2>>
			"Last warning." <<npcincr Avery rage 1>><<garage>>
		<<elseif $daily.pianoPlayedRage gte 1>>
			"I said stop." <<npcincr Avery rage 1>><<garage>>
		<<else>>
			"Knock it off, that noise is distracting me." <<npcincr Avery rage 1>><<garage>>
		<</if>>
		<<set $daily.pianoPlayedRage++>>
	<<else>>
		<<if _pianoSkill gte 3>>
			<span class="teal">Avery seems to enjoy your performance.</span>
		<<else>>
			<span class="teal">Avery laughs, seeming to think your attempts are endearing.</span>
		<</if>>
	<</if>>
<</if>>
<br><br>

<<avery_mansion_contents>>

:: Mansion Display
<<set $location to "avery_mansion">><<set $bus to "avery_display">><<set $avery_passage to $passage>><<set $outside to 0>><<effects>><<avery_mansion>>

<<avery_mansion_contents>>

:: Mansion Display Loosen
<<effects>>

<<if $avery_antiques.bolt is 1>>
	You try to loosen the bolt protecting the more valuable antiques.
<<else>>
	You try to loosen one of the bolts protecting the more valuable antiques.
<</if>>
<br><br>

<<if $avery_antiques.bolt_progress gte 5>>
	<span class="green">The bolt comes loose!</span>
	<<set $avery_antiques.bolts -= 1>>
	<<if $avery_antiques.bolts lte 8 and !$avery_antiques.exposed.includes("dagger") and !$avery_antiques.stolen.includes("dagger")>>
		<<set $avery_antiques.exposed.pushUnique("dagger")>>
		The dagger is within reach.
	<<elseif $avery_antiques.bolts lte 6 and !$avery_antiques.exposed.includes("amulet") and !$avery_antiques.stolen.includes("amulet")>>
		<<set $avery_antiques.exposed.pushUnique("amulet")>>
		The amulet is within reach.
	<<elseif $avery_antiques.bolts lte 0 and $avery_antiques.progress lte 3>>
		<<set $avery_antiques.exposed.pushUnique("mask")>>
		The mask is within reach.
	<</if>>
	<<set $avery_antiques.bolt_progress to 0>>
<<else>>
	You manage to wiggle it a little, but can't yet pull it free.
<</if>>
<br><br>

Bolts remaining:
<<if $avery_antiques.bolts is 10>>
	<span class="red">10</span>
<<elseif $avery_antiques.bolts is 9>>
	<span class="pink">9</span>
<<elseif $avery_antiques.bolts is 8>>
	<span class="purple">8</span>
<<elseif $avery_antiques.bolts is 7>>
	<span class="purple">7</span>
<<elseif $avery_antiques.bolts is 6>>
	<span class="blue">6</span>
<<elseif $avery_antiques.bolts is 5>>
	<span class="blue">5</span>
<<elseif $avery_antiques.bolts is 4>>
	<span class="blue">4</span>
<<elseif $avery_antiques.bolts is 3>>
	<span class="lblue">3</span>
<<elseif $avery_antiques.bolts is 2>>
	<span class="lblue">2</span>
<<elseif $avery_antiques.bolts is 1>>
	<span class="teal">1</span>
<<elseif $avery_antiques.bolts is 0>>
	<span class="green">0!</span>
<</if>>
<br><br>

<<link [[Next|Mansion Display]]>><</link>>
<br>

:: Mansion Display Consider
<<effects>>


You lift the glass protecting Avery's gold antiques. They're arranged in a row, dagger, amulet, and mask. The gold alone must be worth a lot, irrespective of their value as antiques.
<br><br>

There's nothing stopping you from taking them. However, Avery is sure to notice their absence.
<br><br>

<<if $avery_antiques.exposed.includes("dagger")>>
	<<link [[Steal the dagger|Mansion Display Steal Dagger]]>><<set $antiquemoney += 4000>><<museumAntiqueStatus "antiquegolddagger" "found">><<set $avery_antiques.exposed.delete("dagger")>><<set $avery_antiques.stolen.pushUnique("dagger")>><</link>>
	<br>
<</if>>
<<if $avery_antiques.exposed.includes("amulet")>>
	<<link [[Steal the amulet|Mansion Display Steal Amulet]]>><<set $antiquemoney += 4000>><<museumAntiqueStatus "antiquegoldamulet" "found">><<set $avery_antiques.exposed.delete("amulet")>><<set $avery_antiques.stolen.pushUnique("amulet")>><</link>>
	<br>
<</if>>
<<if $avery_antiques.exposed.includes("mask")>>
	<<link [[Steal the mask|Mansion Display Steal Mask]]>><<set $antiquemoney += 12000>><<museumAntiqueStatus "antiquegoldmask" "found">><<set $avery_antiques.exposed.delete("mask")>><<set $avery_antiques.stolen.pushUnique("mask")>><</link>>
	<br>
<</if>>
<<link [[Step away|Mansion Display]]>><</link>>
<br>

:: Mansion Display Steal Dagger
<<effects>><<wearProp "antique gold dagger">>

You take the gold dagger. It's heavy, and the blade is blunt. It's probably more dangerous as a small club than a dagger.
<br><br>

<<link [[Next|Mansion Display]]>><</link>>
<br>

:: Mansion Display Steal Amulet
<<effects>><<wearProp "antique gold amulet">>

You take the gold amulet. Crooked spokes emanate from the centre in a disturbing symbol, but the garishness of the gold detracts from the effect.
<br><br>

<<link [[Next|Mansion Display]]>><</link>>
<br>


:: Mansion Display Steal Mask
<<effects>><<wearProp "antique gold mask">>

You take the gold mask. Dark eyes stare up at you. The metal around them is damaged, as if something were removed with a blade.
<br><br>

<<link [[Next|Mansion Display]]>><</link>>
<br>


:: Mansion Bedroom
<<set $location to "avery_mansion">><<set $bus to "avery_bedroom">><<set $avery_passage to $passage>><<set $outside to 0>><<effects>><<getTarget true>><<avery_mansion>>


<<avery_mansion_contents>>

:: Mansion Bed
<<effects>>
<<wearoutfit>>
<<if $avery_mansion.schedule is "sleep">>
	You snuggle under the covers beside Avery.
<<else>>
	You snuggle under the covers.
<</if>>
<<if $wraith.state and $wraithPrison and ($moonstate is "evening" or $moonstate is _nightstate)>>
	You feel anxious, and your eyes dart over to the mirror.
<</if>>
<br><br>


<<nightmareCheck "Mansion Sleep">>
<<generateSleepLinks "Mansion Sleep">>
<<link [[Climb out of bed|Mansion Bedroom]]>><<storeon "Mansion Bed">><<set $wardrobe_location to "mansion_wardrobe">><<loadTempHairStyle>><<endevent>><</link>>

:: Mansion Sleep
<<set _autosavehere to true>>
<<sleep>>
<<effects>>

<<if $wraith.nightmare is 2 and Time.isBloodMoon() and !_avery_interrupt>>
	<<sleepeffects>>
	You dream of a beautiful figure, cloaked in white, standing under the red moon. It has its arms spread out to you in a welcoming gesture. You can feel its gaze boring into your mind as you step closer.
	<br><br>

	It's surrounded by trees, all bending inwards, and floating above a lake. Everything moves around you, and you find yourself hanging above a large ruin. You can't breathe.
	<br><br>

	You slowly open your eyes, and sluggishly stand from the bed. <<if $avery_mansion.schedule is "sleep">>You make sure not to wake Avery.<</if>> Your ears are ringing.
	<br><br>

	<<wraithPossess "mansion">>
	<<storeon "Mansion Bed" "wardrobe">>
	<span class="nextLink"><<link [[Walk.|Mansion Bedroom]]>><<rainWraith>><</link>></span>
	<br>
<<else>>
	<<wakingEffects $sleepHoursTotal>>
	<<if ["dryheaving","nausea"].includes(_wakingEffect)>>
		<br><br>
		You slept soundly, but now feel a little rough.
		<br><br>
	<<elseif $nightmares gte 1 and $controlled is 0>>
		You <<if _wakingEffect>>dreamed of<<else>>dream you are<</if>> being hunted by something <<if ["haunt", "despair"].includes($wraith.state) and $rng lte 25>>pale<<else>>dark<</if>> and terrible.
	<<else>>
		<<if ($specialClothesEffects.bimbo.total gte random(100,1000) || $specialClothesEffects.pimp.total gte random(100,1000)) or $arousal gte ($arousalmax / 10) * 9>>
			<<wetDream>>
		<<elseif !_wakingEffect>>
			You sleep soundly.
			<br><br>
		<<else>>
			<br><br>
		<</if>>
	<</if>>

	<<sleepeffects>>

	<<if _sleepinterrupt>>
		<<if _avery_interrupt is "injury">>
			<<npc Avery>><<person1>>
			You're awoken by the sound of the front gates opening, followed by an unfamiliar car driving through. It stops outside the mansion. A door opens, closes, then the car drives away.
			<br><br>

			You hear another car door open, and close, in the garage. You climb out of bed, and investigate.
			<br><br>
			<<set $wardrobe_location to "mansion_wardrobe">>
			<<wardrobeSelection true>>
			<<radiooutfits>>
			<br><br>

			<<link [[Next|Mansion Return Broken Bed]]>><<bedclotheson "Mansion Bed">><</link>>
			<br>

		<<elseif _avery_interrupt is "work">>
			<<npc Avery>><<person1>>
			You're awoken by the sound of the bedroom door opening, and slamming against the wall. Avery stands in the doorway. <<He>> is home from work.
			<br><br>
			<<set $wardrobe_location to "mansion_wardrobe">>
			<<wardrobeSelection true>>
			<<radiooutfits>>
			<br><br>

			<<link [[Next|Mansion Return Bed Work]]>><<bedclotheson "Mansion Bed">><</link>>
			<br>
		<<elseif _avery_interrupt is "valentines_missed">>
			<<npc Avery>><<person1>>
			You're awoken by the sound of the bedroom door opening, and slamming against the wall. Avery stands in the doorway, eyes fixed on you.
			<br><br>

			<<set $wardrobe_location to "mansion_wardrobe">>
			<<wardrobeSelection true>>
			<<radiooutfits>>
			<br><br>

			<<link [[Next|Avery Valentines Missed Intro]]>><<unset $avery_valentines_missed>><<set $avery_valentines.missed_approach to true>><</link>>
			<br>

		<<elseif _avery_interrupt is "valentines_ready">>
			<<set $avery_valentines.ready to true>>
			<<npc Avery>><<person1>>
			Someone shakes your shoulder. It's Avery, wearing <<his>> best. "I'm ready when you are," <<he>> says. "For the <span class="gold">Valentine's</span> date. I'll be waiting in the garage."
			<br><br>
			<<endevent>>

			<<link [[Go back to sleep|$passage]]>><</link>>
			<br>
			<<link [[Rise|Mansion Sleep Rise]]>><</link>>
			<br>
		<<elseif _avery_interrupt is "valentines_approach">>

			<<npc "Avery">><<person1>>
			You're awoken by the sound of the bedroom door opening, and slamming against the wall. It's Avery, <<his>> eyes locked on yours, and a smile on <<his>> lips.
			<br><br>

			<<link [[Next|Avery Valentines Invite Mansion]]>><<bedclotheson "Mansion Bed">><</link>>
			<br>

		<<elseif _avery_interrupt is "party_missed">>
			<<npc Avery>><<person1>>
			You're awoken by the sound of the bedroom door opening, and slamming against the wall. Avery stands in the doorway, staring right at you.
			<br><br>
			<<set $wardrobe_location to "mansion_wardrobe">>
			<<wardrobeSelection true>>
			<<radiooutfits>>
			<br><br>

			<<link [[Next|Mansion Return Bed Assess]]>><<bedclotheson "Mansion Bed">><</link>>
			<br>

		<<elseif _avery_interrupt is "date_ready">>
			<<set $avery_mansion.date_ready to true>>
			<<npc Avery>><<person1>>
			Someone shakes your shoulder. It's Avery, wearing <<his>> best. "I'm ready when you are," <<he>> says. "For the date. I'll be waiting in the garage."
			<br><br>
			<<endevent>>

			<<link [[Go back to sleep|$passage]]>><</link>>
			<br>
			<<link [[Rise|Mansion Sleep Rise]]>><</link>>
			<br>

		<<elseif _avery_interrupt is "party_prepare">>
			<<npc Avery>><<person1>>
			You're awoken by the sound of the bedroom door opening, and slamming against the wall. Avery stands in the doorway.
			<br><br>
			<<set $wardrobe_location to "mansion_wardrobe">>
			<<wardrobeSelection true>>
			<<radiooutfits>>
			<br><br>

			<<link [[Next|Mansion Return Bed Party Prepare]]>><<bedclotheson "Mansion Bed">><</link>>
			<br>

		<<elseif _avery_interrupt is "party">>
			<<npc Avery>><<person1>>
			You're awoken by the sound of the bedroom door opening, and slamming against the wall. Avery stands in the doorway.
			<br><br>

			<<set $wardrobe_location to "mansion_wardrobe">>
			<<wardrobeSelection true>>
			<<radiooutfits>>
			<br><br>

			<<link [[Next|Mansion Return Bed Party]]>><<bedclotheson "Mansion Bed">><</link>>
			<br>
		<<elseif ["skyscraper_ready", "skyscraper_approach"].includes(_avery_interrupt)>>
			<<npc "Avery">><<person1>>

			You're awoken by the sound of the bedroom door opening, and slamming against the wall. Avery stands in the doorway.
			<br><br>

			<<if $avery_tower.stage is 2>>
				<<skyscraper_time>>
				"I've just had the call," Avery says. <<Hes>> smiling. <span class="gold">"My skyscraper is finished at last."</span>
				<br><br>
			<</if>>

			<<if _skyscraper_time is "now" or $avery_tower.stage is 3>>
				"The blood moon is high, and the time is nigh," <<he>> rhymes. "Our guests will be here soon, get dressed."
				<br><br>

				<<set $wardrobe_location to "mansion_wardrobe">>
				<<wardrobeSelection true>>
				<<radiooutfits>>
				<br><br>

				<<link [[Get out of bed|Mansion Skyscraper Rise]]>><</link>>
				<br>
			<<else>>
				<<if _skyscraper_time is "tonight">>
					"<span class="gold">The opening ceremony is tonight.</span>
				<<elseif _skyscraper_time is "tomorrow">>
					"<span class="gold">The opening ceremony will be tomorrow.</span>
				<<else>>
					"<span class="gold">The opening ceremony will be on the last day of the month.</span>
				<</if>>
				When the moon is blood red. They're inducting me into their circle, and it's vital you attend. There can be no ceremony without you."
				<br><br>

				Avery walks way, more animated than you've yet seen <<him>>. "Meet me here when the time comes. We'll arrive there in style."
				<br><br>

				<<endevent>>

				<<link [[Go back to sleep|$passage]]>><</link>>
				<br>
				<<link [[Rise|Mansion Sleep Rise]]>><</link>>
				<br>
			<</if>>

			<<if $avery_tower.stage is 2>>
				<<set $avery_tower.stage to 3>>
			<</if>>
		<<elseif _avery_interrupt is "fox">>
			You're awoken by the sound of the lounge's piano playing. You open your eyes. <span class="blue">Avery is still fast asleep.</span>
			<br><br>

			You rub the tiredness from your eyes and focus. Your hair stands on end as you listen.
			<br><br>

			<<if $seabird_lullaby gte 2>>
				The first six notes of <span class="teal">Seabird's Lullaby</span>
			<<else>>
				<<set $seabird_lullaby to 1>>
				Six <span class="teal">faintly familiar</span> notes
			<</if>>
			echo through the mansion, dulling the walls with their soothing hue. You feel anxious, like you want to go back to sleep while wide awake.
			<br><br>

			<<set $wardrobe_location to "mansion_wardrobe">>
			<<wardrobeSelection true>>
			<<radiooutfits>>
			<br><br>

			<<link [[Investigate|Mansion Piano Fox]]>><<bedclotheson "Mansion Bed">><<endevent>><</link>>
			<br>
		<<else>>
			<<npc Avery>><<person1>>
			You feel Avery pawing at you.
			<br><br>
			<<link [[Allow|Mansion Sleep Sex]]>><<npcincr Avery dom 1>><<set $sexstart to 1>><</link>><<promiscuous1>><<gdom>>
			<br>
			<<link [[Pull away|Mansion Sleep Sex Refuse]]>><<npcincr Avery rage 1>><<npcincr Avery love -1>><<npcincr Avery dom -1>><</link>><<garage>><<llove>><<ldom>>
			<br>
		<</if>>
	<<else>>
		<<averySchedule>>
		<<if $avery_mansion.schedule is "sleep">>
			Avery lies beside you.
		<<else>>
			<<if Time.hour lte 5>>
				You spread across the whole bed.
			<<elseif Time.hour lte 8>>
				Dawnlight flows between the curtains.
			<<elseif Time.hour lte 17>>
				The bed's curtains protect you from the sun.
			<<elseif Time.hour lte 21>>
				You hear the traffic in town, somewhat distant.
			<<else>>
				You spread across the whole bed.
			<</if>>
		<</if>>
		<br><br>
		<<set $wardrobe_location to "mansion_wardrobe">>
		<<wardrobeSelection true>>
		<<radiooutfits>>
		<br><br>
		<<getouticon>><<link [[Get out of bed|Mansion Bedroom]]>><<bedclotheson "Mansion Bed">><</link>>
	<</if>>
<</if>>

