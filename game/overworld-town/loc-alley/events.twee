		<<case 2>>
			<<link [[일어난다|Street Wake]]>><</link>>
		<<case 1>>
			<<link [[일어난다|Molestation alley]]>><<set $molestationstart to 1>><</link>>
	<</switch>>
<<else>>
		<<ambulance>>
<</if>>


<<pass 1 hour>>
<<trauma 6>><<set $stress -= 2000>>

