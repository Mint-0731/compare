:: Widgets Pub [widget]

<<widget "landryoptions">>
	<<if $blackmoney gte 1>>
		<<highicon>><<link [[장물을 판매한다|Pub Sell]]>><</link>>
		<br>
	<</if>>
	<<if $spray lt $spraymax and $money gte 250000>>
		<<peppersprayicon>><<link [[후추 스프레이를 충전한다 (£2500)|Pub Spray]]>><<spray 1>><<money -250000 "pubPepperSpray">><</link>>
		<br>
	<</if>>
	<<if crimeSumCurrent() gte 500 and !$pubtask>>
		<<socialiseicon "ask">><<link [[범죄 기록을 감추는 방법을 묻는다|Pub Task]]>><</link>>
		<br>
	<</if>>
	<<if $police_hack is 1>>
		<<policeicon>><<link [[경찰 컴퓨터에 침입하는 방법을 묻는다|Pub Hack]]>><</link>>
		<br>
	<<elseif $police_hack is 4 and $money gte 30000>>
		<<policeicon>><<link [[변경된 경찰서 비밀번호를 묻는다 (£300)|Pub Hack]]>><<money -30000 "pub">><</link>>
		<br>
	<<elseif $pub_hack_job is 3 and $hacker_tasks.length gte 2>>
		<<if $mickeyPub gte 2>>
			<<socialiseicon>><<link [[경찰서의 비밀번호에 대해 더 자세히 묻는다|Pub Hack]]>><<set $pub_hack_job to 4>><</link>>
		<<else>>
			<<socialiseicon>><<link [[해커의 메세지를 전달한다|Pub Hack]]>><<set $pub_hack_job to 4>><</link>>
		<</if>>
		<br>
	<</if>>
	<<if $pubtask2 is 1>>
		<<crimeicon "black box">><<link [[검은 상자를 건넨다|Pub Box]]>><<set $pub_task_stat++>><</link>>
		<br>
	<</if>>
	<<if $estate_fence is "quest" and _estate_asked isnot true>>
		<<mooricon "remy">><<link [[레미의 사유지에 침입할 방법을 묻는다|Pub Estate]]>><</link>>
		<br>
	<</if>>
	<<if $pubfame>>
		<<if $pubfame.status is "ready">>
			<<socialiseicon "ask">><<link [[당신의 명성 때문에 도움을 받을 수 있는지 묻는다|Pub Fame]]>><<set $phase to 0>><</link>>
			<br>
		<<elseif $pubfame.status is "hiding">>
			<<socialiseicon "ask">><<link [[당신의 명성 때문에 도움을 받을 수 있는지 묻는다|Pub Fame Hiding]]>><</link>>
			<br>
		<<elseif $pubfame.status is "accepted">>
			<<socialiseicon>><<link [[당신의 임무에 대해 미키와 대화한다|Pub Fame]]>><<set $phase to 0>><</link>>
			<br>
		<<elseif $pubfame.status is "done">>
			<<socialiseicon>><<link [[미키에게 임무를 완수했다고 알려준다|Pub Fame]]>><<set $phase to 0>><</link>>
			<br>
		<<elseif $pubfame.intro and $hacker_tasks.length gte 2>>
			<<socialiseicon "ask">><<link [[당신의 명성 때문에 도움을 받을 수 있는지 묻는다|Pub Fame Return]]>><</link>>
			<br>
		<</if>>
	<</if>>
	<<if $farm_manors_usb gte 1>>
		<<techicon "usb">><<link [[농장 지역 저택에서 입수한 USB를 건넨다|Pub Farm USB]]>><<unset $farm_manors_usb>><</link>>
		<br>
	<</if>>

	<<if $avery_mansion>>
		<<if (!$avery_mansion.landry_told or $avery_mansion.landry_told is 1) and $avery_fate>>
			<<if $avery_fate is "fallen" or $avery_fate is "kicked" or $avery_fate is "saved">>
				<<socialiseicon>><<link [[마천루에서 일어난 일에 대해 랜드리에게 묻는다|Pub Avery Stones Tell 2]]>><<set $avery_mansion.landry_told to 2>><</link>>
				<br>
				<<socialiseicon "angry">><<link [[마천루에서 일어난 일에 대해 랜드리에게 따진다|Pub Avery Stones Angry]]>><<set $avery_mansion.landry_told to 2>><</link>>
				<br>
			<<elseif $fake_artefact is "pc" and $avery_fate is "ascended">>
				<<socialiseicon>><<link [[마천루에서 일어난 일에 대해 랜드리에게 알려준다|Pub Avery Stones Ascend]]>><<set $avery_mansion.landry_told to 2>><</link>>
				<br>
			<</if>>
		<<elseif !$avery_mansion.landry_told and $fake_artefact is "Avery">>
			<<icon "bones.png">><<link [[랜드리에게 기원의 돌을 바꿔치기했다고 말한다|Pub Avery Stones Tell]]>><<set $avery_mansion.landry_told to 1>><</link>>
			<br>
		<</if>>
		<<if $avery_mansion.fox.known and $avery_mansion.guest and !$avery_fate and !$daily.noBrownFox>>
			<<icon "clothes/foxmask.png">>
			<<if isGwylanAbsent()>>
				<<link [[갈색 여우에 대해 묻는다|Pub Brown Fox Unavailable]]>><</link>>
			<<elseif $daily.brownFox or gwylanSchedule() is "pub">>
				<<link [[갈색 여우에 대해 묻는다 (0:01)|Pub Brown Fox]]>><<pass 1>><</link>>
			<<elseif $brownFoxWoundedTimer>>
				<<link [[갈색 여우에 대해 묻는다 (0:20)|Pub Brown Fox]]>><<pass 20>><</link>>
			<<else>>
				<<link [[갈색 여우에 대해 묻는다 (0:10)|Pub Brown Fox]]>><<pass 10>><</link>>
			<</if>>
			<br>
		<<elseif $avery_mansion.fox.known and $avery_mansion.fox.progress gte 3 and !$avery_mansion.fox.end_landry and $avery_fate>>
			<<icon "clothes/foxmask.png">><<link [[갈색 여우에 대해 묻는다|Pub Avery Stones Fox End]]>><<set $avery_mansion.fox.end_landry to true>><</link>>
			<br>
		<</if>>
		/*
		<<if $avery_mansion.landry gte 2 and $avery_mansion.fake_stones is 1>>
			<<link [[기원의 돌을 바꿔치기하는 것에 대해 묻는다|Pub Avery Fake Stones]]>><</link>>
			<br>
		<</if>>
		 */
	<</if>>
	<<if (($fake_artefact is "pc" or $fake_artefact is "Avery") and $avery_fate isnot "fallen" and $avery_fate isnot "kicked") and C.npc.Avery.state is "dismissed" and !$avery_card_gift>>
		<<socialiseicon>><<link [[랜드리에게 에이버리의 호의를 되찾을 수 있는 방법에 대해 묻는다|Pub Avery Card]]>><</link>>
		<br>
	<</if>>
	<br>
<</widget>>

<<widget "brownFoxOptions">>
	<<if $brownFoxRevealed>>
		<<if ["pub", "sulking"].includes(gwylanSchedule())>>
			<span class="purple"><<His>> emotions are hard to get a read on right now.</span>
		<<elseif $avery_mansion.fox.progress gte 15>>
			<<He>> smiles warmly. <span class="gold"><<He>> has full confidence in you.</span>
		<<elseif $avery_mansion.fox.progress gte 12 or $avery_mansion.fox.friend>>
			<<He>> leans forward. <span class="green"><<Hes>> willing to take risks for you.</span>
		<<elseif $avery_mansion.fox.progress gte 9>>
			<<He>> sits back casually. <span class="teal"><<He>> trusts you to get things done.</span>
		<<elseif $avery_mansion.fox.progress gte 6>>
			<<He>> sits quietly. <span class="blue"><<Hes>> beginning to trust your abilities.</span>
		<<elseif $avery_mansion.fox.progress gte 3>>
			<<He>> looks you up and down. <span class="purple"><<Hes>> still concerned about your ability to help.</span>
		<<elseif $avery_mansion.fox.progress gte 0>>
			<<He>> is on guard and sharp. <span class="pink"><<He>> seems unsure of your abilities.</span>
		<<else>>
			<<He>> crosses <<his>> arms as <<he>> regards you. <span class="red"><<He>> doesn't seem to think you have what it takes.</span>
		<</if>>
	<<else>>
		<<if $avery_mansion.fox.progress gte 15>>
			<<He>> smiles warmly. <span class="gold"><<He>> fully trusts you.</span>
		<<elseif $avery_mansion.fox.progress gte 12 or $avery_mansion.fox.friend>>
			<<He>> leans forward. <span class="green"><<Hes>> willing to take risks for you.</span>
		<<elseif $avery_mansion.fox.progress gte 9>>
			<<He>> sits back casually. <span class="teal"><<He>> trusts you.</span>
		<<elseif $avery_mansion.fox.progress gte 6>>
			<<He>> sits quietly. <span class="blue"><<Hes>> beginning to trust you.</span>
		<<elseif $avery_mansion.fox.progress gte 3>>
			<<He>> looks you up and down. <span class="purple"><<He>> still needs you to prove yourself.</span>
		<<elseif $avery_mansion.fox.progress gte 0>>
			<<He>> is on guard and sharp. <span class="pink"><<He>> seems unsure of your loyalties.</span>
		<<else>>
			<<He>> crosses <<his>> arms as <<he>> regards you. <span class="red"><<He>> doesn't trust you.</span>
		<</if>>
	<</if>>
	<br><br>

	<<if $avery_mansion.fox.task isnot "heist" and $avery_mansion.fox.progress gte 12 and $fake_artefact is "pc">>
		<<if $brownFoxWoundedTimer or !$avery_mansion.fox.dungeon>>
			<<if !$avery_mansion.fox.heist_intro>>
				<<set $avery_mansion.fox.heist_intro to true>>
				"I have a proposal for you," <<he>> starts. "You've done much. I don't want you putting yourself in more danger than is necessary."
				<br><br>

				<<He>> palms <<his>> hands together.
				<<if $brownFoxWoundedTimer and !$avery_mansion.fox.dungeon>>
					"Once my leg is healed, and once you find the vault, <span class="green">we can work together to steal the bones</span>."
				<<elseif $brownFoxWoundedTimer>>
					"Once my leg is healed, <span class="green">we can work together to steal the bones</span>."
				<<else>>
					"Once you find the vault, <span class="green">we can work together to steal the bones</span>."
				<</if>>
				<br><br>
			<</if>>
		<<else>>
			<<set $avery_mansion.fox.task to "heist">>
			"<span class="blue">I think it's time for us to make our move.</span> I'm healed up, and we have the information we need. The next time Avery's not in the way, I'll sneak in, and we'll get the bones at last."
			<br><br>

			<<He>> cups <<his>> hands to <<his>> mouth, and whistles
			<<if $seabird_lullaby gte 2>>
				the first six notes of <span class="teal">Seabird's Lullaby</span>.
			<<else>>
				<<set $seabird_lullaby to 1>>
				six <span class="teal">faintly familiar</span> notes.
			<</if>>
			"Whistle that in the garden when the way is clear, and I'll enter."
			<br><br>
		<</if>>
	<<elseif $avery_mansion.fox.stones and !$avery_mansion.fox.friend and $avery_mansion.fox.progress gte 12>>
		<<set $avery_mansion.fox.friend to true>>
		"You've done well by me." <<He>> stops to think for a moment. "When the day comes for the bones to be used..."
		<br><br>

		<<He>> looks away briefly. "I'll come sneak into the mansion after Avery leaves for the tower. We can share a drink over your victory. Promise." <<He>> smiles at you.
		<br><br>
	<</if>>

	<<if !$avery_mansion.fox.task>>
		<<icon "front_gate.png">><<link [["Tell <<him>> that " + $avery_mansion.guest + " will be the next guest of honour"|Pub Brown Fox Task]]>><</link>>
		<br>
	<<elseif $avery_mansion.fox.task_complete is "success" and $avery_mansion.fox.task isnot "heist">>
		<<socialiseicon>><<link [[Tell <<him>> you completed <<his>> task|Pub Brown Fox Task]]>><<set $phase to "success">><</link>>
		<br>
	<<elseif $avery_mansion.fox.task isnot $avery_mansion.guest and $avery_mansion.fox.task isnot "heist" or $avery_mansion.fox.task_complete is "fail">>
		<<icon "cross.png">><<link [[Tell <<him>> you weren't able to complete <<his>> task|Pub Brown Fox Task]]>><<set $phase to "fail">><</link>>
		<br>
	<</if>>
	<<if $avery_mansion.jobs.includes("dungeon") and !$avery_mansion.fox.dungeon and $fake_artefact isnot "Avery">>
		<<icon "avery_dungeon.png">><<link [[Tell <<him>> about the dungeon|Pub Brown Fox Dungeon]]>><<set $avery_mansion.fox.dungeon to true>><<set $avery_mansion.fox.progress += 3>><</link>>
		<br>
	<</if>>
	<<if $fake_artefact is "Avery" and !$avery_mansion.fox.stones>>
		<<icon "bones.png">><<link [[Tell <<him>> that you found the stones yourself|Pub Brown Fox Stones]]>><<set $avery_mansion.fox.stones to true>><<set $avery_mansion.fox.progress += 3>><</link>>
		<br>
	<</if>>
	<<if !$brownFoxRevealed and ($brownFoxWoundedHint or $gwylanSeen?.includes("yearning"))>>
		<<ind>><<link [[Tell <<him>> you know who <<he>> is|Pub Brown Fox Revealed]]>><<set $brownFoxRevealed to true>><</link>>
		<br>
	<</if>>
	<<if $brownFoxRevealed and ["pub", "sulking"].includes(gwylanSchedule()) and !$gwylanSeen?.includes("pub_yearning") and !$avery_mansion.fox.yearning>>
		<<ind>><<link [[Apologise|Pub Brown Fox Apologise]]>><<set $avery_mansion.fox.yearning to true>><</link>>
		<br>
	<</if>>
	<<getouticon>><<link [[Say goodbye|Pub]]>><<endevent>><</link>>
	<br>
<</widget>>

:: Pub
<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">>

<<if $exposed gte 1>>
	You are hiding in a trolley to conceal your <<lewdness>>. Everyone's too busy or intoxicated to notice you.
	<br><br>

	<<link [[Look for something to cover with|Pub Exposed]]>><</link>>
	<br>
	<<link [[Sneak out the back|Industrial Alleyways]]>><</link>>
	<br>
<<else>>
	<<if $pubbooze is "herbal">>
		<<wearProp "beer mug">>
		<<set $pubbooze to 0>>
		바텐더가 마을 특제 음료를 한 잔 따라준다. 마시고 나니 내부가 좀 더 화사하게 보인다.
	<<elseif $pubbooze is "booze">>
		<<wearProp "beer mug">>
		<<set $pubbooze to 0>>
		바텐더가 싸지만 인기있는 음료를 한 잔 따라준다.
	<<else>>
		당신은 술집에 들어간다. 늘 그렇듯이 내부는 바빠보인다.
	<</if>>
	<<if $arousal gte $arousalmax>>
		<<orgasmLocation "pub">>
	<</if>>
	<br><br>
	<<if $averyPub is 1 and (Time.dayState is "day" or Time.dayState is "dusk")>>
		<<npc Avery>><<person1>>
		<<loadNPC 1 avery_sidepiece>><<person2>>
		당신은 눈에 띄지 않도록 조심하면서, 에이버리를 찾는다. 당신은 곧 바 스톨에서, 활발하게 이야기 중인 소녀와 에이버리를 발견한다.
		당신은 이제 그 <span class="red">소녀가 같은 고아원 사람이라는 것을 알아차린다.</span>
		<br><br>
		이버리가 몸을 숙여 그녀의 허벅지 위에 손을 얹고, 그녀를 긴장시킨다. 그녀는 벌떡 일어나, 화장실 핑계를 대며 사라진다.
		<br><br>
		<<link [[화장실로 간다|Avery Dismissal Restroom]]>><</link>>
		<br>
		<<link [[바 스톨로 간다|Avery Dismissal Bar]]>><</link>>
		<br>
	<<elseif ($fame.bestiality gte 400 or $fame.rape gte 400 or $fame.prostitution gte 400 or $fame.sex gte 400 or $fame.exhibitionism gte 400) and !$pubfame>>
		<<set $pubfame to {seen: [], tasksDone: []}>><<set $fameDecay to {}>><<set $fameDecayTimer to {}>>
		<<generate1>><<person1>>
		뒤에서 누군가 당신의 어깨를 잡는다. "그동안 바빴던 모양이지." 한 남자가 당신의 귀에 속삭인다. 당신은 그의 입에서 술냄새를 맡을 수 있다. "내가 널 못 알아본다고 생각하지 마. 넌 마을의 화젯거리야.
		<<if $fame.bestiality gte 400>>
			똥개 무리가 널 생으로 따먹는 걸 내가 못 봤다는 게 좀 놀라울 지경이야."
		<<elseif $fame.sex gte 400 or $fame.rape gte 400 or $fame.prostitution gte 400>>
			누가 널 생으로 따먹는 걸 내가 못 봤다는 게 좀 놀라울 지경이야."
		<<else>>
			네가 옷을 입고 있다는 게 좀 놀라울 지경이야."
		<</if>>
		<<stress 3>><<gstress>>
		<br><br>
		<<His>> grip tightens. "I reckon it's time I got my slice of the pie. <<if $fame.prostitution gte 400>>Hope you don't mind that I'm not paying for it.<<elseif $fame.rape gte 400>>You like it rough, right? That's what I've heard.<</if>> Come 'ere, sweetheart."
		<br><br>
		<<link [[다음|Pub Fame Intro]]>><</link>>
	<<elseif $pubwhore gte 10 and $pubattack isnot 1>>
		<<set $pubattack to 1>>
		<span class="red">당신의 머리 위로 검은 자루가 씌워지더니</span>, 두 쌍의 팔이 뒤에서 당신을 붙잡는다. 그들은 대기 중인 밴으로 당신을 끌고 간다.
		<br><br>
		<<link [[다음|Brothel Punishment]]>><</link>>
		<br>
	<<elseif $pubwhore gte 20>>
		<<set $pubwhore to 10>>
		<<generate1>><<generate2>><<person1>>한 남자가 당신을 벽에 밀친다. 그의 옆에는 다른 남자가 서 있다. 술집 직원과 손님들은 모른척 고개를 돌린다. "<span class="red">보스가 우리를 보냈어,</span>" <<person1>>그가 말한다. "그가 말하길, 네가 최근에 버릇없이 굴었다더군. 우리는 너를 데려가야 해." 그가 바를 힐끗 쳐다본다. "그리고 뭔가 시도할 생각 마. 누구도 너를 도와주지 않을 거다."
		<br><br>
		<<if $money gte 50000>>
			<<link [[뇌물을 준다 (£500)|Pub Accost]]>><<set $phase to 0>><</link>>
			<br>
		<</if>>
		<<link [[싸운다|Pub Accost Fight]]>><<set $fightstart to 1>><</link>>
		<br>
		<<link [[그들과 함께 간다|Pub Accost]]>><<set $phase to 1>><</link>>
		<br>
	<<else>>
		<<socialiseicon "ask">><<link [[랜드리와 대화한다|Pub Landry]]>><<endevent>><</link>>
		<br>
		<<if playerIsPregnant() and playerAwareTheyArePregnant()>>
			<span class="blue">You can't bring yourself to drink while you know you're with child.</span>
			<br>
		<<else>>
			<<if $money gte 1000>>
				<<foodicon "beer">><<link [[술을 마신다 (£10 0:05)|Pub]]>><<endevent>><<money -1000 "pubAlcohol">><<set $pubbooze to "booze">><<alcohol 120>><<pass 5>><</link>><<ggalcohol>>
				<br>
			<</if>>
			<<if $money gte 2000>>
				<<foodicon "beerbottle">><<link [[약초주를 마신다 (£20 0:05)|Pub]]>><<endevent>><<money -2000 "pubAlcohol">><<set $pubbooze to "herbal">><<pass 5>><<alcohol 60>><<hallucinogen 20>><</link>><<galcohol>><<ghallucinogens>>
				<br>
			<</if>>
		<</if>>
		<<if $farm>>
			<<if $farm.tower gte 1 and !$farm.tower_guard and !$farm.build_finished.includes("tower 1")>>
				<<investigateicon>><<link [[농장에서 일할 경비원을 찾는다 (0:30)|Pub Guard]]>><<endevent>><<pass 30>><</link>>
				<br>
			<</if>>
		<</if>>
		<br>
		<<if !($weekly.theft.pub || $weekly.pubMusic)>>
			<<if !$per_npc.pubMusic>>
				<<generate2>><<person2>><<saveNPC 1 pubMusic>><<endevent>>
			<</if>>
			당신은  <<loadNPC 1 pubMusic>><<person2>>한 남자가 구석에서 음악을 연주하고 있는 것을 본다.<br>
			<<birdicon "sing">><<link [[다가간다|Pub Music]]>><<set $pubdrink to 0>><</link>>
			<br><br>
		<</if>>
		<<generate1>><<person1>>당신은 혼자 앉아 있는 남자를 발견한다.
		<br>
		<<brothelicon>><<link [[추파를 던진다 (0:05)|Pub Flirt]]>><<if !($weekly.theft.pub || $weekly.pubMusic)>><<clearsinglenpc 1>><</if>><<pass 5>><<set $pubdrink to 0>><</link>><<promiscuous1>>
		<br>
		<<investigateicon>><<link [[다른 사람을 찾는다 (0:01)|Pub]]>><<endevent>><<pass 1>><</link>>
		<br>

		<<if C.npc.Gwylan.state is "scorned">>
			<<if gwylanSchedule() is "pub">>
				<br>
				You see Gwylan sulking in a secluded corner. No one seems to be paying <<nnpc_him "Gwylan">> any mind.
				<br>
				<<socialiseicon>><<link [[다가간다|Gwylan Pub Sulking]]>><<endevent>><</link>>
				<br>
			<</if>>
		<</if>>

		<<if Time.weekDay is 1 and Time.hour gte 21 and C.npc.Whitney.state is "active">>
			<br>
			Some delinquents occupy a table, drowning the room in revelry.
			<<if $weekly.whitneyPub>>
				<span class="purple">You shouldn't provoke them further.</span>
			<<else>>
				You spot Whitney among them.
				<<if C.npc.Whitney.love gte 10>>
					<span class="teal"><<nnpc_He "Whitney">> eyes you from <<nnpc_his "Whitney">> seat.</span>
				<<else>>
					<span class="blue">If <<nnpc_he "Whitney">> notices you, <<nnpc_he "Whitney">> doesn't show it.</span>
				<</if>>
				<br>
				<<ind>><<link [[다가간다|Whitney Pub Approach]]>><<endevent>><<set $weekly.whitneyPub to 1>><<set $phase to 0>><</link>>
			<</if>>
			<br>
		<</if>>

		<br>
		<<harvesticon>><<link [[떠난다|Harvest Street]]>><<endevent>><</link>>
		<br>
	<</if>>
<</if>>

:: Pub Intro

<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">>
당신은 술집 안으로 들어간다. 내부는 아늑하면서도 소박한 느낌이다. 오래된 농기구들이 벽에 장식 되어있어, 근처의 오랜 농업 역사를 나타내고 있다.
<<if Time.dayState is "night">>
	늦은 시간임에도 불구하고 술집은 사람들로 활기가 넘쳐서, 자리를 찾기 까다롭다.
<<else>>
	술집은 사람들로 활기가 넘쳐서, 자리를 찾기 까다롭다.
<</if>>
<br><br>
<<npc Landry>><<person1>>
<<if $pronoun is "m">>
	"본 적 없는 얼굴인데." 남자의 목소리가 내려앉는다. 그는 짧은 검은 머리에 회색 스웨터, 어두운 색조의 바지를 입고 있다. 특히 이런 곳에서는 더더욱, 당신이 주의를 기울일 만한 사람은 아니다. "같이 일해볼래? 너한테 제안할 게 있어."
	<br><br>
<<else>>
	"본 적 없는 얼굴인데." 여자의 목소리가 내려앉는다. 그녀는 검은 머리를 어깨까지 내리고 회색 가디건과 어두운 바지를 입고 있다. 특히 이런 곳에서는 더욱, 당신이 주의를 기울일 만한 사람은 아니다. "같이 일해볼래? 너한테 제안할 게 있어."
	<br><br>
<</if>>
이렇게 탁 트인 공공장소라면 위험하지 않을 거라고 판단한 당신은, 그의 제안을 받아들인다. 그의 안내를 따라 중앙의 방으로 들어가자, 부분 부분 시야가 차단된 작은 장소가 나타난다. 이상하게도 이곳의 테이블들만 비어있는 채다. 그가 그 작은 테이블에 자리하고, 당신도 뒤따라 앉는다. 그는 소박하고 헐렁한 옷차림에 가려져서 그렇지, 날씬한 체형인 듯 하다.
<br><br>
"까놓고 말할게." 그가 입을 열었다. "네가 돈이 필요한 처지라는 거 알고 있어. 어떻게 아는지는 묻지 마, 소문이 퍼지니까. 내가 널 도울 수 있을 것 같은데. 나한테 보석이나, 네가 어떻게 해야 할지 모르겠는 물건이 있다면 넘겨. 돈은 후하게 쳐줄게."
<br><br>
그는 누군가 있는건 아닌지, 다시 한 번 확인한다. "어쨌든 내 생각대로라면, 우리는 서로 각자에게 도움을 줄 수 있을 거라 생각해. 뭐, 그게 내가 하고 싶은 말의 전부야." 그가 일어나서 손을 내민다. "기억해둬. 나랑 이야기하고 싶다면 직원에게 말해. 그럼 내가 있는 곳을 알려줄 거야. 내 이름은 랜드리야."
<<set $pubintro to 1>>
<br><br>
<<link [[떠난다|Pub]]>><<endevent>><</link>>
<br>

:: Pub Landry
<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">>

<<if $phase is 1>>
	<<endevent>><<npc Landry>><<person1>>
	You walk back to Landry's table. "What's your plan now?" <<he>> asks.
	<br><br>
	<<landryoptions>>
	<<getouticon>><<link [[떠난다|Pub]]>><<endevent>><</link>>
	<br>
<<elseif $fake_artefact is undefined and $skulduggery gte 600 and C.npc.Avery.init is 1 and !$avery_fate or ($avery_mansion and $avery_mansion.landry is 1 and !$avery_fate)>>
	<<npc Landry 1>><<person1>>
	You ask the bartender for Landry, who nods and beckons you over to your usual table. Someone's sitting in your usual spot, hunched forwards and speaking in a hushed tone. They wear a dark green cloak with a hood.
	<<if $transformationParts.fox.ears isnot "disabled" or $transformationParts.wolf.ears isnot "disabled" or $transformationParts.cat.ears isnot "disabled">>
		Thanks to your sharp ears, you're just able to make out what they're saying.
	<</if>>
	<br><br>
	"...Cloister uses a similar reactive dust for their chastity exams. Very similar. It's a toned down version of what the Children use, in fact. It normally reacts with natural oils secreted by the human body, but there are more... explosive reactions, too. We add a small reservoir of mercury behind a stopper made of the stuff. When it dissolves in reaction to the chemicals they use in their ritual, it'll flow out. It'll be like completing a circuit, and it'll—"
	<br><br>
	They suddenly stop.
	<<if $avery_mansion?.fox?.known>>
		<<set $daily.brownFox to true>>
		Their head tilts in your direction. It's the brown fox. "Wonderful timing. I'll leave you two to discuss business." Landry tilts <<his>> head questioningly as the brown fox stands and strides past you, briefly placing a hand on your shoulder before leaving the pub.
		<br><br>
		Landry clears <<his>> throat. "Good to see you're already acquainted."
	<<else>>
		<span class="red">Their head tilts in your direction.</span> Landry immediately raises <<his>> hand. "It's okay. <<pShes>> here to see me."
		<br><br>
		The mysterious figure nods and stands. They turn, revealing that their face is obscured by a brown fox mask. <<if $auriga_artefact is "Avery">>It's almost identical to the ones you saw at Remy's party.<</if>> They stride past you without saying a word, and exit the Pub.
	<</if>>
	<br><br>
	You take your seat. "Awfully useful, that one," Landry says. "No one ever pays the little fox any mind, or ever seems to remember they've been somewhere. Not all old dogs need new tricks I guess."
	<br><br>
	<<link [[다음|Pub Avery Note]]>><</link>>
	<br>
<<elseif ($wren_intro isnot undefined or $wrenSeen?.includesAny("cards", "prison")) and ($prison?.wren_names is 2 or crimeSumCurrent() gte 5000 or $fame.social gte 600) and $wrenHeist is undefined and Time.hour lte 17>>
	<<npc Landry>><<person1>>You ask the bartender for Landry, who nods and beckons you over to your usual table. You've barely sat down when
	<<set $wrenHeist to false>><<set $wrenHeistMonthly to 30>>

	<<npc Wren 2>><<person2>>there's a small disturbance at the front of the pub. Landry sighs and leaves to investigate. You're about to follow when someone sits across from you. <span class="gold">It's Wren.</span>
	<br><br>
	"Fancy running into you here," <<he>> says.
	<br><br>
	<<if $speech_attitude is "meek">>
		"W-what are you doing here?" you ask.
	<<elseif $speech_attitude is "bratty">>
		"Let me guess," you say with a smirk.
	<</if>>

	<<if $wrenSeenLast is "cards">>
		<<if $speech_attitude is "meek">>
			"Sorry, but I-I can't play cards right now..."
		<<elseif $speech_attitude is "bratty">>
			"You want to swindle me out of my clothes? Well, I'm too busy to play your games right now."
		<<else>>
			"Looking for a game?" you ask. "Sorry, but I'm busy."
		<</if>>
		<br><br>
		"Not this time," <<he>> says lightly.
	<<else>>
		<<if $speech_attitude is "meek">>
			"I-I'm not here to do anything to Landry, I promise..."
		<<elseif $speech_attitude is "bratty">>
			"You want to rope me into stealing from Landry? Not on your life."
		<<else>>
			"Looking for a partner-in-crime?" you ask. "Sorry, but I won't steal from Landry."
		<</if>>
		<br><br>
		"Easy, <<girl>>. That's not why I'm here," <<he>> says.
	<</if>>
	<br><br>
	"I've got something different in mind. Something that will benefit both of us. A job." <<He>> grins at you. "Interested?"
	<br><br>

	<<link [[렌의 제안을 들어본다|Wren Heist Intro]]>><</link>>
	<br>
	<<link [[렌의 제안을 거절한다|Wren Heist Intro End]]>><<set $phase to 0>><<npcincr Wren love -1>><</link>><<llove "Wren">>
	<<exit>>
<<else>>
	<<npc Landry>><<person1>>당신은 바텐더에게 랜드리에 대해 묻는다. 바텐더는 고개를 끄덕이더니, 당신이 늘 앉는 테이블을 향해 손짓한다. 당신은 랜드리가 도착해 맞은 편에 앉은 후에야 겨우 자리에 앉는다.
	<br><br>

	"뭘 가지고 왔지?" 그가 묻는다.
	<<if $pubfame>>
		<<if $pubfame.status is "finished">>
			"If you're looking for our friend, they're busy. Should be ready to see you <span class="gold"><<if $pubfame.timer gt 1>>in <<number $pubfame.timer>> days<<else>>tomorrow<</if>></span>."
		<<elseif $pubfame.status is "hidingKnown">>
			"If you're looking for our friend, they're still lying low. Should be ready to see you <span class="gold"><<if $pubfame.timer gt 1>>in <<number $pubfame.timer>> days<<else>>tomorrow<</if>></span>."
		<</if>>
	<</if>>
	<br><br>
	<<landryoptions>>
	<<getouticon>><<link [[떠난다|Pub]]>><<endevent>><</link>>
	<br>
<</if>>


:: Pub Spray
<<wearProp "pepper spray">>
<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">>
당신이 테이블 위에 돈을 올려 놓자, 랜드리가 작은 통을 교환해준다.
<<gspray>>
<br><br>
<<if $pubspray isnot 1>>
	<<set $pubspray to 1>>
	"가격에 관해선 유감이지만," 그가 말한다. "성분 재료를 구하기가 까다로워서 말이야."
	<br><br>
<</if>>
<<landryoptions>>
<<getouticon>><<link [[떠난다|Pub]]>><<endevent>><</link>>
<br>

:: Pub Sell

<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">>
당신은 물건들을 테이블 위에 올려놓는다. 랜드리는 익숙한 일인 듯 느긋한 태도로 물건의 가치를 매긴다.
<<if $blackmoney lt 100>>
	"잘 했어. 또 이런 걸 손에 넣는다면 어디서 날 찾아야 할지는 알고 있겠지?"
	<br><br>
<<elseif $blackmoney lt 500>>
	"꽤나 많이 가져왔네. 또 이런 걸 손에 넣는다면 어디서 날 찾아야 할지는 알고 있겠지?"
	<br><br>
<<else>>
	"이거 상당히 많은 양이군. 네가 감당할 수 없는 만큼은 아니었길 바래. 혹시 네 기록을 지우고 싶다면 어디서 날 찾아야 할지는 알고 있겠지."
	<br><br>
<</if>>
당신은 <span class="gold">£<<print $blackmoney>></span>를 얻었다.
<<money `$blackmoney * 100` "pubStolenGoods">><<set $blackmoney to 0>>
<br><br>
<<getouticon>><<link [[술집으로|Pub]]>><<endevent>><</link>>
<br>

:: Pub Task
<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">>

<<if $pubstage is undefined>>
	<<set $pubstage to 1>><<set $pubtask to "forest">>
	"내가 좀 도와줄 수 있어," 랜드리가 비스듬히 기대어, 거의 누운 채로 말한다. "하지만 네가 날 위해 해줘야 할 일이 있어. 그리고 아냐, 돈과 관련된 건 아니야. 내가 지금 기다리고 있는 물건이 오지않고 있는데, 네가 찾아줬으면 좋겠어. 다행히도 GPS 추적기가 달려 있어서, 그게 어디 있는진 정확히 알고 있어. <span class="gold">마을 옆에 있는 숲의 깊은 곳에 있지.</span>"
	<br><br>
	"나에게 그걸 가져와 준다면 네가 저지른 범죄의 대가를 치르는 걸 막아주지. 작은 검은 상자야. 다른 바위나 나뭇 가지와 헷갈리지마. 아아, 그리고 조심하는게 좋아. 거긴 늘 실종되는 사람들이 있으니까."
<<elseif $pubstage is 1>>
	<<set $pubstage to 2>><<set $pubtask to "moor">>
	"내가 또 도와줄 수 있어," 랜드리가 비스듬히 기대어, 누운 채로 말한다. "하지만 네가 날 위해 해줘야 할 일이 또 있어. 도착하지 않은 다른 물건에 관한 거야. 이번엔 마을에서 좀 떨어진, <span class="gold">황무지에서 잃어버린듯 해</span>. 거길 가려면 하베스트 가의 길을 따라 마을을 벗어나야 할 거야."
	<br><br>
	"나에게 그걸 가져와 준다면 네가 저지른 범죄의 대가를 치르는 걸 막아주지. 작은 검은 상자 알지? 아아, 그리고 조심하는 게 좋아. 괴물이니 뭐니 하는 이야기는 믿지 않지만 어떤 괴담들은 그럴싸해 보이거든."
<<elseif $pubstage is 2>>
	<<unset $pubstage>><<set $pubtask to "sewers">>
	"내가 좀 도와줄 수 있어," 랜드리가 비스듬히 기대어, 거의 누운 채로 말한다. "하지만 네가 날 위해 해줘야 할 일이 있어. 그리고 아냐, 돈과 관련된 건 아니야. 내가 지금 기다리고 있는 물건이 오지않고 있는데, 네가 찾아줬으면 좋겠어. 다행히도 GPS 추적기가 달려 있어서, 그게 어디 있는진 정확히 알고 있어. <span class="gold">마을 아래의 오래된 하수도 깊은 곳에 있지.</span>"
	<br><br>
	"나에게 그걸 가져와 준다면 네가 저지른 범죄의 대가를 치르는 걸 막아주지. 작은 검은 상자 알지? 웅덩이나 먼지랑 헷갈리면 안 돼. 아아, 그리고 조심하는 게 좋아. 사람들이 하류로 자주 휩쓸려 가거든."
<</if>>
<br><br>

<<link [[떠난다|Pub]]>><<endevent>><</link>>
<br>

:: Pub Box

<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">>
"That's it! You're a lifesaver." <<He>> examines the box more closely. "I hope it wasn't too much trouble. Don't worry, I'll fulfil my side of things. You'll be clean as can be." <<He>> stands. "Now if you'll excuse me, I've some favours to call in."
<br><br>
<<unset $pubtask>>
<<unset $pubtask2>>
<<unset $pubtasksetting>>
<<crimeDown 10000>>
<<link [[떠난다|Pub]]>><<endevent>><</link>>
<br>

:: Pub Hack
<<set $outside to 0>><<set $location to "pub">><<effects>><<set $bus to "harvest">><<set $phase to 1>>
<<if $police_hack is 1>>
	<<if $pubfame and !$pubfame.intro>>
		"Hacking a police computer?" Landry asks, reclining. "I like your style.
		<<if $pubfame.status is "hiding">>
			<<set $pubfame.status to "hidingKnown">>
			I can't help you there, and unfortunately <span class="red">our friend is out of commission for the moment</span>. Needs to lie low, keep some nasty folk off their trail. Someone spilt important information about them."
			<<stress 12>><<ggstress>>
			<br><br>

			<<He>> shakes <<his>> head before you can say anything. "Don't apologise. I've said worse under torture. They'll be able to hook you up once they're back in business. Should be fine <span class="gold"><<if $pubfame.timer gt 1>>in <<number $pubfame.timer>> days<<else>>tomorrow<</if>></span>."
			<br><br>

			<<link [[떠난다|Pub]]>><<endevent>><</link>>
		<<elseif $pubfame.status is "hidingKnown">>
			I can't help you there, and unfortunately our friend is still lying low. They'll be able to hook you up once they're back in business, though."
			<br><br>

			<<link [[떠난다|Pub]]>><<endevent>><</link>>
		<<else>>
			<<set $police_hack to 4>>
			I can't help you here, but I think I know who can." <<He>> checks to make sure nobody's nearby, then jerks a thumb toward a door behind the table. <span class="teal">"Our mutual friend should be able to hook you up."</span>
			<br><br>

			You knock on the door. "It's me."
			<br><br>

			'Mickey' inches it open. "Hey. I overheard you and Landry. A police password? Easy. But it'll cost you. <<printmoney 30000>>." They raise an eyebrow at your expression. "What? I need cash too. Favours don't pay for everything."
			<br><br>

			<<if $money gte 30000>>
				<<link [[Deal (£300)|Pub Hack Deal Mickey]]>><<set $police_hack to 5>><<set $phase to 1>><<money -30000 "pub">><</link>>
				<br>
				<<link [[No deal|Pub Hack Deal Mickey]]>><<set $police_hack to 4>><<set $phase to 2>><</link>>
			<<else>>
				You don't have enough.
				<<link [[다음|Pub Hack Deal Mickey]]>><<set $police_hack to 4>><<set $phase to 2>><</link>>
			<</if>>
		<</if>>
	<<else>>
		"Hacking a police computer?" Landry asks, reclining. "I like your style. But if you're looking for my help with cyber stuff, you're out of luck." <<He>> rubs <<his>> chin in thought. "There is someone.
		<<if $pubfame and $pubfame.intro>>
			Remember Mickey? The hacker I pointed you to for your fame issue. They should be able to get things done."
		<<else>>
			<span class="teal">This orphan at the home on Domus Street.</span> A computer whiz. Mickey, or Mckay, something like that."
			<br><br>

			당신은 랜드리가 말하는 사람이 누구인지 알고있지만 입 밖으로 꺼내진 않았다. 외부인들에게 고아들의 정보는 비밀이다.
			<br><br>

			"아마도 그게 최선일거야." 랜드리의 말이 이어진다. "그 고아를 찾는 거. 만약 네가 녀석을 데려와 나와 함께 일하게 해준다면, 너한테도 약간의 돈은 챙겨줄게. 베일리의 심기를 거스르는 일만 하지마." 그가 말하며 웃는다. "뭐, 내가 말하지 않아도 알고 있겠지만."
		<</if>>
		<br><br>

		<<link [[수락한다|Pub Hack Deal]]>><<set $police_hack to 2>><<if $pub_hack_job lte 1>><<set $pub_hack_job to 1>><</if>><<set $phase to 1>><</link>>
		<br>
		<<link [[수락하지 않는다|Pub Hack Deal]]>><<set $phase to 2>><</link>>
		<br>
	<</if>>
	<<exit>>
<<elseif $police_hack is 4>>
	"그럼." 랜드리가 말한다. "10분만 기다려."
	<br><br>

	당신은 잠깐동안 술집의 다른 손님들을 구경한다. 곧 랜드리가 돌아왔다.
	<br>
	"여기." 랜드리가 말한다. "새로운 경찰서 마스터 패스워드야. 그리고 우리 둘의 친구가 인사 전해달라는군."
<<elseif $mickeyPub gte 2>>
	"The police computer job," Landry says, nodding. "Right. You mentioned that. Our mutual friend has you covered."
	<br><br>
	<<He>> slides over an envelope. Inside is a card with a word scrawled on it.
	<br><br>
	"That's the police master password. There's also this," <<he>> adds, holding out a USB stick. "A virus. Wipes computer systems clean. Should be able to cause some trouble. Or make old trouble disappear. Good luck."
<<else>> /*Was elseif $pub_hack_job is 4*/
	<<money 50000 "pub">><<set $mickeyPub to 2>>
	"미키가 찾아왔었어." 랜드리가 말한다. "이상한 녀석. 네가 나한테 줄 SD카드들을 좀 갖고 있다고 말하던데?"
	<br><br>
	You hand over the SD memory cards. In return Landry gives you an envelope. Inside is money and a card with a word scrawled on it.
	<br><br>
	"고마워. 그건 경찰서 마스터 패스워드야. 나한테 인재를 데려와준 보답으로 500 파운드도. 어쩌면 나중에 새로운 일을 하게 될 지도 모르겠어."
	<br><br>
	"그리고 이거." 그가 USB 스틱을 건네며 말한다. "바이러스야. 컴퓨터 시스템을 깨끗하게 지워주지. 몇몇 문제를 일으키는데 쓸만할 거야. 아니면 오래된 문제들을 없애버리든지. 행운을 빌게."
<</if>>
