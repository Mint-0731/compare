	<<elseif $worn.under_lower.type.includes("dance")>>
		<<set $_text_output to "댄스복">>
	<<else>>
		<<set $_text_output to "속옷">>
	<</if>>
<</silently>><<if $_text_output>><<print $_text_output>><</if>>
<</widget>>

