:: Wardrobe Sale Crate

정말 당신의 모든
<<if $crateContents is "all">>
	옷들을
<<else>>
	입고 있는 옷들을
<</if>>
상자에 넣어 위탁판매할까? 조만간 쇼핑하러 가야할지도 모르겠다.
<br><br>
<<set _value to 0>>
<<for _label, _items range $wardrobe>>
	<<for _i to 0; _i lt _items.length; _i++>>
		<<if setup.clothes[_label][clothesIndex(_label,_items[_i])].shop.length is 0>>
			<<continue>>
		<</if>>
		<<if _items[_i].outfitSecondary isnot undefined>>
			<<continue>>
		<</if>>
		<<if _items[_i].outfitPrimary is undefined and $crateContents is "outfits">>
			<<continue>>
		<</if>>
		<<set _value += Math.floor(getClothingCost(_items[_i], _label) * (_items[_i].integrity / clothingData(_label,_items[_i],'integrity_max')) / 3)>>
	<</for>>
<</for>>
전부 팔면 <<printmoney `_value + 5000`>>를 받을 수 있다.
<br><br>
<<link [[네|Wardrobe Sale Crate Result]]>><</link>>
<br>
<<link [[아니오|$wardrobeReturnLink]]>>
	<<unset $wardrobeReturnLink>>
	<<unset $crateContents>>
<</link>>

:: Wardrobe Sale Crate Result

<<set $tailorMonthlyService to 7>>
<<set _value to 0>>
<<set _equip to setup.clothingLayer.all>>
<<for _eIndex to 0; _eIndex lt _equip.length; _eIndex++>>
	<<set _toDelete to []>>
	<<for _iIndex to 0; _iIndex lt $wardrobe[_equip[_eIndex]].length; _iIndex++>>
		<<if setup.clothes[_equip[_eIndex]][clothesIndex(_equip[_eIndex],$wardrobe[_equip[_eIndex]][_iIndex])].shop.length is 0>>
			<<continue>>
		<</if>>
		<<if $wardrobe[_equip[_eIndex]][_iIndex].outfitPrimary is undefined and $crateContents is "outfits">>
			<<continue>>
		<</if>>
		<<set _value += Math.floor(tailorClothingCost($wardrobe[_equip[_eIndex]][_iIndex],_equip[_eIndex]) * ($wardrobe[_equip[_eIndex]][_iIndex].integrity / clothingData(_equip[_eIndex],$wardrobe[_equip[_eIndex]][_iIndex],'integrity_max')) / 3)>>
		<<run _toDelete.push(clone(_iIndex))>>
	<</for>>
	<<for _iIndex to $wardrobe[_equip[_eIndex]].length; _iIndex gte 0; _iIndex-->>
		<<if _toDelete.includes(_iIndex)>>
			<<run $wardrobe[_equip[_eIndex]].deleteAt(_iIndex)>>
		<</if>>
	<</for>>
<</for>>
운전기사가 <<printmoney `_value + 5000`>>를 두고 상자를 가져간다.
<<money `Math.floor(_value + 5000)` "tailor">>
<br><br>
<<link [[계속|$wardrobeReturnLink]]>>
	<<unset $wardrobeReturnLink>>
	<<unset $crateContents>>
<</link>>

:: Wardrobe Repair Crate

정말 당신의 모든
<<if $crateContents is "all">>
	옷들을
<<elseif $crateContents is "damaged">>
	손상된 옷들을
<<else>>
	입고 있는 옷들을
<</if>>
상자에 넣고 수선에 맡길까? 조만간 쇼핑하러 가야할지도 모르겠다.
<br><br>
<<set _value to 0>> /* recalculated with adding lower or upper halves when missing */
<<for _label, _items range $wardrobe>>
	<<for _i to 0; _i lt _items.length; _i++>>
		<<if isNaN(clothingData(_label,_items[_i],'integrity_max'))>><<continue>><</if>>
		<<if (_items[_i].outfitPrimary is undefined and _items[_i].outfitSecondary is undefined and $crateContents is "outfits") or (_items[_i].integrity gt clothingData(_label,_items[_i],'integrity_max'))>>
			<<continue>>
		<</if>>
		<<set _value += Math.floor(tailorClothingCost(_items[_i],_label) * (1 - (_items[_i].integrity / clothingData(_label,_items[_i],'integrity_max'))) * 1.25)>>
	<</for>>
<</for>>
전부 수선하려면
<<if _value gt 5000>>
	<<printmoney `_value - 5000`>>가 필요하다.
<<else>>
	돈은 필요없다.
<</if>>
<br><br>
<<if $money gte _value>>
	<<link [[네|Wardrobe Repair Crate Result]]>><</link>>
<<else>>
	돈이 부족하다.
<</if>>
<br>
<<link [[아니오|$wardrobeReturnLink]]>>
	<<unset $wardrobeReturnLink>>
	<<unset $crateContents>>
<</link>>

:: Wardrobe Repair Crate Result

<<set $tailorMonthlyService to 7>>
<<set $wardrobeRepair to {timeLeft: 1}>>
<<set _equip to setup.clothingLayer.all>>
<<set _value to 0>>

/* item stat keys to find matching outfit clothing */
<<set _itemStatsIdentifierKeys to [
	"colour",
	"colourCustom",
	"accessory_colour",
	"accessory_colourCustom",
	"one_piece",
	"pattern",
]>>

/* some item stat keys are optional */
<<set _itemStatsConditionalKeys to {
	get accessory_colour() { return ((item) => !T.currentClothing.accessory_colour_sidebar || !item.accessory_colour_sidebar); },
	get accessory_colourCustom() { return this.accessory_colour; },
	get pattern() { return ((item) => !T.currentClothing.pattern_options?.length || !item.pattern_options?.length); },
}>>

/* Add a new key whenever the clothing object is updated */
<<set _itemStatsKeys to [
	...T.itemStatsIdentifierKeys,
	"hoodposition",
	"altposition",
	"altsleeve",
	"inherited_attributes",
]>>

<<for _eIndex to 0; _eIndex lt _equip.length; _eIndex++>>
	<<set _toDelete to []>>
	<<for _iIndex to 0; _iIndex lt $wardrobe[_equip[_eIndex]].length; _iIndex++>>
		<<set _currentClothing to $wardrobe[_equip[_eIndex]][_iIndex]>>
		<<if isNaN(clothingData(_equip[_eIndex],_currentClothing,'integrity_max'))>><<continue>><</if>>
		<<if _currentClothing.integrity gte clothingData(_equip[_eIndex],_currentClothing,'integrity_max') and _currentClothing.one_piece isnot "broken" and $crateContents is "damaged">>
			<<continue>>
		<</if>>
		<<if (_currentClothing.outfitPrimary is undefined and _currentClothing.outfitSecondary is undefined and $crateContents is "outfits") or (_currentClothing.integrity gt clothingData(_equip[_eIndex],_currentClothing,'integrity_max'))>>
			<<continue>>
		<</if>>
		<<set _value += Math.floor(tailorClothingCost(_currentClothing,_equip[_eIndex]) * (1 - (_currentClothing.integrity / clothingData(_equip[_eIndex],_currentClothing,'integrity_max'))) * 1.25)>>

		/* Deletes the full outfit set paired with a damaged outfit piece in wardrobe before duplicating */
		<<if $crateContents is "damaged" and _currentClothing.one_piece is 1 and (_currentClothing.outfitPrimary or _currentClothing.outfitSecondary)>>
			<<set _ignoreSlot to _equip[_eIndex]>>
			<<if _currentClothing.outfitSecondary>>
				<<set _upperSlot to _currentClothing.outfitSecondary[0]>>
				<<set _upperOutfit to setup.clothes[_upperSlot][clothesIndex(_upperSlot, _currentClothing)]>>
			<<else>>
				<<set _upperSlot to _ignoreSlot>>
				<<set _upperOutfit to _currentClothing>>
			<</if>>

			<<set _itemDeleteSlots to new Set([_upperOutfit.slot, ...Object.keys(_upperOutfit.outfitPrimary)])>>
			<<set _itemDeleteSlots.delete(_ignoreSlot)>>

			/* Searches wardrobe to mark matching outfit pieces for deletion before duplicating */
			<<set _itemDeleteCandidates to Object.fromEntries(Object.entries($wardrobe)
				.filter(([slot, items]) => T.itemDeleteSlots.has(slot))
				.map(([slot, items]) => {
					/* Converted to entries in order to preserve index */
					const itemEntry = Object.entries(items)
						.filter(([, item]) => T.upperOutfit.variable === item.variable)
						/* Colours and pattern must match */
						.filter(([, item]) =>
							T.itemStatsIdentifierKeys.every((key) => {
								/* Some outfit secondaries (hanfu, overalls) do not store accessory_colour */
								if (T.itemStatsConditionalKeys[key] && T.itemStatsConditionalKeys[key](item)) {
									return true;
								}
								return T.currentClothing[key] === item[key];
							})
						)
						/* Edge case for damaged hood paired with an upper w/ hoodposition === "down" */
						.filter(([, item]) => {
							if (item.outfitPrimary) {
								return Object.keys(item.outfitPrimary).includes(T.ignoreSlot);
							}
							return true;
						})
						/* Get most damaged item */
						.reduce((minimum, [index, item]) => {
							if (minimum === undefined || item.integrity < minimum.item.integrity) {
								return {index: Number(index), item: item};
							}
							return minimum;
						}, undefined);
					return [slot, itemEntry];
				})
				.filter(([slot, itemEntry]) => itemEntry))
			>>

			<<if _ignoreSlot isnot _upperSlot>>
				<<if _itemDeleteCandidates[_upperSlot]>>
					/* Edge case for damaged lower paired with an upper w/ hoodposition === "down" */
					<<set _upperOutfit to _itemDeleteCandidates[_upperSlot].item>>
					<<set _currentClothing to clone(_upperOutfit)>>

					<<run _itemDeleteSlots.clear()>>
					<<run [_upperSlot, ...Object.keys(_upperOutfit.outfitPrimary)].forEach((k) => T.itemDeleteSlots.add(k))>>
					<<set _itemDeleteSlots.delete(_ignoreSlot)>>

					<<run Object.entries(_itemDeleteCandidates).forEach(([slot]) => {
						if (!T.itemDeleteSlots.has(slot)) {
							delete T.itemDeleteCandidates[slot];
						}
					})>>
				<<else>>
					/* Edge case for damaged secondary paired with split/partly broken upper */
					<<set _outfitRepairSkip to true>>
				<</if>>
			<</if>>

			<<if !_outfitRepairSkip>>
				/* Deletes each outfit component except for current slot and adds repair costs */
				<<run Object.entries(_itemDeleteCandidates).forEach(([slot, {index, item}]) => {
					T.value += Math.floor(tailorClothingCost(item,slot) * (1 - (item.integrity / clothingData(slot,item,'integrity_max'))) * 1.25);
					V.wardrobe[slot].deleteAt(index);
				})>>

				/* _currentClothing marked "broken" to trigger full repair */
				<<set _currentClothing.one_piece to "broken">>
				<<if _currentClothing.outfitSecondary>>
					<<set _currentClothing.outfitSecondary[1] to "broken">>
				<</if>>
				<<if _currentClothing.outfitPrimary>>
					<<run Object.entries(_currentClothing.outfitPrimary).forEach(([itemSlot, itemName]) => {
						T.currentClothing.outfitPrimary[itemSlot] = "broken";
					})>>
				<</if>>
			<</if>>
			<<unset _outfitRepairSkip>>
		<</if>>

		<<set $wardrobeRepair[_currentClothing.slot] ||= []>>
		<<set _itemStats to {
			index: _currentClothing.index
		}>>
		/* Conditionally stores values in _itemStats if they are not 0 or undefined */
		<<run _itemStatsKeys.forEach((key) => {
			if (!T.currentClothing[key]) return;
			switch (key) {
				case "one_piece": case "inherited_attributes":
					if (T.currentClothing.one_piece != "split") return;
					break;
				case "altposition": case "altsleeve":
					if (T.currentClothing[key] === "none") return;
					break;
				case "hoodposition":
					if (T.currentClothing[key] === "up") return;
					break;
			}
			T.itemStats[key] = T.currentClothing[key];
		})>>

		<<set _isBroken to (_currentClothing.one_piece === "broken")>>
		<<if _currentClothing.outfitSecondary and _isBroken>>
			/* Copy over lost primary attributes that outfit secondary inherited */
			<<if _currentClothing.inherited_attributes>>
				<<run Object.entries(T.currentClothing.inherited_attributes).forEach(([key, value]) => T.itemStats[key] = value)>>
			<</if>>
			/* If a secondary part of an outfit is broken adds the primary part so the complete outfit will be repaired */
			<<set _upperSlot to _currentClothing.outfitSecondary[0]>>
			<<set _upperIndex to clothesIndex(_upperSlot, _currentClothing)>>
			<<set $wardrobeRepair[_upperSlot] ||= []>>
			/* clothing to send for repair is now _currentClothing's upper part */
			<<set _itemStats.index to _upperIndex>>
			<<run $wardrobeRepair[_upperSlot].push(clone(_itemStats))>>

			/* Adds all outfit components from upper primary (i.e. bottom + hood from a cow onesie) */
			<<set _upperOutfit to setup.clothes[_upperSlot][_upperIndex]>>
			<<run Object.keys(_upperOutfit.outfitPrimary).forEach((itemSlot) => {
				T.itemStats.index = clothesIndex(itemSlot, T.upperOutfit);
				V.wardrobeRepair[itemSlot] ||= []
				V.wardrobeRepair[itemSlot].push(clone(T.itemStats));
			})>>
		<<else>>
			<<run $wardrobeRepair[_currentClothing.slot].push(clone(_itemStats))>>

			<<if _currentClothing.outfitPrimary and _isBroken>>
				/* Adds all broken outfit components from upper primary */
				<<set _upperOutfit to _currentClothing>>
				<<run Object.entries(_upperOutfit.outfitPrimary).forEach(([itemSlot, itemName]) => {
					if (itemName === "broken") {
						T.itemStats.index = clothesIndex(itemSlot, T.upperOutfit);
						V.wardrobeRepair[itemSlot] ||= []
						V.wardrobeRepair[itemSlot].push(clone(T.itemStats));
					}
				})>>
			<</if>>
		<</if>>
		<<run _toDelete.push(clone(_iIndex))>>
	<</for>>
	<<for ;_toDelete.length gt 0;>>
		<<run $wardrobe[_equip[_eIndex]].deleteAt(_toDelete.pop())>>
	<</for>>
<</for>>
<<if _value gt 5000>>
	<<money `-(_value - 5000)` "tailor">>
	운전기사가 상자와 <<printmoney `_value - 5000`>>를 들고 떠난다.
<<else>>
	운전기사가 상자를 들고 떠난다.
<</if>>
<br><br>
<<link [[계속|$wardrobeReturnLink]]>>
	<<unset $wardrobeReturnLink>>
	<<unset $crateContents>>
<</link>>
