:: Widgets Job [widget]
<<widget "dance_job_init">>
	/*First argument is how long the job should last in minutes. Second argument is the starting interest of the audience, out of 100. Higher is easier. */

	/* Temporary danceStudio.job object, cleared in dance_job_end */
	<<set $danceStudio.job to {
		interest: _args[1] ? _args[1] : 50,
		stage: false,
		stageExplore: 0,
		bunny: false,
		exhibitionism: false,
		exposed: false,
	}>>
	<<if Time.hour gte 20>>
		<<set $danceStudio.job.time to 1>>
	<<elseif _args[0]>>
		<<set $danceStudio.job.time to $timeStamp + (_args[0] * 60)>>
	<<else>>
		<<set $danceStudio.job.time to $timeStamp + (180 * 60)>>
	<</if>>
<</widget>>

<<widget "dance_job_end">>
	<<unset $danceStudio.job>>
	<<set $weekly.danceJob to "done">>
	<<timeTrackingEndDanceJobs>>
<</widget>>

<<widget "dance_job_text">>
	관중들은
	<<if $danceStudio.job.interest gte 100>>
		<span class="green">매혹된 것처럼 보인다.</span>
	<<elseif $danceStudio.job.interest gte 80>>
		<span class="teal">사로잡힌 것처럼 보인다.</span>
	<<elseif $danceStudio.job.interest gte 60>>
		<span class="lblue">열정적으로 보인다.</span>
	<<elseif $danceStudio.job.interest gte 40>>
		<span class="blue">흥미로워 보인다.</span>
	<<elseif $danceStudio.job.interest gte 20>>
		<span class="purple">지루해 보인다.</span>
	<<elseif $danceStudio.job.interest gte 1>>
		<span class="pink">기분이 나빠 보인다.</span>
	<<else>>
		<span class="red">화난 듯 보인다.</span>
	<</if>>
	<br><br>
<</widget>>

<<widget "dance_job_interest">>
	<<if _args[0]>>
		<<set $danceStudio.job.interest += _args[0]>>
	<</if>>
<</widget>>

<<widget "timeTrackingStartDanceJobs">>
	<<if _args[0]>>
		<<timeTrackingStart "danceJobs">><<timeTrackingStart `_args[0] + "DanceJob"`>><<timeTrackingStart `_args[0] + "DanceTips"`>>
	<</if>>
<</widget>>

<<widget "timeTrackingEndDanceJobs">>
	<<timeTrackingEnd "danceJobs">>
	<<timeTrackingEnd "partyDanceJob">><<timeTrackingEnd "docksDanceJob">><<timeTrackingEnd "danubeDanceJob">>
	<<timeTrackingEnd "partyDanceTips">><<timeTrackingEnd "docksDanceTips">><<timeTrackingEnd "danubeDanceTips">>
<</widget>>
