:: Widgets Audience [widget]
<<widget "audiencecamera">>
	<<exposure>>
	<<if $audienceselector is 1>>
		<<set $audiencedesc to "흥분한">>
		<<set $audiencecamera to $audiencecamera1>>
	<<elseif $audienceselector is 2>>
		<<set $audiencedesc to "얼굴이 빨개진">>
		<<set $audiencecamera to $audiencecamera2>>
	<<elseif $audienceselector is 3>>
		<<set $audiencedesc to "열렬한">>
		<<set $audiencecamera to $audiencecamera3>>
	<<elseif $audienceselector is 4>>
		<<set $audiencedesc to "욕망적인">>
		<<set $audiencecamera to $audiencecamera4>>
	<<elseif $audienceselector is 5>>
		<<set $audiencedesc to "갈망하는">>
		<<set $audiencecamera to $audiencecamera5>>
	<<elseif $audienceselector is 6>>
		<<set $audiencedesc to "활기찬">>
		<<set $audiencecamera to $audiencecamera6>>
	<</if>>
	<<rng>>
	<<if $swarm and $swarm.amount and $swarm.amount.active and $swarm.amount.active[0] gt 0 and $rng gte 51>>
		<<audiencecameraswarm>>
	<<elseif $rng gte 81 and $facepic isnot 1>>
		<<set $facepic to 1>>
		$audiencedesc <<putpost $audiencecamera "이">> 카메라를 당신의 얼굴로 향했다. 플래시가 터지고, <<ahe "은">> 사진을 찍었다.
		<<cleareventpool>>
		<<if $vaginastate isnot 0 and $vaginastate.endsWith("penetrated")>>
			<<addinlineevent "" 3>>
			<<personselect $vaginatarget>>
			<<if $enemytype is "beast">>
				<<if $orgasmdown gte 1>>
					<<if $face is "covered">>
						"<<pShesPost "이">> 짐승 자지가 보지에 넣어진 채 가 버렸어! 말도 안 돼."
					<<else>>
						"<<beasttypePost "이">> 공공장소에서 널 따먹고 있는데, 넌 오르가즘을 느꼈어. 어떻게 이 부끄러움을 견딜 수 있지?"
					<</if>>
				<<elseif $leglocktarget isnot undefined>>
					<<if $face is "covered">>
						"<<= $position is "doggy" ? "<<beasttype_ ul>> 향해 몸을 뒤로 밀어대고" : "다리로 <<beasttype_ ul>> 감싸고")>> 있는 주제에, 인간으로서의 존엄성이 있는 척 하지 말라고."
					<<else>>
						"이 <<bitch_ nun>> 내가 보고 싶은 것 보다도 훨씬 더 <<bred>> 것을 원하고 있어!"
					<</if>>
				<<else>>
					<<if $face is "covered">>
						"넌 <<beasttypePost>> 새끼야. 위엄 있는 척 가식 떨지마."
					<<else>>
						"이 <<bitchPost "이">> 범해지는 걸 볼 수 있어서 기쁜데."
					<</if>>
				<</if>>
			<<else>>
				<<if $orgasmdown gte 1>>
					<<if $face is "covered">>
						"보지에 채워져서 가 버리는 건 정상이야. 부끄러워 할 필요 없어."
					<<else>>
						"<<pshePost "이">> 가 버릴 때 <<pshePost "의">> 귀여운 표정 좀 봐. 좀 더 <<pherPost "의">> 보지를 따먹어."
					<</if>>
				<<elseif $leglocktarget isnot undefined>>
