:: Gwylan Widgets [widget]
<<widget "gwylanGreeting">><<silently>>
	<<set $_gwylanSpeech to "">>
	<<if !$daily.gwylan.greeting>>
		<<set $daily.gwylan.greeting to true>>
		<<set $_gwylanSpeech to "<br><br>">>
		<<if $location is "cafe" and $daily.robin_in_cafe is 1>>
			<<set $_gwylanSpeech += "Gwylan ">>
		<<else>>
			<<set $_gwylanSpeech += "<<nnpc_He 'Gwylan'>> ">>
		<</if>>
		<<if $gwylan.wary gte 5>>
			<<set $_gwylanSpeech += "looks through you.">>
		<<elseif _gwylanLastSeenDays gte 21>>
			<<set $_gwylanSpeech += "looks surprised, but happy, to see you.">>
		<<elseif $gwylan.hunting is 3>>
			<<set $_gwylanSpeech += "looks both happy and irritated to see you.">>
		<<elseif $daily.gwylan.ritual>>
			<<set $_gwylanSpeech += "gives you a warm smile across beetroot-red cheeks.">>
		<<elseif _gwylanLovePercent gte 25>>
			<<set $_gwylanSpeech += "perks up upon seeing you.">>
		<<else>>
			<<if $location is "cafe">>
				<<set $_gwylanSpeech += "smiles softly, but continues staring out at the sea.">>
			<<else>>
				<<set $_gwylanSpeech += "waves you over.">>
			<</if>>
		<</if>>

		<<set $_linePool to []>>
		<<if $moorLuck gt 0>>
			<<set $_linePool.push(`"There's an air of luck around you today.`)>>
		<</if>>
		<<if $gwylanSeen.includes("romance")>>
			<<set $_linePool.push(`"Hello, dearest.`)>>
		<<else>>
			<<set $_linePool.push(`"Hello, dear.`)>>
		<</if>>
		<<if $gwylanSeen.includes("ritual_beast")>>
			<<set $_linePool.push(`"Hello, <<pcpetname 'Gwylan' 'name'>>.`)>>
		<</if>>
		<<if $location is "forest_shop" and $gwylanTalked.length gte 10 and (!$gwylan.wary or $gwylan.wary lte 1)>>
			<<set $_linePool.push(`"My favourite customer!`)>>
		<</if>>
		<<if $exposed gte 2 and $location is "forest_shop">>
			<<set $_linePool.push(`<<He>> avoids looking down. "Must be chilly in here.`)>>
		<</if>>
		<<if $worn.head.name is "rose" and $worn.head.colour.includes("pink")>>
			<<set $_linePool.push(`<<He>> frowns upon seeing the pink rose in your hair. "Hello.`)>>
		<<elseif $worn.head.name is "sage witch hat">>
			<<set $_linePool.push(`"Nice hat.`)>>
		<</if>>
		<<if $worn.upper.name === "chain tunic" && $worn.lower.name === "chain tunic skirt" ||
			$worn.upper.name.includes("vintage") && $worn.lower.name.includes("vintage")>>
			<<set $_linePool.push(`"That looks really good on you.`)>>
		<<elseif $worn.upper.type.includes("costume") && $worn.lower.type.includes("costume") ||
			(V.worn.upper.type.includes("naked") && V.worn.under_upper.type.includes("costume") &&
			V.worn.lower.type.includes("naked") && V.worn.under_lower.type.includes("costume"))>>
			<<set $_linePool.push(`"Nice outfit.`)>>
		<</if>>
		<<if $location is "forest_shop" and $worn.feet.name is "reindeer slippers">>
			<<set $_linePool.push(`<<He>> notices your slippers. "Hello, deer.`)>>
		<</if>>

		<<if $_linePool.length>>
			<<set $_gwylanSpeech += " " + $_linePool.pluck()>>
			<<if _gwylanLastSeenDays gte 21>>
				<<set $_gwylanSpeech += `" <<He>> rubs the back of <<his>> head. "I'm glad to see you again. I was starting to think you had forgotten about me.`>>
			<</if>>
			<<if $location is "cafe" and getRobinLocation() is "cafe">>
				<<set $_gwylanSpeech += ` Come, join us." Robin smiles and waves at you.`>>
			<<else>>
				<<set $_gwylanSpeech += `"`>>
			<</if>>
		<</if>>
	<</if>>
<</silently>><<print $_gwylanSpeech>><</widget>>

<<widget "gwylanOptions">>
	<<if $gwylanPassTime>>
		<<pass $gwylanPassTime>>
		<<unset $gwylanPassTime>>
	<</if>>
	<<set _gwylanLocation to gwylanSchedule()>>
	<<set $gwylan.timer.lastSeen to Time.date.timeStamp>>

	<<if _gwylanLocation is "nowhere">>
		/* Nothing */
		<<gwylanOptionsLeave>>
		<<exit>>
	<</if>>

	/* Story progress */
	<<if !$gwylanSeen.includes("struggles") and $gwylan.progress gte 15 and _gwylanLovePercent gte 65 and $gwylanSeen.includes("ritual_beast") and $dateCount.GwylanBeast gte 2 and $gwylan.request.event isnot "meetAtCafe" and !gwylanRequestMet() and C.npc.Gwylan.dom gte 10 and C.npc.Gwylan.lust gte 25>>
		<<set $_noLeave to true>>
		<<if $location is "forest_shop">>
			<<He>> looks unsure of <<himself>> for a moment. "I need to ask you something," <<he>> blurts out.
			<br><br>

			<<link [[Next|Gwylan Talk Struggles Intro]]>><</link>>
			<br>
		<<else>>
			Gwylan's eyes have closed. <span class="blue">You try getting <<his>> attention, but <<he>> won't respond.</span>
			<br><br>

			<<if $location is "cafe" and !(between($chef_state, 7, 8) and $chef_rework lte 30)>>
				<<getouticon>><<link [[Say goodbye and go back inside (0:01)|Gwylan Talk Struggles Intro]]>><<pass 1>><</link>>
			<<elseif $location is "cafe">>
				<<getouticon>><<link [[Say goodbye (0:01)|Gwylan Talk Struggles Intro]]>><<pass 1>><</link>>
			<<else>>
				<<getouticon>><<link [[Back to the shop|Gwylan Talk Struggles Intro]]>><</link>>
			<</if>>
			<br>
		<</if>>
		<<exit>>
	<</if>>
	<<if $location is "forest_shop" and _gwylanLovePercent gte 80 and C.npc.Gwylan.dom gte 75 and $dateCount.GwylanSex gte 5 and $gwylan.sea gte 5 and !$gwylanSeen.includes("partners") and _gwylanStatus.includes("lust") and !$weekly.gwylanLIChance and $exposed is 0>>
		<<set $weekly.gwylanLIChance to true>>
		You feel Gwylan's hand on yours.
		<br><br>

		"Would you like to join me for a walk?" <<he>> asks. "I'd like to talk about something." <<He>> pauses. "I won't get angry at you again. Promise."
		<br><br>

		<<link [[Yes (1:00)|Gwylan Promenade Walk]]>><<endevent>><<pass 20>><<trauma -1>><</link>><<ltrauma>><<gyearning true>>
		<br>
		<<link [[Not right now|Gwylan Promenade Walk No]]>><<npcincr Gwylan dom -5>><</link>><<llyearning>>
		<br>
		<<exit>>
	<</if>>

	/* Leaving the cafe for elsewhere */
	<<if $location is "cafe" and !(between($chef_state, 7, 8) and $chef_rework lte 30) and $gwylan.robin gte 10 and $daily.robin_in_cafe and getRobinLocation() isnot "cafe" and false>> /* WARNING! Re-enable later for Gwybin cafe */
		Gwylan stands up with <<his>> plate. <<He>> empties the crumbs into the air, just as a flock of seagulls pass by. They don't let a single crumb land on the beach.
		<br><br>

		<<He>> smiles at you. "We better get going. You don't want to be late for school." Robin nods and grabs <<person2>><<his>> backpack. <span class="red">TODO: Walking to school with Gwylan and Robin.</span>
		<br><br>
		<<schoolicon "building">><<link [[Walk to school (0:05)|Gwylan Walk School Robin]]>><<set $daily.gwylan.cafeSkip to true>><<pass 5>><<unset $cafe_study>><<storeon "cafe_balcony">><<set $phase to 1>><</link>>
		<br>
		<<getouticon>><<link [[Excuse yourself and go back inside (0:01)|Ocean Breeze]]>><<pass 1>><<unset $cafe_study>><<storeon "cafe_balcony">><<endevent>><</link>>
		<br>
		<<exit>>
	<</if>>
	<<if $location is "cafe" and Time.schoolDay and (Time.hour is 8 and Time.minute gte 40 or Time.hour is 9) and !$daily.gwylan_skip_school and ($gwylanSeen.includes("cafe_walk") or ($gwylan.sea + ($gwylanTalked.count("fox_mask") * 20) + ($gwylanTalked.count("dark_pendant") * 20) gte 40))>>
		<<if _gwylanTF.known>>
			Gwylan's ears twitch, and <<he>> seems to realise something.
		<</if>>

		<<He>> smiles at you.
		<<if !$gwylanSeen.includes("cafe_walk")>>
			<<set $gwylanSeen.pushUnique("cafe_walk")>>
			<<if $worn.neck.name is "familiar collar" and $worn.neck.cursed is 1 or $gwylanSeen.includes("petplay") and $worn.neck.type.includes("leash")>>
				<<set _magicLeash to true>>
				"School starts for you soon, doesn't it?" <<He>> grabs your leash and pulls you closer, trailing two fingers up your chest. "Want me to walk you there?"
			<<else>>
				"School starts for you soon, doesn't it? Want me to walk you there?"
			<</if>>
		<<else>>
			<<if $worn.neck.name is "familiar collar" and $worn.neck.cursed is 1 or $gwylanSeen.includes("petplay") and $worn.neck.type.includes("leash")>>
				<<set _magicLeash to true>>
				"We better get going, <<pcpetname "Gwylan" "my">>." <<He>> grabs your leash and pulls you closer, trailing two fingers up your chest. "You don't want to be late for school."
			<<else>>
				"We better get going, <<pcpetname "Gwylan" "simple">>. You don't want to be late for school."
			<</if>>
		<</if>>
		<br><br>

		<<schoolicon "building">><<link [[Walk to school (0:10)|Gwylan Walk School Solo]]>><<set $daily.gwylan.cafeSkip to true>><<pass 10>><<unset $cafe_study>><<storeon "cafe_balcony">><</link>>
		<br>
		<<refuseicon>><<link [[Decline the offer (0:01)|Gwylan Walk School Solo Decline]]>><<pass 1>><<set $daily.gwylan.cafeSkip to false>><<set $daily.gwylan_skip_school to 1>><</link>>
		<br>
		<<exit>>
	<</if>>
	<<if $location is "cafe" and !["cafe", "cliff", "walking_to_cafe"].includes(_gwylanLocation)>>
		<<if !(between($chef_state, 7, 8) and $chef_rework lte 30)>>
			Gwylan stands up with <<his>> plate. <<He>> empties the crumbs into the air, just as a flock of seagulls pass by. They don't let a single crumb land on the beach.
			<br><br>
		<</if>>

		"I'm heading back to the shop," <<he>> says.
		<<if $gwylan.request is "meetAtShop" and !$daily.gwylan.preventProgress>>
			"Remember to meet me there later, please."
		<<elseif $daily.gwylan.ritualRequestBlocked and $gwylanSeen.includes("ritual_beast")>>
			"If you still wish to enact the ritual today, you know where to find me." <<He>> winks, and leaves the balcony.
		<<else>>
			"Thank you for the company." <<He>> bows, and leaves the balcony.
		<</if>>
		<br><br>

		<<gwylanOptionsLeave>>
		<<exit>>
	<</if>>

	/* Leaving the forest shop for elsewhere */
	<<if $location is "forest_shop" and ["walking_to_cafe", "cafe", "cliff"].includes(_gwylanLocation) and !$daily.gwylan.cafeOfferDeclined>>
		Gwylan's eyes are glued to a nearby cuckoo clock. <<He>> suddenly walks by you, grabbing <<his>> hat and an umbrella from a stand.
		<<if ["walking_to_cafe", "cafe"].includes(_gwylanLocation)>>
			<<if $gwylanSeen.includesAny("cafe_walk", "struggles") or $gwylan.sea gte 10>>
				"Breakfast time," <<he>> says.
				<<if Time.schoolDay and $gwylanSeen.includes("cafe_walk")>>
					"Would you like to accompany me? I could walk you to school afterwards."
				<<else>>
					"Would you like to accompany me?"
				<</if>>
				<br><br>

				<<cafeicon>><<link [[Walk with Gwylan (0:15)|Gwylan Walk Cafe Solo]]>><<pass 15>><<set $phase to 0>><</link>>
				<br>
				<<refuseicon>><<link [[Decline the offer (0:01)|Gwylan Walk Cafe Solo]]>><<pass 1>><<set $phase to 1>><<set $daily.gwylan.cafeOfferDeclined to true>><</link>>
			<<else>>
				"Breakfast time," <<he>> says. "Sorry. The <<if Time.season is "winter">>gingerbread waits<<else>>crepes wait<</if>> for nobody.<<if $gwylanSeen.includes("cafe")>> Meet me at the cafe later?<</if>>"
				<br><br>

				<<gwylanOptionsLeave>>
			<</if>>
		<<else>>
			"I'm going to..." <<He>> looks unsure for a moment. "Apologies, with my routine disrupted by the renovation I don't really know what to do with myself. I'll be on Cliff street."
			<br><br>

			<<gwylanOptionsLeave>>
		<</if>>
		<<exit>>
	<</if>>

	/* Normal options */
	<<if $location is "forest_shop" and _gwylanLocation is "sleep">>
		<<He>> lets out an exaggerated yawn. "You sure know how to make the time run away from me. I'm off to sleep."
		<br><br>
	<<else>>
		<<if $location is "forest_shop">>
			<<set $daily.gwylan.clothesTalk ||= 0>>
			<<if $daily.gwylan.clothesTalk gte 3 and !$daily.gwylan.enoughTalk>>
				<<set $daily.gwylan.enoughTalk to true>>
				<<if $daily.gwylan.traumaTalk>>
					<<He>> dons a sad smile. "Thank you for confiding in me. Forgive me, but this is a lot to process. Can we continue another day?"
					<br><br>
					<span class="blue">Gwylan needs time to process what you've told <<him>>.</span>
					<br><br>
				<<else>>
					<<He>> stretches. "Thank you for sharing your stories. I think that's all I can process for one day. Same time tomorrow?"
					<br><br>
					<span class="blue">Gwylan wants to hear more stories another day.</span>
					<br><br>
				<</if>>
			<<elseif $daily.gwylan.enoughTalk>>
				<span class="blue">Gwylan wants to hear more stories another day.</span>
				<br><br>
			<</if>>
			<<gwylanOptionsSpecial>>
			<<if $gwylanSeen.includes("cafe_walk") and $exposed is 0 and (Time.hour === 6 && Time.minute >= 45 || Time.hour is 7)>>
				<<cafeicon>><<link [[Ask to walk to the cafe (0:15)|Gwylan Walk Cafe Ask]]>><<pass 15>><</link>>
				<br>
			<</if>>
			<<gwylanOptionsRequest>>
			<<gwylanOptionsService>>
			<<gwylanOptionsClothing>>
		<</if>>

		<<if $forest_shop_intro and !$gwylanSeen.includes("clothes_intro")>>
			<<set $_askbr to true>>
			<<socialiseicon "ask">><<link [[Ask Gwylan about the shop (0:10)|Gwylan Talk Clothes Intro]]>><<pass 10>><</link>>
			<br>
		<</if>>

		<<if $location is "cafe">>
			<<gwylanOptionsCafe>>
		<</if>>

		<<if $gwylanSeen.includes("yearning")>>
			<<gwylanOptionsGift>>
		<</if>>
	<</if>>
	<<gwylanOptionsLeave>>
<</widget>>

<<widget "gwylanOptionsSpecial">>
	<<if !_hideRitualOptions>>
		<<if $gwylanSeen.includes("ritual_beast")>>
			<<if $gwylan.timer.ritual and Time.date.dayDifference(new DateTime(V.gwylan.timer.ritual)) > 0>>
				<<set _ritualDays to Time.date.dayDifference(new DateTime(V.gwylan.timer.ritual))>>
				<<if _ritualDays gt 7>>
					<<set $gwylan.timer.ritual to Time.date.timeStamp + (7 * 86400)>>
					<<set _ritualDays to 7>>
				<</if>>
				<<set $_askbr to true>>
				<<icon "clothes/witch_hat_sage.png">><span class="pink">Gwylan will be ready for another ritual in <<number _ritualDays>> <<pluralise _ritualDays "day">>.</span>
			<<elseif $gwylanSeen.includes("ritual_sex_intro")>>
				<<set $_askbr to true>>
				<<icon "clothes/witch_hat_sage.png">><<link [[Help Gwylan with <<his>> ritual (?:??)|Gwylan Ritual Select]]>><</link>>
			<<else>>
				<<set $_askbr to true>>
				<<icon "clothes/witch_hat_sage.png">><<link [[Help Gwylan with <<his>> ritual (?:??)|Gwylan Forest Journey Prep]]>><<endevent>><</link>>
			<</if>>
			<br>
			<<if (!$gwylan.timer.sample or $gwylan.timer.sample lte Time.date.timeStamp) and !["meetAtCafe", "sample"].includes($gwylan.request.event)>>
				<<set $_askbr to true>>
				<<if $gwylanSeen.includes("sample")>>
					<<ind>><<link [[Help Gwylan replace the measuring charms|Gwylan Request Sample]]>><</link>>
				<<else>>
					<<ind>><<link [[Ask Gwylan about the poison in the world|Gwylan Request Sample]]>><</link>>
				<</if>>
				<br>
			<</if>>
		<<elseif !$gwylanSeen.includes("ritual_beast") and $gwylan.request.event is "meetAtShop" and !$daily.gwylan.preventProgress>>
			<<set $_askbr to true>>
			<<socialiseicon "ask">><<link [[Help Gwylan (?:??)|Gwylan Forest Journey Prep]]>><<endevent>><</link>>
			<br>
		<</if>>
	<</if>>

	/* ToDo: Gwylan ToDo: Magic Tattoos */
	<<if $gwylanSeen.includes("ritual_beast") and !$gwylanSeen.includes("tattoos_intro")>>
		<<set $_askbr to true>>
		<<ind>><<link [[Ask Gwylan about <<his>> tattoos|Gwylan Talk Tattoos Intro]]>><</link>>
		<br>
	<</if>>
	<<if $gwylanSeen.includes("gwylan_ears") and !$gwylanSeen.includesAny("gwylan_ears_talk", "gwylan_tf_revealed") and $gwylanSeen.includes("hat_found")>>
		<<set $_askbr to true>>
		<<icon "clothes/witch_hat_sage.png">><<link [[Ask Gwylan about the ears on <<his>> hat (0:05)|Gwylan Talk TF Ears]]>><<pass 5>><</link>>
		<br>
	<</if>>
	<<if $gwylanSeen.includes("gwylan_tail") and !$gwylanSeen.includesAny("gwylan_tail_talk", "gwylan_tf_revealed")>>
		<<set $_askbr to true>>
		<<ind>><<link [[Ask Gwylan about <<his>> fake tail (0:05)|Gwylan Talk TF Tail]]>><<pass 5>><</link>>
		<br>
	<</if>>
	<<if $gwylanSeen.includes("gwylan_fangs") and !$gwylanSeen.includesAny("gwylan_fangs_talk", "gwylan_tf_revealed")>>
		<<set $_askbr to true>>
		<<ind>><<link [[Ask Gwylan about <<his>> sharp teeth (0:05)|Gwylan Talk TF Fangs]]>><<pass 5>><</link>>
		<br>
	<</if>>
	<<if $gwylanSeen.includesAll("gwylan_ears_talk", "gwylan_tail_talk", "gwylan_fangs_talk") and $settings.transformAnimalEnabled and ($gwylanTalked.includes("transformation") or $gwylanSeen.includes("player_tf")) and !$gwylanSeen.includes("gwylan_tf_revealed")>>
		<<set $_askbr to true>>
		<<icon "transformation.png">><<link [[Confront Gwylan about <<his>> foxiness (0:05)|Gwylan Talk TF Revealed Confront]]>><<pass 5>><</link>>
		<br>
	<</if>>
	<<if $avery_mansion>>
		<<if $avery_mansion.fox.known and $avery_mansion.fox.end and !$brownFoxRevealed and $gwylanTalked.includes("fox_mask") and ($brownFoxWoundedHint or $gwylanSeen.includes("yearning"))>>
			<<set $_askbr to true>>
			<<icon "clothes/foxmask.png">><<link [[Ask <<him>> to try on the fox mask (0:05)|Gwylan Talk Brown Fox]]>><<pass 5>><</link>>
			<br>
		<<elseif $brownFoxRevealed and !$brownFoxMaskTalk and $gwylanTalked.includes("fox_mask") and $avery_fate>>
			<<set $_askbr to true>>
			<<icon "clothes/foxmask.png">><<link [[Ask about the brown fox mask (0:05)|Gwylan Talk Brown Fox Mask]]>><<pass 5>><</link>>
			<br>
		<</if>>
	<</if>>
	<<if $_askbr>><br><</if>>
<</widget>>

<<widget "gwylanOptionsRequest">>
	<<if !$gwylan.request.event and $gwylanSeen.includes("hat_found")>>
		<<set $_reqbr to true>>
		<<socialiseicon "ask">><<link [[Ask <<him>> if <<he>> needs help with anything|Gwylan Request]]>><</link>>
		<br>
	<</if>>
	<<if $harpy gte 6 and $birdFly gte 1 and $gwylan.request.event isnot "preen" and !$plucked and $gwylanSeen.includesAny("preen", "request_preen")>>
		<<set $_reqbr to true>>
		<<tficon "bird">><<link [[Ask <<him>> to preen your wings (0:40)|Gwylan Request Preen]]>><</link>><<lstress>><<garousal>>
		<br>
	<</if>>
	<<if $gwylan.request.event and $location is "forest_shop">>
		<<switch $gwylan.request.event>>
			<<case "clothing">>
				<<if gwylanRequestMet()>>
					<<set $_reqbr to true>>
					<<set $_iconItem to $gwylan.request.items.find(item => item.root)>><<set $_iconWorn to V.worn[$_iconItem.slot]>>
					<<clothingicon $_iconWorn $_iconItem.slot>>
					<<if $gwylan.request.special and $gwylan.request.special isnot "none">>
						<<if $gwylan.request.special is "gold accessories">>
							<<link [[`Show <<him>> the gold accessories`|Gwylan Request Clothes Complete]]>><</link>>
						<<elseif $gwylan.request.details.outfit>>
							<<link [[`Show <<him>> the $gwylan.request.special outfit`|Gwylan Request Clothes Complete]]>><</link>>
						<<else>>
							<<link [[`Show <<him>> the $gwylan.request.special`|Gwylan Request Clothes Complete]]>><</link>>
						<</if>>
					<<elseif $_iconWorn.name>>
						<<link [[`Show <<him>> the $_iconWorn.name`|Gwylan Request Clothes Complete]]>><</link>>
					<<else>>
						<<link [[Show <<him>> the clothing <<he>> asked for|Gwylan Request Clothes Complete]]>><</link>>
					<</if>>
					<br>
				<<elseif $earSlime.forcedDressing and $gwylan.request.items.some(item => ![V.earSlime.forcedDressing, "n"].includes(item.gender)) ||
					$earSlime.forcedCommando gt 0 && $gwylan.request.items.some(item => item.slot === "under_lower") ||
					$gwylan.request.items.some(item => item.reveal lt earSlimeCorruptionClothes() && setup.clothingLayer.torso.includes(item.slot))>>
					<<set $_reqbr to true>>
					<<set _earSlimeText to numberOfEarSlime() gt 1 ? "ear slimes" : "ear slime">>
					<<socialiseicon "angry">><<link [[`Tell <<him>> your _earSlimeText won't let you complete <<his>> request`|Gwylan Talk Ear Slime Clothes]]>><</link>>
					<br>
				<</if>>
			<<case "ingredients">>
				<<if $gwylan.request.special is "tutorial" and $gwylanTutorialShrooms + $plants.wolfshroom.amount gte 3>>
					<<set $_reqbr to true>>
					<<tendingicon "wolfshroom">><<link [[Give <<him>> the wolfshrooms|Gwylan Request Tutorial Complete]]>><</link>>
					<br>
				<<elseif gwylanRequestMet()>>
					<<set $_reqbr to true>>
					<<set $_iconItem to $gwylan.request.items.find(item => item.root)>>
					<<set $_iconPlant to setup.plants[$_iconItem.name].icon.replace(/\.[^/.]+$/, "")>>
					<<tendingicon $_iconPlant>><<link [[Give <<him>> the ingredients <<he>> asked for|Gwylan Request Ingredients Complete]]>><</link>>
					<br>
				<</if>>
			<<case "sample">>
				<<if gwylanRequestMet()>>
					<<set $_reqbr to true>>
					<<scienceicon>><<link [[Give <<him>> the samples|Gwylan Request Sample Complete]]>><</link>>
					<br>
				<</if>>
			<<case "samplePlayer">>
				/* ToDo: Gwylan */
			<<case "cream">>
				<<set $_reqbr to true>>
				<<tendingicon "cream">><<link [[Take up <<his>> lewd offer|Gwylan Request Cream]]>><</link>>
				<br>
			<<case "preen">>
				<<if $harpy gte 6 and $gwylan.request.special is "harpy">>
					<<set $_reqbr to true>>
					<<tficon "bird">><<link [[Let <<him>> preen your wings (0:40)|Gwylan Request Preen]]>><</link>><<lstress>><<garousal>>
					<br>
					<<if $bird?.materials?.feathers gte 10>>
						<<birdicon "feathers">><<link [[Give <<him>> 10 feathers instead|Gwylan Request Feathers]]>><<set $phase to 1>><</link>>
						<br>
					<</if>>
				<<elseif $bird?.materials?.feathers gte $gwylan.request.items.find(feather => feather.name === "feathers").need or $harpy gte 6>>
					<<set $_reqbr to true>>
					<<if $bird?.materials?.feathers gte $gwylan.request.items.find(feather => feather.name === "feathers").need>>
						<<birdicon "feathers">><<link [[Give <<him>> the requested feathers|Gwylan Request Feathers]]>><<set $phase to 2>><</link>>
						<br>
					<</if>>
					<<if $harpy gte 6>>
						<<tficon "bird">><<link [[Let <<him>> preen your wings instead (0:40)|Gwylan Request Preen]]>><</link>><<lstress>><<garousal>>
						<br>
					<</if>>
				<</if>>
			<<case "chastity">>
				<<if !playerChastity()>>
					<<lockicon "unlock">><<link [[Tell <<him>> you got your chastity device removed|Gwylan Chastity Removed]]>><</link>>
					<br>
				<<elseif playerChastity() and gwylanRequestMet()>>
					<<lockicon "unlock">><<link [[Give <<him>> the items <<he>> asked for (1:00)|Gwylan Chastity Removal Gold]]>><<pass 20>><</link>>
					<br>
				<</if>>
			<<default>>
				/* Request not applicable to interaction here */
		<</switch>>
		<<if !gwylanRequestMet() and !$gwylan.request.command and $debug is 1>>
			/* ToDo: Gwylan - rerolling requests */
			<span class="red">DEV NOTE: Request rerolling not yet implemented. Clears current request. May entirely break story progression if used carelessly.</span>
			<br>
			<<set $_reqbr to true>>
			<<icon "cross.png">><<link [[Ask Gwylan if you can do something else|Forest Shop Entrance]]>><<gwylanRequestEnd "skip">><<endevent>><</link>>
			<br>
		<</if>>
	<</if>>
	<<if $_reqbr>><br><</if>>
<</widget>>

<<widget "gwylanOptionsService">>
	<<if playerChastity() and $gwylan.request.hold isnot "chastity" and ($gwylanSeen.includesAny("chastity", "partners") or $gwylanJordanChastity or $gwylan.request.event is "chastity" and !$gwylan.request.items?.length)>>
		<<if $gwylan.requestLast?.hold is "chastity" and (!$gwylan.request.event or $gwylan.request.event is "chastity")>>
			<<lockicon>><<link [[Ask for help removing your chastity device|Gwylan Chastity Removal]]>><<set $phase to "skip">><</link>>
		<<else>>
			<<lockicon>><<link [[Ask for help removing your chastity device|Gwylan Chastity Removal]]>><</link>>
		<</if>>
		<br>
	<</if>>
	<<if !$gwylan.taken and $worn.neck.name is "familiar collar" and $gwylanSeen.includes("familiar_collar") and $daily.gwylan.collar_lock isnot 2>>
		<<if $worn.neck.cursed is 1>>
			<<icon "clothes/familiar_collar.png">><<link [[Ask Gwylan to unlock your familiar collar|Gwylan Familiar Collar Unlock]]>><</link>>
		<<else>>
			<<icon "clothes/familiar_collar.png">><<link [[Ask Gwylan to lock your familiar collar|Gwylan Familiar Collar Lock]]>><</link>><<gwylanHypnoNote>>
		<</if>>
		<br>
	<</if>>
	<<if $gwylanSeen.includesAll("partners", "familiar_collar") and (!$gwylan.timer.petBed or $gwylan.timer.petBed and Time.date.dayDifference(new DateTime(V.gwylan.timer.petBed)) <= 1) and $gwylan.request.hold isnot "petBed" and ($tiredness gte 1000 or $gwylanSeen.includes("doggy_bed"))>>
		<<if $gwylan.timer.petBed and Time.date.dayDifference(new DateTime(V.gwylan.timer.petBed)) <= 1>>
			<<bedicon "gwylanpet">><<link [[Ask Gwylan to keep your pet bed out for another week|Gwylan Dog Bed Request]]>><</link>>
		<<elseif $gwylanSeen.includes("doggy_bed")>>
			<<bedicon "gwylanpet">><<link [[Ask Gwylan to drag your pet bed out again|Gwylan Dog Bed Request]]>><</link>>
		<<else>>
			<<bedicon "default">><<link [[Ask Gwylan if you can sleep here|Gwylan Dog Bed Request]]>><</link>>
		<</if>>
		<br>
	<</if>>
	<<if !_hideHypnosisOptions>>
		<<if $gwylanSeen.includes("player_tf")>>
			<<if $angel gte 4 or $fallenangel gte 2 or $demon gte 4 or $wolfgirl gte 4 or $cat gte 4 or $cow gte 4 or $harpy gte 4 or $fox gte 4>>
				<<set $_hypnobr to true>>
				<<icon "transformation.png">><<link [[Ask for help coming to terms with your inner self|Gwylan Hypnosis Start]]>><<set $phase to "peace">><</link>><<gwylanHypnoNote>>
				<br>
			<</if>>
		<</if>>
		<<if numberOfEarSlime(true)>>
			<<if ($gwylanJordanSlime or $gwylanSeen.includes("ear_slime_intro")) and !$gwylanSeen.includes("ear_slime")>>
				<<set $_hypnobr to true>>
				<<socialiseicon "ask">><<link [[Ask about your ear <<pluralise numberOfEarSlime(true) "slime">>|Gwylan Talk Ear Slime]]>><</link>>
				<br>
			<<elseif $gwylanSeen.includes("ear_slime")>>
				<<set $_hypnobr to true>>
				<<hypnosisicon>><<link [[Ask for help silencing your ear <<pluralise numberOfEarSlime(true) "slime">>|Gwylan Hypnosis Start]]>><<set $phase to "silence">><</link>><<gwylanHypnoNote>>
				<br>
			<</if>>
		<</if>>
		<<if $gwylanSeen.includes("request_intro") and $sleeptrouble gte 1>>
			<<set $_hypnobr to true>>
			<<bedicon "zzz">><<link [[Tell Gwylan you're having trouble sleeping|Gwylan Hypnosis Start]]>><<set $phase to "slumber">><</link>><<gwylanHypnoNote>>
			<br>
		<</if>>
		/* ToDo: Gwylan - make proper unlock condition */
		<<if $gwylanSeen.includes("ritual_beast") and $hallucinations gte 2>>
			<<set $_hypnobr to true>>
			<<symbol "awareness">><<link [[Ask Gwylan for help with hallucinations|Gwylan Hypnosis Start]]>><<set $phase to "insight">><</link>><<gwylanHypnoNote>>
			<br>
		<</if>>
		<<if $gwylanSeen.includes("request_intro") and Object.keys(V.hypnosis_traits).filter(trait => ["suggestion", "scream", "cover", "deviancy"].includes(trait) && V.hypnosis_traits[trait] >= 1).length>>
			<<set $_hypnobr to true>>
			<<hypnosisicon>><<link [[Ask for help forgetting hypnosis|Gwylan Hypnosis Start]]>><<set $phase to "removal">><</link>><<gwylanHypnoNote>>
			<br>
		<</if>>
		<<if $_hypnobr>><br><</if>>
	<</if>>

	/* ToDo: Gwylan - Sneaking into the garden */

	/* ToDo: Gwylan - Punishments for disobedience, including familiar collar */

	/* ToDo: Gwylan - break down to Gwylan about your troubles? Leads to existing fruit trauma scene. */

	/* ToDo: Gwylan - Telling Gwylan about misc troubles. Pool of possible scenes based on trauma, traits, etc. Could unlock hypnosis services.
	'tell Gwylan you've been having trouble sleeping' etc.
	V.gwylan.request.missed is 1 or V.gwylan.timer.lastSeen too high, say player feels bad about not seeing Gwylan
	*/

	/* ToDo: Gwylan - basic service unrelated to hypno that can be done without cooldown? */

<</widget>>

<<widget "gwylanOptionsClothing">>
	<<if $gwylanSeen.includes("clothes_intro")>>
		<<if $daily.gwylan.enoughTalk>>
			/* Nothing */
		<<else>>
			/* Get sets that the player can talk about */
			<<set $_setsAtForestShop to getSpecialSets(sets => sets.shop.includes("forest"))>>
			/* Get unlocked sets */
			<<set $_setsUnlocked to getUnlockedSpecialSets().filter(set => $_setsAtForestShop.includes(set) && !$gwylanTalked.includes(set))>>
			<<if !$gwylanSeen.includesAny("clothes_talk_cheated", "clothes_talk_bypassed")>>
				/* Count cheat sets for one-time event */
				<<set $_setsCheated to getUnlockedSpecialSets(V.specialClothes.filter(c => c.unlocked === 1).map(c => c.name)).filter(set => $_setsAtForestShop.includes(set) && !$gwylanTalked.includes(set))>>
				<<set $_setsUnlocked to $_setsUnlocked.concat($_setsCheated)>>
			<</if>>
			<<if !$gwylanSeen.includes("clothes_talk_bypassed")>>
				/* Count feat sets for one-time event */
				<<set $_setsBypassed to getUnlockedSpecialSets(V.specialClothes.filter(c => c.unlocked === 2).map(c => c.name)).filter(set => $_setsAtForestShop.includes(set) && !$gwylanTalked.includes(set))>>
				<<set $_setsUnlocked to $_setsUnlocked.concat($_setsBypassed)>>
			<</if>>
			<div class="no-numberify">
				/* Talk to Gwylan about further heists after catsuit conversation */
				<<if $gwylanTalked.includes("catsuit") and
				(($bird?.hunts?.estate is "complete" and !$gwylanTalked.includes("heist_silver")) or
				($lakestealgold is 1 and !$gwylanTalked.includes("heist_gold")) or
				($compound?.symbol.includes("docks") and !$gwylanTalked.includes("symbol")) or
				(($wrenHeist or $wrenSeen?.includes("heist")) and !$gwylanTalked.includes("heist_wren")))>>
					<<set $_catsuit to clone(setup.clothes.upper[75])>>
					<<set $_catsuit.colour to "black">>
					<<clothingicon $_catsuit "upper">><<link [[Tell <<him>> about your criminal adventures|Gwylan Talk Heists]]>><<set $phase to "silver">><</link>>
					<br>
				<</if>>
				<<if !$gwylanSeen.includes("clothes_talk_savescum") and _saveLoaded>>
					<<if localStorage.getItem("gwylanTalk") is "seen">>
						<<set $gwylanSeen.pushUnique("clothes_talk_savescum")>>
					<<elseif localStorage.getItem("gwylanTalk") is "nobody">>
						<!-- Do nothing. Don't trigger savescum message if nobody happens -->
					<<elseif !localStorage.getItem("gwylanTalk")>>
						<<run localStorage.setItem("gwylanTalk", 0)>>
					<<else>>
						<<run localStorage.setItem("gwylanTalk", Number(localStorage.getItem("gwylanTalk")) + 1)>>
					<</if>>
				<</if>>
				<<for $_label, _value range $_setsUnlocked>>
					<<set $_subsetVals to Object.keys(setup.specialClothesSets).filter(set => setup.specialClothesSets[set].subsetOf?.includes(_value))>>
					<<if $gwylanTalked.includesAll($_subsetVals)>>
						<<set $_clothesbr to true>>
						/* If value is a set that includes other sets, such as 'halloween', do not show the talk link unless all of its subsets have been talked about already. */
						/* Empty arrays are valid to bypass this check, which is intended. */
						/* Get icon provided by setup */
						<<set _timeToPass to $_subsetVals.length ? 20 : 15>>
						<<set $_clothingObject to clone(setup.specialClothesSets[_value])>>
						<<if $_clothingObject.icon is "clothes">>
							<<set $_cIcon to clone(setup.clothes[$_clothingObject.iconSlot][$_clothingObject.iconIndex])>>
							<<set $_cIcon.colour to $_clothingObject.iconColor>><<set $_cIcon.accessory_colour to $_clothingObject.iconAccColor>>
							<<clothingicon $_cIcon $_clothingObject.iconSlot>>
						<<else>>
							<<set $_cIcon to $_clothingObject.icon>>
							<<icon $_cIcon>>
						<</if>>
						/* Passage names are "Gwylan Talk Clothes " + the set name from setup in title case with underscores removed */
						<<set _incomingPassageText to toTitleCase(_value.replace(/_/g," "))>>
						<<capture _value, _incomingPassageText, _timeToPass>>
							<<if Number(localStorage.getItem("gwylanTalk")) gte 1>>
								<<link [[`Show <<him>> the $_clothingObject.text`|Gwylan Talk Clothes Savescum]]>><<set $clothesBeingTalkedAbout to _value>><</link>>
								<br>
							<<elseif !$_setsAtForestShop.includes(_value) or !setup.specialClothesSets[_value]>>
								<<link [[`Show <<him>> the $_clothingObject.text`|Gwylan Talk Clothes Error]]>><<set $clothesBeingTalkedAbout to _value>><</link>>
								<br>
							<<elseif $_setsCheated?.includes(_value)>>
								<<link [[`Show <<him>> the $_clothingObject.text`|Gwylan Talk Clothes Cheated]]>><<set $clothesBeingTalkedAbout to _value>><</link>>
								<br>
							<<elseif $_setsBypassed?.includes(_value)>>
								<<link [[`Show <<him>> the $_clothingObject.text`|Gwylan Talk Clothes Bypassed]]>><<set $clothesBeingTalkedAbout to _value>><</link>>
								<br>
							<<else>>
								<<if $_subsetVals.length>>
									<<link [[`Ask <<him>> about the $_clothingObject.text (0:_timeToPass)`|`Gwylan Talk Clothes `+ _incomingPassageText]]>><<set $gwylanPassTime to _timeToPass>><</link>><<glove>>
								<<else>>
									<<link [[`Show <<him>> the $_clothingObject.text (0:_timeToPass)`|`Gwylan Talk Clothes `+ _incomingPassageText]]>><<set $gwylanPassTime to _timeToPass>><</link>><<glove>>
								<</if>>
								<br>
							<</if>>
						<</capture>>
					<</if>>
				<</for>>
			</div>
		<</if>>
		<<if $_clothesbr>><br><</if>>
	<</if>>
<</widget>>

<<widget "gwylanOptionsGift">>
	<<if $location is "forest_shop" and checkSextoysGift("Gwylan") and C.npc.Gwylan.penis is "none" and checkIfNPCHasCategorySextoy("Gwylan","strap-on").length <= 5>>
		<<set $_giftbr to true>>
		<<for _key range Object.keys(V.NPCName[7].sextoys).filter(t => V.NPCName[7].sextoys[t][0].gift_state === "held")>>
			<<set _toy to V.NPCName[7].sextoys[_key][0]>>
			<<set _icon to `sexToys/${_toy.name.replace(/ /g, "_")}.png`>>
			<span @class="`clothes-${_toy.colour}`"><<icon _icon>></span>
			<<capture _toy>>
				<<link [[Gift Gwylan the _toy.colour _toy.name|Gwylan Gift Strap-on]]>>
					<<endevent>>
					<<set $phase to _toy.name>>
					<<set _toy.gift_state to "received">>
					<<generateNewStrapon _toy.size _toy.colour _toy.shape>>
					<<giveNNPCnewstrapon "Gwylan">>
				<</link>>
			<</capture>>
			<br>
		<</for>>
		<br>
	<</if>>
	<<if canGiftFood("Gwylan") and $location isnot "cliff">>
		<<set $_giftbr to true>>
		<<skinicon "give">><<link [[Give Gwylan food|Gwylan Gifts List]]>><</link>>
		<br>
	<</if>>
	<<if $_giftbr>><br><</if>>
<</widget>>

<<widget "gwylanOptionsCafe">>
	<<set $_schoolWalkAvailable to ($gwylanSeen.includes("cafe_walk") or ($gwylan.sea + ($gwylanTalked.count("fox_mask") * 20) + ($gwylanTalked.count("dark_pendant") * 20) gte 40)) or ($gwylan.robin gte 10 and $daily.robin_in_cafe and false)>> /* WARNING! Re-enable later for Gwybin cafe */
	<<if $_schoolWalkAvailable and Time.schoolDay and ((Time.hour is 7 and Time.minute gte 45) or (Time.hour is 8 and Time.minute lte 35)) and !$daily.gwylan_skip_school>>
		<<set _passTime to "<<passTimeUntil 8 45>><<set $daily.gwylan.cafeSkip to true>>">><<set _passTimeDisplay to "0:" + ("0" + ((45 - Time.minute + 60) % 60)).slice(-2)>>
	<<elseif $_schoolWalkAvailable and Time.schoolDay and Time.hour is 8 and Time.minute gt 35 and !$daily.gwylan_skip_school>>
		<<set _passTime to "<<pass 10>><<set $daily.gwylan.cafeSkip to true>>">><<set _passTimeDisplay to "0:10">>
	<<elseif Time.hour lte 7 or (Time.hour is 8 and Time.minute lt 10)>>
		<<set _passTime to "<<pass 1 hour>>">><<set _passTimeDisplay to "1:00">>
	<<elseif Time.hour is 8 and Time.minute lte 20>>
		<<set _passTime to "<<passTimeUntil 9 20>><<set $daily.gwylan.cafeSkip to true>>">><<set _passTimeDisplay to "1:" + ("0" + (20 - Time.minute)).slice(-2)>> /* Because why stop socialising only minutes before you're going to leave anyway? */
	<<elseif Time.hour is 9 and Time.minute gte 10>>
		<<set _passTime to "<<pass 10>><<set $daily.gwylan.cafeSkip to true>>">><<set _passTimeDisplay to "0:10">> /* So that Gwylan stays a little while longer if the player just arrived. */
	<<else>>
		<<set _passTime to "<<passTimeUntil 9 20>><<set $daily.gwylan.cafeSkip to true>>">><<set _passTimeDisplay to "0:" + ("0" + ((20 - Time.minute + 60) % 60)).slice(-2)>>
	<</if>>
	<<beachicon>><<link [[Watch the sea with <<him>> (_passTimeDisplay)|Gwylan Ocean Breeze Watch]]>>_passTime<<stress -6>><<trauma -3>><<willpower 1>><</link>><<lstress>><<ltrauma>><<gwillpower>>
	<br>
	<<if $location is "cafe" and !(between($chef_state, 7, 8) and $chef_rework lte 30) and $daily.cafeEaten isnot 1>>
		<<if $money gte 200>>
			<<foodicon "coffee">><<link [[Buy coffee (_passTimeDisplay £2)|Gwylan Ocean Breeze Watch]]>>
				<<set $phase to "coffee">><<set $phase2 to 1>><<set $daily.cafeEaten to 1>><<money -200 "cafe">>
				<<stress -9>><<trauma -3>><<tiredness -4>><<willpower 1>>_passTime
			<</link>><<lstress>><<ltrauma>><<ltiredness>><<gwillpower>>
			<br>
		<</if>>
		<<if $money gte 700>>
			<<if Time.season is "winter">>
				<<foodicon "winterale">>
				<<if playerIsPregnant() and playerAwareTheyArePregnant()>>
					<span class="blue">You can't bring yourself to drink winter ale while you know you're with child.</span>
				<<else>>
					<<link [[Buy winter ale (_passTimeDisplay £7)|Gwylan Ocean Breeze Watch]]>>
