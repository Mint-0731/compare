				<<set $_actionPassed to true>>
				<<if hasSharpSenses("instincts") and random(0, 1)>>
					<<set $huntGame.otherTracked to "scent">>
					<span class="green">Then, you smell it; the faintest hint on the wind. You have <<him>>.</span>
				<<else>>
					<<set $huntGame.otherTracked to "trail">>
					<span class="green">You manage to find <<print either("some disturbed leaves", "a broken branch", "a few faint footprints")>>. You have <<his>> trail.</span>
				<</if>>
				<br><br>

				<span class="purple">The hunt intensifies...</span> <<note "+ Skulduggery Difficulty" "purple">>
				<<set $huntGame.skills.skulduggeryMin += 20>><<set $huntGame.skills.skulduggeryMax += 20>>
			<<else>>
				<span class="red">You fail to find anything.</span>
			<</if>>
		<<case "stealth">>
			You skulk through the underbrush, trying to leave as little of a trail as possible.
			<<skulduggerycheck "silent">>
			<<if $skulduggerysuccess is 1>>
				<<if $huntGame.hunterKnown and $huntGame.hunter is "other" and $huntGame.otherTracked and $huntGame.playerTracked and $huntGame.playerTrackedKnown>>
