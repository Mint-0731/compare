				<<if playerIsPregnant() and playerAwareTheyArePregnant()>>
					<span class="blue">You can't bring yourself to drink autumn ale while you know you're with child.</span>
				<<else>>
					<<link [[Buy autumn ale (_passTimeDisplay £7)|Gwylan Ocean Breeze Watch]]>>
						<<set $phase to "autumn ale">><<set $phase2 to 1>><<set $daily.cafeEaten to 1>><<money -700 "cafe">>
						<<stress -12>><<alcohol 80>><<willpower 1>>_passTime
					<</link>><<llstress>><<galcohol>><<gwillpower>>
				<</if>>
				<br>
			<</if>>
		<</if>>
		<<if $money gte 300>>
			/* ToDo: Gwylan - bringing a milkshake to Gwylan at the forest shop */
			<<if getRobinLocation() is "cafe">>
				<<if $gwylanSeen.includes("yearning")>>
					<<foodicon "milkshake">><<link [[Buy milkshake and share with Gwylan (_passTimeDisplay £3)|Gwylan Ocean Breeze Watch]]>>
						<<set $phase to "milkshake">><<set $phase2 to 2>><<set $daily.cafeEaten to 1>><<money -300 "cafe">>
						<<stress -12>><<willpower 1>>_passTime
					<</link>><<llstress>><<gwillpower>>
					<br>
				<</if>>
				<<if $robinromance is 1>>
					<<foodicon "milkshake">><<link [[Buy milkshake and share with Robin (_passTimeDisplay £3)|Gwylan Ocean Breeze Watch]]>>
						<<set $phase to "milkshake">><<set $phase2 to 3>><<set $daily.cafeEaten to 1>><<money -300 "cafe">>
						<<stress -12>><<willpower 1>>_passTime
					<</link>><<llstress>><<gwillpower>>
					<br>
				<</if>>
				<<if $gwylanSeen.includes("yearning") and $robinromance is 1>>
