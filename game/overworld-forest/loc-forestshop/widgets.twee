				<<else>>
					<<link [[Buy shandy (_passTimeDisplay £7)|Gwylan Ocean Breeze Watch]]>>
						<<set $phase to "shandy">><<set $phase2 to 1>><<set $daily.cafeEaten to 1>><<money -700 "cafe">>
						<<stress -12>><<alcohol 40>><<willpower 1>>_passTime
