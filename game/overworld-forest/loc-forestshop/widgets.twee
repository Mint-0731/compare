<<widget "gwylanHuntEffects">>
	<<if $huntGame.timer gte 20>>
		<<set _forceConfrontation to true>>
		<<set $huntGame.distance to 0>>
	<</if>>

	/* Player actions */
	<<switch $huntGame.playerAction>>
		<<case "hunt">>
			<<if $huntGame.hunterKnown and $huntGame.hunter is "other">>
				You try to circle back on <<= $huntGame.adversaryText>>, following <<his>> <<if $huntGame.otherTracked is "scent">>scent<<else>>trail<</if>>.
			<<else>>
				You follow <<= $huntGame.adversaryText>>'s <<if $huntGame.otherTracked is "scent">>scent<<else>>trail<</if>>.
			<</if>>
			<<if $huntGame.otherAction is "run">>
				<br>
				<<if $athleticsSuccess>>
					<<set $_actionPassed to true>>
					<<set $huntGame.distance -= 1>>
					<<if $huntGame.hunter is "player">>
						<<set $huntGame.distance -= 1>>
						<span class="green">You can tell you're gaining on <<him>>.</span>
					<<else>>
						<span class="purple">It won't be long until you force a confrontation at this rate.</span>
					<</if>>
				<<else>>
					<<if $huntGame.hunter is "player">>
						<<set $huntGame.distance -= 1>>
						<span class="purple">You're evenly paced with <<him>>.</span>
					<<else>>
						<span class="purple">It won't be long until you force a confrontation at this rate.</span>
					<</if>>
				<</if>>
			<<else>>
				<<set $huntGame.distance -= 2>>
			<</if>>
		<<case "track">>
			<<if hasSharpSenses("instincts")>>
				You sniff the air, trying to find <<= $huntGame.adversaryText>>'s scent.
			<<else>>
				You stay low, checking for any sign of <<= $huntGame.adversaryText>>'s passing.
			<</if>>
