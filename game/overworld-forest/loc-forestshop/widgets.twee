			<</if>>
			<<skulduggerycheck "silent">>
			<<if $skulduggerysuccess is 1>>
				<<if $huntGame.hunterKnown and $huntGame.hunter is "other" and $huntGame.otherTracked and $huntGame.playerTracked and $huntGame.playerTrackedKnown>>
					<br>
					You steady your breathing and focus. The forest blankets you in silence. <span class="gold">You're sure you've made <<him>> lose your trail.</span>
					<<set $huntGame.playerTracked to false>><<set $huntGame.playerTrackedKnown to false>>
