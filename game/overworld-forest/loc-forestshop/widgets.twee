						<<set $phase to "fruity ale">><<set $phase2 to 1>><<set $daily.cafeEaten to 1>><<money -700 "cafe">>
						<<stress -12>><<alcohol 60>><<willpower 1>>_passTime
					<</link>><<llstress>><<galcohol>><<gwillpower>>
				<</if>>
				<br>
			<<elseif Time.season is "summer">>
