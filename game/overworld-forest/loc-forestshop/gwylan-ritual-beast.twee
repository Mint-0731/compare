	Gwylan gently grabs the <<personsimple>> by the chin, <<nnpc_his "Gwylan">> eyes reflecting a green glow. "Behave yourself, seedling."
	<br><br>

	<span class="green">The <<personsimple>> loosens up, and seems to calm down.</span>
	<<if $beastRitual.tainted>>
		"I'm... I'm sorry. It hurts. Fill the... holes..."
	<<else>>
		"Oh... I'm sorry..."
	<</if>>
	<<set $enemyanger to 0>><<set $enemytrust += 50>>

	<<if $beastRitual.gwylan.leftarm isnot 0>>
		<<set _tentToFreeLeft to Object.values($tentacles).find(tentacle => tentacle.id === $beastRitual.gwylan.leftarm)>>
		<<if _tentToFreeLeft>>
			<<tentacleadvdisable _tentToFreeLeft>>
		<</if>>
	<</if>>
	<<if $beastRitual.gwylan.rightarm isnot 0>>
		<<set _tentToFreeRight to Object.values($tentacles).find(tentacle => tentacle.id === $beastRitual.gwylan.rightarm)>>
		<<if _tentToFreeRight>>
			<<tentacleadvdisable _tentToFreeRight>>
		<</if>>
	<</if>>
	<<set $beastRitual.gwylan.leftarm to 0>><<set $beastRitual.gwylan.rightarm to 0>><<set $beastRitual.gwylan.mouth to 0>>
	<<if $beastRitual.taintedArm is "right arm">>
		<<set $NPCList[0].righthand to "idle">><<set $NPCList[0].lefthand to 0>>
	<<else>>
		<<set $NPCList[0].righthand to 0>><<set $NPCList[0].leftthand to "idle">>
	<</if>>
	<br><br>
<</if>>

<<effects>>
<<effectsabomination>>

<<if $speechbanish gte 1 and $beastRitual.tainted and $beastRitual.gwylan.mouth isnot "choking">>
	<<set $speechbanish to 0>>
	<<if !$gwylanSeen.includes("ritual_banish")>>
		<<set $gwylanSeen.pushUnique("ritual_banish")>>
		Gwylan winces at the bright shimmer. <<nnpc_He "Gwylan">> seems to realise something.
		<<if $beastRitual.gwylan.mouth isnot 0>>
			<<nnpc_He "Gwylan">> momentarily removes the vine from <<nnpc_his "Gwylan">> mouth.
		<</if>>
		"Whatever you just did, <span class="green">it's working</span>. Do it again!" <<gwylanPurgeEffect>>
	<<elseif !$beastRitual.banish>>
		<<set $beastRitual.banish to true>>
		Gwylan winces at the bright shimmer.
		<<if $beastRitual.gwylan.mouth isnot 0>>
			<<nnpc_He "Gwylan">> momentarily removes the vine from <<nnpc_his "Gwylan">> mouth.
		<</if>>
		"You're burning the poison away! Keep going!" <<gwylanPurgeEffect>>
	<<elseif $beastRitual.gwylan.mouth is 0>>
		"Again! Banish another one!" <<gwylanPurgeEffect>>
	<</if>>
	<br>
<</if>>

<<if $angel gte 6 and Object.values($tentacles).some(tentacle => tentacle.head is "vaginaimminent" or tentacle.head is "penisimminent") and !$beastRitual.virginityProtected>>
	<<set _gwyTargetFeet to Object.values($tentacles).find(tentacle => tentacle.head is "vaginaimminent" or tentacle.head is "penisimminent")>>
	<<if _gwyTargetFeet>>
		<<set $beastRitual.virginityProtected to true>>
		With a sharp kick, Gwylan <span class="green">beats back the _gwyTargetFeet.fullDesc just before it ruins your purity forever</span>.
		<<if $transformationParts.angel.halo isnot "hidden">>
			<span class="blue">You think you see the reflection of your halo in <<nnpc_his "Gwylan">> eyes for a moment.</span>
		<</if>>
		<br>
		More vines creep around <<nnpc_him "Gwylan">>, ensnaring <<nnpc_his "Gwylan">> legs.
		<<tentacleadvdisable _gwyTargetFeet>>
		<<set _gwyTargetFeet.tentaclehealth -= 5>><<tentacle_record "damage" 5>>
		<<set $enemyanger += 15>>
		<br>
	<</if>>
<</if>>

<<abomination>>
<<if $beastRitual.tainted>>
	<<His>> $beastRitual.taintedArm hangs limply at <<his>> side.
	<<if $beastRitual.taintedArm is "right arm">>
		<<set $NPCList[0].righthand to "idle">>
	<<else>>
		<<set $NPCList[0].leftthand to "idle">>
	<</if>>
	<br>
<</if>>
<br>

<<set _gwyNameText ||= "Gwylan">><<set _gwySpeech to []>>
<<for _gwyPart, _gwyVal range $beastRitual.gwylan>>
	<<set _gwyPartText to _gwyPart is "leftarm" ? "left arm" : _gwyPart is "rightarm" ? "right arm" : _gwyPart>>
	<<if ["leftarm", "rightarm"].includes(_gwyPart)>>
		<<if _gwyVal is 0 and ($head is "grappled" or $leftleg is "grappled" or $rightleg is "grappled" or $leftarm is "tentgrappled" or $rightarm is "tentgrappled")>>
			<<if $head is "grappled">>
				<<set _gwyTarget to "neck">><<set _gwyTargetBody to "neck">>
			<<elseif $leftleg is "grappled">>
				<<set _gwyTarget to "leftleg">><<set _gwyTargetBody to "left leg">>
			<<elseif $rightleg is "grappled">>
				<<set _gwyTarget to "rightleg">><<set _gwyTargetBody to "right leg">>
			<<elseif $leftarm is "tentgrappled">>
				<<set _gwyTarget to "leftarm">><<set _gwyTargetBody to "left arm">>
			<<elseif $rightarm is "tentgrappled">>
				<<set _gwyTarget to "rightarm">><<set _gwyTargetBody to "right arm">>
			<</if>>
			<<if _gwyTarget>>
				<<set _gwyTargetTentacle to Object.values($tentacles).find(tentacle => tentacle.shaft === _gwyTarget && tentacle.shaft !== "finished")>>
				<<if _gwyTargetTentacle>>
					<<= _gwyNameText>> grabs the _gwyTargetTentacle.fullDesc with <<nnpc_his "Gwylan">> <<= _gwyPartText>>, <span class="green">prying it off of your <<= _gwyTargetBody>> and freeing you</span>.
					<<tentacleadvdisable _gwyTargetTentacle>><<set _gwyNameText to "<<nnpc_He 'Gwylan'>>">>
					<<set $beastRitual.gwylan[_gwyPart] to _gwyTargetTentacle.id>><<set _gwyTargetTentacle.head to _gwyPart + "gwylan">><<set _gwyTargetTentacle.shaft to _gwyPart + "gwylan">>
					<<set _gwySpeechGrab to _gwySpeechGrab is "grab_one" ? "grab_two" : "grab_one">>
				<</if>>
			<</if>>
		<<elseif _gwyVal is 0>>
			<<set _gwyPossibleTargets to Object.values($tentacles).filter(tentacle => tentacle.desc && tentacle.head isnot "finished" && !["mouthgwylan", "leftarmgwylan", "rightarmgwylan"].includes(tentacle.shaft))>>
			<<if _gwyPossibleTargets.length>>
				<<set _gwyTargetTentacle to _gwyPossibleTargets.random()>>
				<<= _gwyNameText>> grabs the _gwyTargetTentacle.fullDesc with <<nnpc_his "Gwylan">> <<= _gwyPartText>>, and starts to work the shaft.
				<<tentacleadvdisable _gwyTargetTentacle>><<set _gwyNameText to "<<nnpc_He 'Gwylan'>>">>
				<<set $beastRitual.gwylan[_gwyPart] to _gwyTargetTentacle.id>><<set _gwyTargetTentacle.head to _gwyPart + "gwylan">><<set _gwyTargetTentacle.shaft to _gwyPart + "gwylan">>
				<<set _gwyTargetTentacle.tentaclehealth -= 1>><<tentacle_record "arousal" 1>>
			<</if>>
		<<else>>
			<<set _gwyTargetTentacle to Object.values($tentacles).find(tentacle => tentacle.id === _gwyVal && tentacle.shaft !== "finished")>>
			<<if _gwyTargetTentacle>>
				<<if $beastRitual.gwylan.mouth is 0 and $rng gte 66>>
					<<= _gwyNameText>> <span class="pink">guides the _gwyTargetTentacle.fullDesc into <<nnpc_his "Gwylan">> mouth</span> with <<nnpc_his "Gwylan">> <<= _gwyPartText>>. The shaft curls around <<nnpc_his "Gwylan">> chest.
					<<set _gwyTargetTentacle.tentaclehealth -= 1>><<tentacle_record "fluid" 1>><<set _mouthDisableTemp to true>>
					<<tentacleadvdisable _gwyTargetTentacle>>
					<<set _gwyTargetTentacle.head to "mouthgwylan">><<set _gwyTargetTentacle.shaft to "mouthgwylan">>
					<<set $beastRitual.gwylan[_gwyPart] to 0>><<set $beastRitual.gwylan.mouth to _gwyTargetTentacle.id>>
				<<else>>
					<<if _gwyPart is "left arm">>
						<<= _gwyNameText>> rubs and kneads the _gwyTargetTentacle.fullDesc with <<nnpc_his "Gwylan">> <<= _gwyPartText>>. Nectar flows out in bursts.
					<<else>>
						<<= _gwyNameText>> milks the _gwyTargetTentacle.fullDesc with <<nnpc_his "Gwylan">> <<= _gwyPartText>>. Nectar steadily leaks out.
					<</if>>
					<<set _gwyTargetTentacle.tentaclehealth -= 2>><<tentacle_record "fluid" 2>>
				<</if>>
				<<set _gwyNameText to "<<nnpc_He 'Gwylan'>>">>
			<<else>>
				<<set $beastRitual.gwylan[_gwyPart] to 0>>
			<</if>>
		<</if>>
	<<elseif ["mouth"].includes(_gwyPart)>>
		<<set _gwyTargetTentacle to Object.values($tentacles).find(tentacle => tentacle.id === $beastRitual.gwylan[_gwyPart] && tentacle.shaft !== "finished" || tentacle.shaft === "gwylanchoke")>>
		<<if _mouthDisableTemp>>
		<<elseif _gwyVal is "choking">>
			<<if _gwyTargetTentacle?.shaft is "gwylanchoke">>
				<span class="red">The _gwyTargetTentacle.fullDesc chokes Gwylan,</span> but <<nnpc_he "Gwylan">> continues working regardless.
				<<set _gwyTargetTentacle.tentaclehealth -= 2>><<tentacle_record "fluid" 2>>
			<<else>>
				<span class="green">Gwylan gasps as you free <<nnpc_him "Gwylan">> from the vine choking <<nnpc_him "Gwylan">>.</span> "Thanks, dear!"
				<<set $beastRitual.gwylan[_gwyPart] to 0>>
			<</if>>
		<<elseif _gwyTargetTentacle>>
			<<if $enemyanger gte 100 and !$beastRitual.choked and ($beastRitual.person is "Gwylan" or $rng gte 51)>>
				The _gwyTargetTentacle.fullDesc slowly worms deeper and deeper into Gwylan's throat, before the shaft <span class="red">suddenly curls around <<nnpc_his "Gwylan">> neck while the head thrusts faster.</span>
				<<nnpc_His "Gwylan">> eyes widen, but <<nnpc_he "Gwylan">> continues regardless.
				<<set $beastRitual.choked to true>>
				<<set $beastRitual.gwylan[_gwyPart] to "choking">><<set _gwyTargetTentacle.shaft to "gwylanchoke">>
			<<else>>
				Nectar leaks out of the corners of <<nnpc_his "Gwylan">> mouth as the _gwyTargetTentacle.fullDesc thrusts in and out.
				<<set _gwyTargetTentacle.tentaclehealth -= 2>><<tentacle_record "fluid" 2>>
			<</if>>
		<<else>>
			<<if _gwySpeechGrab>>
				<<if _gwySpeechGrab is "grab_two">>
					<<set _gwySpeech.push("I'll keep these two away from you.", "Come here, you've got two people to play with.")>>
				<<else>>
					<<set _gwySpeech.push("I'll keep this grabby one away from you.", "I need you to be able to move. I'll keep this one off of you.", "Come here, you've got two people to play with.")>>
				<</if>>
			<</if>>
			<<if $beastRitual.gwylan.mouth is 0 and _gwySpeech.length>>
				<<= _gwyNameText>> speaks. "<<print _gwySpeech.random()>>"
				<<set _gwyNameText to "<<nnpc_He 'Gwylan'>>">>
			<<else>>
				<<if $enemyanger gte 30>>
					<<set $enemyanger -= 10>>
					<<= _gwyNameText>> hums a soothing tune to the <<person>>. <span class="green"><<He>> calms downs lightly.</span>
				<<else>>
					<<= _gwyNameText>> hums a soothing tune to the vines. <span class="green">They become more sluggish.</span>
					<<for _i to 0; _i lt $tentacles.max; _i++>>
						<<set _tentacleSoothe to $tentacles[_i]>>
						<<if _tentacleSoothe isnot undefined>>
							<<set _tentacle.tentaclehealth -= 0.2>><<tentacle_record "soothe" 0.2>>
						<</if>>
					<</for>>
				<</if>>
			<</if>>
			<<set $beastRitual.gwylan[_gwyPart] to 0>>
		<</if>>
	<</if>>
	<<if _gwyTargetTentacle and _gwyTargetTentacle.tentaclehealth lte 0 and _gwyTargetTentacle.shaft isnot "finished">>
		<<if _gwyTargetTentacle.shaft is "gwylanchoke">>
			<span class="green">Worn out, it retracts from Gwylan's throat and away from the two of you.</span> <<nnpc_He "Gwylan">> gasps for breath and coughs.
		<<else>>
			<span class="green">Worn out, it retracts from the two of you.</span>
		<</if>>
		<<tentacleadvdisable _gwyTargetTentacle>>
		<<set _gwyTargetTentacle.shaft to "finished">><<set _gwyTargetTentacle.head to "finished">><<set $beastRitual.gwylan[_gwyPart] to 0>>
	<</if>>
<</for>>
<<if _freshFallen>>
	<<set $beastRitual.fallen to true>>
	<span class="blue"><<= _gwyNameText>> winces as <<nnpc_he "Gwylan">> watches the light fade from your eyes.</span>
	<br>
<</if>>
<<if $beastRitual.person is "Gwylan">>
	<<if $beastRitual.stateTimer is 5>>
		The vines seem primarily interested in Gwylan.
	<<elseif $beastRitual.stateTimer is 4>>
		Several more vines surround Gwylan.
	<<elseif $beastRitual.stateTimer is 3>>
		Vines worm their way up Gwylan's legs and body.
	<<elseif $beastRitual.stateTimer is 2>>
		One brave vine worms its way between Gwylan's thighs. <<nnpc_He 'Gwylan'>> clenches them together tightly in response, subduing it.
	<<elseif $beastRitual.stateTimer is 1>>
		A vine finally manages to get through,
		<<if C.npc.Gwylan.penis isnot "none">>
			wrapping around <<nnpc_his "Gwylan">> penis.
		<<else>>
			rubbing against <<nnpc_his "Gwylan">> vagina.
		<</if>>
		<<nnpc_He "Gwylan">> doesn't seem too bothered by it, though. In fact, <<nnpc_he "Gwylan">> might even be enjoying it.
	<<elseif $beastRitual.stateTimer is 0>>
		You and Gwylan are pulled closer together by the vines ensnaring you.
		<<if !$beastRitual.fallen and $beastRitual.gwylan.mouth isnot "choking">>
			<<nnpc_He "Gwylan">> smiles cheerfully at you before returning to work.
		<</if>>
	<</if>>
<<elseif $beastRitual.stateTimer is 5>>
	The vines seem primarily interested in you.
<<elseif $beastRitual.stateTimer is 0>>
	You and Gwylan are pulled closer together by the vines ensnaring you.
	<<if !$beastRitual.fallen and $beastRitual.gwylan.mouth isnot "choking">>
		<<nnpc_He "Gwylan">> smiles cheerfully at you before returning to work.
	<</if>>
<</if>>
<<set $beastRitual.stateTimer++>>
<br><br>

<<stateabomination>>
<<actionsabomination>>

<<if _combatend>>
	<span id="next"><<link [[Next|Gwylan Ritual Bait Sex Plant Finish]]>><</link>></span><<nexttext>>
<<elseif ($pain gte 100 and $willpowerpain is 0 or $beastRitual.fallen) and $beastRitual.gwylan.mouth isnot "choking">>
	<span id="next"><<link [[Next|Gwylan Ritual Bait Sex Plant Finish]]>><</link>></span><<nexttext>>
<<else>>
	<span id="next"><<link [[Next|Gwylan Ritual Bait Sex Plant]]>><</link>></span><<nexttext>>
<</if>>

:: Gwylan Ritual Bait Sex Plant Finish
<<effects>><<run statusCheck("Gwylan")>>
<<unset $genitalReactionDisable>>
<<set $beastRitual.purgeInfo to $combat_tentacle_record>>
<<set $beastRitual.orgasms to $orgasmcurrent>>
<<if $enemyarousal gte $enemyarousalmax>>
	<<set $beastRitual.end to "orgasm">>
	<<ejaculation "short">><<set $beastRitual.purge++>><<set $beastRitual.ejac to true>>
	<<if $NPCList[0].vagina.toString().includes("mouth") or ["mouth", "vagina", "anus"].includes($NPCList[0].penis.toString())>>
		<<set $beastRitual.purgeDirect++>>
		<<if $temple_confessor_intro or $gwylanSeen.includes("ritual_beast")>>
			<span class="lewd">You take the poison into your body directly.</span>
			<<if $angel gte 6>>
				<span class="gold">The purity within you clashes with it, snuffing it out.</span><<trauma 6>><<pain 1>><<gtrauma>><<gpain>>
			<<elseif $fallenangel gte 2 and $fallenangel lt 4>>
				<span class="black">It rushes to fill the emptiness inside of you, and vanishes within. You feel nothing.</span>
			<<elseif $demon gte 6>>
				<span class="purple">It melds with your very being.</span><<stress -12>><<trauma -6>><<purity -40>><<llstress>><<ltrauma>><<lllpurity>>
			<<elseif $dryad gte 6>>
				<span cass="red">You feel violently ill as it twists your connection to the world. Your blossom turns sickly for a moment.</span><<stress 12>><<trauma 24>><<pain 10>><<ggstress>><<ggtrauma>><<ggpain>>
			<<else>>
				<<purity -25>><<llpurity>>
			<</if>>
			<br>
		<<else>>
			<span class="pink">A strange emptiness fills you.</span>
		<</if>>
	<<else>>
		The ivory bowl fills with a glowing pink fluid.
	<</if>>

	Focus returns to the <<persons>> eyes as <<his>> vines retract from you and Gwylan. <<gwylanPurgeEffect>>
	<br><br>

	<<if $beastRitual.tainted>>
		<<set $beastRitual.purge++>>
		<<He>> looks around in a panic, clutching <<his>> limp arm with the other. "Where am I? Who..." <<He>> freezes upon seeing Gwylan, who returns a gentle smile.
		<br><br>

		<<He>> backs away slowly, but stops as you all hear a sizzling. A pure black fluid leaks from the cracks in <<his>> skin.
		The fluid drips to the ground, where it shimmers briefly before roses begin to bloom in their place. The same roses sprout from the cracks in <<his>> skin, sealing them.
		Thick vines grow down <<his>> shoulder, protecting <<his>> brittle arm.
		<br><br>

		<<He>> looks between the two of you. "Th... thank you." <<His>> vines flare, wrapping the three of you into a tight hug, which Gwylan tenderly returns.
	<<else>>
		<<He>> looks around in confusion. "Oh, wow, that felt great! Wait, why do I feel so naked? Did you prune me? Who..." <<He>> freezes upon seeing Gwylan, who returns a gentle smile.
		<br><br>

		"Oh, hell no." <<He>> moves to run, but stops as you all hear a sizzling. A pure black fluid leaks from the cracks in <<his>> skin.
		The fluid drips to the ground, where it shimmers briefly before roses begin to bloom in their place. The same roses sprout from the cracks in <<his>> skin, sealing them.
		<br><br>

		<<He>> looks between the two of you. "I, uh... thanks."
	<</if>>
	<br><br>

	<<His>> vines quickly propel <<him>> to the edge of the garden, where they climb the wall. <<Hes>> hauled over the top, and vanishes into the forest.
	<<tearful>> Gwylan brushes you down and looks you over. "You did great."
	<<clotheson>>
	<<endcombat>>

	<<link [[Next|Gwylan Ritual Bait End Plant]]>><</link>>
	<br>
<<elseif $enemyhealth lte 0>>
	<<if $beastRitual.purgeInfo.banish gte 60 and $beastRitual.tainted>>
		<<set $beastRitual.end to "banish">>
		<<set $beastRitual.purge++>>
		<span class="gold"><<His>> vines all writhe and shimmer with your banishing light.</span> They flail in the air, but begin to return to a natural hue even as the <<person>> yells in pain.
		<br><br>

		Suddenly, <span class="purple">they all begin to expel a pure black fluid</span>. It drips to the ground, where it evaporates. <<His>> screams slowly turn into a relieved sigh.
		<br><br>

		<<He>> pants heavily, looking between you and Gwylan with eyes finally focused. "Where am I? Who..." <<He>> freezes upon seeing Gwylan, who returns a gentle smile.
		<br><br>

		<<He>> backs away slowly, but stops. The same black fluid leaks from the cracks in <<his>> skin. Roses sprout from them, sealing them.
		Thick vines grow down <<his>> shoulder, protecting <<his>> brittle arm.
		<br><br>

		<<He>> looks between the two of you. "Th... thank you, angels." Gwylan winces. The <<persons>> vines flare, wrapping the three of you into a tight hug, which Gwylan tenderly returns.
		<br><br>

		<<His>> vines quickly propel <<him>> to the edge of the garden, where they climb the wall. <<Hes>> hauled over the top, and vanishes into the forest.
		<<tearful>> Gwylan brushes you down and looks you over. "That isn't my usual method, but it worked. I'm blessed to have your help." <<He>> walks you over to the bath.
		<<clotheson>>
		<<endcombat>>

		<<link [[Next|Gwylan Ritual Bait End]]>><</link>>
		<br>
	<<else>>
		<<set $beastRitual.end to "beaten">>
		The <<person>> backpedals from you, looking between you and Gwylan warily as focus returns to <<his>> eyes. Gwylan sighs sadly and turns to you. "Oh dear, you weren't gentle enough."
		<br><br>

		<<if $beastRitual.tainted>>
			The <<person>> hisses. "Have I not suffered enough without you humans trying to take more from me? I won't be taken and farmed like my siblings!"
		<<else>>
			The <<person>> frowns. "You could have just asked if you wanted to have some fun. You didn't have to... do all this mind-game stuff, and then hurt me."
		<</if>>
		<br><br>

		<<His>> vines quickly propel <<him>> to the edge of the garden, where they climb the wall. <<Hes>> hauled over the top, and vanishes into the forest.
		<<tearful>> Gwylan brushes you down and looks you over. "That could have gone better. We'll have to hope we purged enough for <<him>> to recover on <<his>> own." <<He>> walks you over to the bath.
		<<clotheson>>
		<<endcombat>>

		<<link [[Next|Gwylan Ritual Bait End]]>><</link>>
		<br>
	<</if>>

<<else>>
	/* Not sure about having this case, might make the encounter too forgiving */
	<<set $beastRitual.end to "failed">>
	"Enough!" Gwylan yells. A green ribbon of light leaves <<nnpc_his "Gwylan">> eyes as the vines release <<nnpc_him "Gwylan">>.
	<<nnpc_He "Gwylan">> kneels down and peels the vines away from you one by one, before wiping the tears from your eyes.
	<br><br>

	Focus fully returns to the <<persons>> eyes. Gwylan gets up, standing between you and <<him>> protectively.
	<br><br>

	<<if $beastRitual.tainted>>
		<<He>> sneers down at your pitiful state. "Have I not suffered enough without you humans trying to take more from me? I won't be taken and farmed like my siblings! This is the least you deserve."
	<<else>>
		The <<person>> frowns. "You could have just asked if you wanted to have some fun. You didn't have to... do all this mind-game stuff. Then I wouldn't have had to hurt you."
	<</if>>
	<br><br>

	<<His>> vines quickly propel <<him>> to the edge of the garden, where they climb the wall. <<Hes>> hauled over the top, and vanishes into the forest.
	<<tearful>> Gwylan tries to help you up, mindful of all the thorns stuck in you.
	<<clotheson>>
	<<endcombat>>

	<<link [[Next|Gwylan Ritual Bait End]]>><</link>>
	<br>
<</if>>


:: Gwylan Ritual Bait End Plant
