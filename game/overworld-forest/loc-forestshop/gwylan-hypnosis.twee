<<gwylanOptions>>

:: Gwylan Hypnosis Widgets [widget]

<<widget "gwylanHypnosis">>
	<<set $_trait to _args[0]>>
	<<set $_duration to _args[1]>>
	<<set $_level to _args[2] || 5>>
	/* Catch invalid arguments and escape */
	<<if !["devotion", "peace", "silence", "slumber", "insight"].includes($_trait)>>
		<<exit '<span class="red">ERROR: Invalid hypnosis type: <<= $_trait>> inflicted. Please report.</span>'>>
	<</if>>
	<<if typeof $_duration isnot "number">>
		<<exit '<span class="red">ERROR: Invalid hypnosis duration: <<= $_duration>> inflicted. Please report.</span>'>>
	<</if>>

	/* Set up colours and text */
	<<switch $_trait>>
		<<case "devotion">>
			<<switch $hypnosis_traits.devotion>>
				<<case 1 0 undefined>><<set $_hypnotic to "Hypnotic">><<set $_color to "lblue">>
				<<case 2>><<set $_hypnotic to "Bewitched">><<set $_color to "blue">>
				<<case 3>><<set $_hypnotic to "Beguiled">><<set $_color to "purple">>
				<<case 4>><<set $_hypnotic to "Mesmeric">><<set $_color to "pink">>
				<<case 5>><<set $_hypnotic to "Sublime">><<set $_color to "red">>
				<<case 6>><<set $_hypnotic to "Frenzied">><<set $_color to "basicHypnoCss()">>
			<</switch>>
			<<set $_traitText to $worn.neck.name is "familiar collar" and $worn.neck.cursed is 1 ? "Devotion" : "Curiosity">>
		<<case "peace">><<set $_hypnotic to "Hypnotic">><<set $_color to "forest-green">><<set $_traitText to "Peace">>
		<<case "silence">><<set $_hypnotic to "Hypnotic">><<set $_color to "purple">><<set $_traitText to "Silence">>
		<<case "slumber">><<set $_hypnotic to "Hypnotic">><<set $_color to "blue">><<set $_traitText to "Slumber">>
		<<case "insight">><<set $_hypnotic to "Hypnotic">><<set $_color to "grey">><<set $_traitText to $awareness gte 300 ? "Ignorance" : "Insight">>
	<</switch>>

	<<if !$hypnosis_traits[$_trait] and $_duration lte 0>>
		/* Error, escape */
		<<exit '<span class="red">ERROR: Invalid negative hypnosis duration: <<= $_duration>> inflicted on non-existent trait: <<= $_trait>>. Please report.</span>'>>

	<<elseif !$hypnosis_traits[$_trait] and $_duration gt 0>>
		/* Initial trait gain */
		<<set $hypnosis_traits[$_trait] to 1>>
		<<set $hypnosisTimers[$_trait] to {}>>
		<<set $hypnosisTimers[$_trait].time to $_duration>>
		<<if $_trait is "devotion">>
			/* Initial Curiosity/Devotion gain */
			<<set $hypnosisTimers[$_trait].max to gwylanHypnoMax("value")>>
			<<set $hypnosisTimers[$_trait].time to Math.clamp($hypnosisTimers[$_trait].time, 0, gwylanHypnoMax("value"))>>
			<<set $gwylanSeen.pushUnique("hypnosis_first")>>
			<span @class="$_color">A question with no answer fills your mind, and visions of the forest linger. Gwylan looks a little softer around the edges.</span><br>
			You've gained the <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> trait. <<arousal 200>><<awareness 2>><<garousal>><<gawareness>>
		<<else>>
			/* Other trait gain */
			<<set $hypnosisTimers[$_trait].max to $_duration>>
			You've gained the <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> trait.
		<</if>>
		<<hypnotised 1>>

	<<elseif $hypnosis_traits[$_trait] and $_duration lte 0>>
		/* Duration/trait down */

		<<if $_trait is "devotion">>
			<<set $hypnosisTimers.devotion.time to Math.clamp($hypnosisTimers.devotion.time + $_duration, 0, gwylanHypnoMax("value"))>>
			<<if $hypnosisTimers.devotion.time lte gwylanHypnoMax("value", $hypnosis_traits.devotion - 1)>>
				<<switch $hypnosis_traits.devotion>>
					<<case 1>>/* Trait cleared */
						<<run delete $hypnosis_traits.devotion>><<run delete $hypnosisTimers.devotion>>
						<span class="erase-from-history">You feel as </span><span class="erase-from-history">though you once </span><span class="erase-from-history">had a burning </span><span class="erase-from-history">question in your </span><span class="erase-from-history">mind, but you </span><span class="erase-from-history">can't remember it.</span><br>
						Your <span class="lblue">Hypnotic <<= $_traitText>></span> has <<print either("evaporated", "ebbed away", "receded")>>. <<awareness -2>><<lawareness>><br>
					<<case 2>>/* Decay to level 1 */
						<<set $hypnosis_traits.devotion-->>
						<span class="lblue">The riddle stuck in your head becomes hollow, as if it never had an answer. The extra space someone once took up in your memory feels empty.</span><br>
						Your <span class="blue">Bewitched <<= $_traitText>></span> has shallowed to <span class="lblue">Hypnotic <<= $_traitText>></span>. <<awareness -4>><<lawareness>><br>
					<<case 3>>/* Decay to level 2 */
						<<set $hypnosis_traits.devotion-->>
						<span class="blue">The mystery at the back of your mind begins to close and simplify. The visions of Gwylan's smiling face become blurry and indistinct.</span><br>
						Your <span class="purple">Beguiled <<= $_traitText>></span> has shallowed to <span class="blue">Bewitched <<= $_traitText>></span>. <<awareness -6>><<lawareness>><br>
					<<case 4>>/* Decay to level 3 */
						<<set $hypnosis_traits.devotion-->>
						<span class="purple">The paradox looping in your mind breaks free, reaching a conclusion. The lurid visions of Gwylan fade to grey.</span><br>
						Your <span class="pink">Mesmeric <<= $_traitText>></span> has shallowed to <span class="purple">Beguiled <<= $_traitText>></span>. <<awareness -8>><<llawareness>><br>
					<<case 5>>/* Decay to level 4 */
						<<set $hypnosis_traits.devotion-->>
						<span class="pink">The answer you once held vanishes, and with it, the repeating tide of new questions halts. You've forgotten something.</span><br>
						Your <span class="red">Sublime <<= $_traitText>></span> has shallowed to <span class="pink">Mesmeric <<= $_traitText>></span>. <<awareness -12>><<llawareness>><br>
					<<case 6>>/* Decay to level 5 */
						<<set $hypnosis_traits.devotion-->>
						<span class="red">The maddening spiral finally releases you from its whirlpool grip.</span><br>
						Your <span @class="basicHypnoCss()">Frenzied <<= $_traitText>></span> has shallowed to <span class="red">Sublime <<= $_traitText>></span>. <<awareness -15>><<lllawareness>><br>
				<</switch>>
			<<elseif $_duration lte -2>>
				<span class="witchbloom">Your <span @class="$_color"><<= $_traitText>></span> shallows.</span>
			<</if>>
			<<if $hypnosisTimers.devotion>>
				<<set $hypnosisTimers.devotion.max to gwylanHypnoMax("value")>>
			<</if>>
		<<else>>
			<<if $hypnosisTimers[$_trait].time + $_duration lte 0>>
				<<run delete $hypnosis_traits[$_trait]>><<run delete $hypnosisTimers[$_trait]>>
				<<switch $_trait>>
					<<case "peace">>
						<span class="purple">A familiar uncertainty fills your being. Your Hypnotic Peace has faded.</span><br>
					<<case "silence">>
						<<if numberOfEarSlime()>>
							<span class='purple'>Familiar whispers fill your ears. Your Hypnotic Silence has faded.</span><br>
						<<else>>
							<span class='purple'>Your Hypnotic Silence has faded.</span><br>
						<</if>>
					<<default>>
						<span class="purple">Your Hypnotic <<= $_traitText>> has faded.</span><br>
				<</switch>>
			<</if>>
		<</if>>

	<<else>>
		/* Trait already exists */

		<<if $_trait is "devotion">>
			/* Hypnotic Curiosity/Devotion trait levels and logic */
			<<if $hypnosis_traits.devotion gt $_level>>
				/* Level of action is insufficient to increase curiosity/devotion */
				<span class="witchbloom">A familiar embrace enwreathes your heart, but your <span @class="$_color"><<= $_traitText>></span> goes no deeper.</span>
			<<else>>
				<<if $hypnosisTimers.devotion.time + $_duration gt gwylanHypnoMax("value") and $hypnosis_traits.devotion gte gwylanHypnoMax("trait")>>
					/* Max current trait level, can't increase further */
					<<if $daily.devotionWall>>
						<<if $hypnosis_traits.devotion gte 5>>
							<<set _devotionTrauma to true>>
							<span class="witchbloom">You slip deeper.</span> <<arousal 1000>><<trauma 12>><<ggarousal>><<ggtrauma>>
						<<else>>
							<span class="forest-green">Your mind rejects further <<= $_traitText>>, being pulled back to the shore of sense at the last moment.</span>
						<</if>>
					<<elseif $hypnosis_traits.devotion gte 5>>
						<<set _devotionTrauma to true>>
						<span class="witchbloom">Your mind delves ever deeper down a path of infinite questions.</span> <<arousal 500>><<stress -3>><<trauma 12>><<garousal>><<lstress>><<ggtrauma>>
					<<else>>
						<<set _devotionTrauma to true>>
						Your mind feels like it's on the edge of slipping into something deeper, <span class="forest-green">before being pulled back to the shore of sense at the last moment.</span>
						Your <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> can't yet sink further. <<arousal 500>><<stress -3>><<trauma 3>><<garousal>><<lstress>><<gtrauma>>
					<</if>>
					<<set $daily.devotionWall to true>>
				<<elseif $hypnosisTimers.devotion.time + $_duration gt gwylanHypnoMax("value")>>
					/* Trait level increases */
					<<set $_score to Math.clamp($hypnosisTimers.devotion.time + $_duration, 0, gwylanHypnoMax("value", gwylanHypnoMax()))>>
					<<switch gwylanHypnoMax("level", $_score)>>
						<<case 0 1>>
							/* Should be impossible */
						<<case 2>>
							<span class="blue">A riddle with no retort fills your mind, and visions of the forest shop linger. A strange feeling of attachment to Gwylan follows.</span><br>
							Your <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> has deepened. You are now <span class="blue">Bewitched</span>. <<arousal 500>><<awareness 4>><<garousal>><<gawareness>>
						<<case 3>>
							<span class="purple">A mystery with no closure fills your mind, and visions of Gwylan's smiling face linger. <<nnpc_He "Gwylan">> looks so safe and comforting.</span><br>
							Your <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> has deepened. You are now <span class="purple">Beguiled</span>. <<arousal 1000>><<awareness 6>><<ggarousal>><<gawareness>>
						<<case 4>>
							<span class="pink">A paradox with no resolution fills your mind, and visions of Gwylan's naked body linger. <<nnpc_He "Gwylan">> looks so warm and welcoming.</span><br>
							Your <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> has deepened, becoming <span class="pink">Mesmeric</span>. <<arousal 1000>><<awareness 8>><<ggarousal>><<ggawareness>>
						<<case 5>>
							<<if !$gwylanSeen.includes("hypnosis_sublime")>>
								<<set $gwylanSeen.pushUnique("hypnosis_sublime")>>
								<span class="red">An answer finally fills your mind. <<nnpc_Hes "Gwylan">> been in front of you all along. You expected to find the bottom, but you remain adrift in an ocean.
								<<nnpc_He "Gwylan">> only raises more questions, spiralling down into infinity. Visions of Gwylan snuff out any other thoughts you have. <<nnpc_He "Gwylan">> is everything.</span><br>
								Your <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> has blossomed, becoming <span class="red">Sublime</span>. <<arousal 1000>><<awareness 12>><<ggarousal>><<ggawareness>>
							<<else>>
								<span class="red">An answer finally fills your mind. <<nnpc_Hes "Gwylan">> been in front of you all along. <<nnpc_He "Gwylan">> is everything.</span><br>
								Your <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> has deepened beyond abyssal fathoms, becoming <span class="red">Sublime</span>. <<arousal 1000>><<awareness 12>><<ggarousal>><<ggawareness>>
							<</if>>
						<<case 6>>
							<span @class="basicHypnoCss()">You plunge below the bottom, into something that was never meant to be. You reach out and grip nothing. Nothing grips back, and nothing will ever be the same.</span><br>
							Your <span @class="$_color"><<= $_hypnotic>> <<= $_traitText>></span> has become <span class="basicHypnoCss()">Frenzied</span>. <<arousal 5000>><<awareness 20>><<gggarousal>><<gggawareness>>
						<<default>>
					<</switch>>
					<<set $hypnosis_traits.devotion to gwylanHypnoMax("level", $_score)>><<hypnotised 1>>
				<<else>>
					/* Trait level does not increase but value does */
					<span class="blue">Your <span @class="$_color"><<= $_traitText>></span> deepens.</span>
				<</if>>
				<<set $hypnosisTimers[$_trait].time to Math.clamp($hypnosisTimers[$_trait].time + $_duration, 0, gwylanHypnoMax("value"))>>
				<<set $hypnosisTimers[$_trait].max to gwylanHypnoMax("value")>>
			<</if>>

		<<else>>
			<<set $hypnosisTimers[$_trait].time to Math.clamp($hypnosisTimers[$_trait].time + $_duration, 0, 30)>>
			/* Refreshing/adding duration of existing unleveled traits */
			<<if $hypnosisTimers[$_trait].max lt $_duration>>
				/*If existing max is less than new base duration, equalise before overflow check */
				<<set $hypnosisTimers[$_trait].max to $_duration>>
			<</if>>
			<<if $hypnosisTimers[$_trait].time gte $hypnosisTimers[$_trait].max>>
				/* Allow some overflow, up to 1/2 of overflow value added on to time and max */
				<<set $_overflow to $hypnosisTimers[$_trait].time - $hypnosisTimers[$_trait].max>>
				<<set $_adjustment to Math.ceil($_overflow / 2)>>
				<<set $hypnosisTimers[$_trait].time to $hypnosisTimers[$_trait].max += $_adjustment>>
				<<set $_overflow to true>>
			<</if>>
			<<set $hypnosisTimers[$_trait].max to Math.max($hypnosisTimers[$_trait].max, $hypnosisTimers[$_trait].time)>>
			Your <span @class="$_color">Hypnotic <<= $_traitText>></span> has been nurtured.
			<<if $_overflow>>
				<span class="blue">Your trance felt deeper than last time.</span>
			<</if>>
			<<hypnotised 1>>
		<</if>>
	<</if>>
<</widget>>

<<widget "gwylanHypnoNote">>
	<<set $_note to "">>
	<<if _args[0] is "kiss" and !$gwylanSeen?.includes("kiss_hypno")>>
		/* Do nothing, no warning the first time hypnosis from kiss happens */
	<<elseif $gwylanSeen?.includes("hypnosis_first")>>
		<<set $_devotion to $worn.neck.name is "familiar collar" and $worn.neck.cursed is 1 ? "Devotion" : "Curiosity">>
		<<set $_level to _args[0] || 6>>
		/* Change level later if needed, levelled actions not currently used */
		<<if $_level is "kiss">><<set $_level to 6>><</if>>
		<<if $_level lte $hypnosis_traits.devotion>>
			<<set $_color to "black">>
			| <span @class='$_color'><<print $_devotion>></span>
		<<else>>
			<<switch $hypnosis_traits.devotion>>
				<<case 1>><<set $_color to "blue">>
				<<case 2>><<set $_color to "purple">>
				<<case 3>><<set $_color to "pink">>
				<<case 4>><<set $_color to "red">>
				<<case 5>><<set $_color to "witch">>
				<<default>><<set $_color to "lblue">>
			<</switch>>
			| <span @class='$_color'>+ <<print $_devotion>></span>
		<</if>>
	<</if>>
	<<if _args[0] is "kiss">>
		<<kissvirginitywarning>>
	<</if>>
<</widget>>

<<widget "gwylanWillpowerDifficulty">>
	<<set $_level to _args[0] || 1>>
	<<if !$hypnosis_traits.devotion or $hypnosis_traits.devotion lt $_level>>
		<<set $willpowerSuccess to 1>>
	<<elseif $hypnosis_traits.devotion gte 5>>
		/* resisting Gwylan is now impossible */
		<<if !$settings.blindStatsEnabled>>
			<<if $settings.skillCheckStyle is "skillname">>
				<<hypnosisText "<span class='white'>|</span> <span class='orange'>Willpower</span>">>
			<<else>>
				| <span class='orange'>Willpower</span>:
				<<switch random(1, 18)>>
					<<case 1>><<hypnosisText "Snuffed.">>
					<<case 2>><<hypnosisText "Clay between my fingers.">>
					<<case 3>><<hypnosisText "Shush, <<pcpetname 'Gwylan'>>.">>
					<<case 4>><<hypnosisText "This is what you wanted, <<pcpetname 'Gwylan'>>.">>
					<<case 5>><<hypnosisText "Given away willingly.">>
					<<case 6>><<hypnosisText "Mine to keep.">>
					<<default>><<hypnosisText "Impossible.">>
				<</switch>>
			<</if>>
		<</if>>
		<<set $willpowerSuccess to 0>>
	<<elseif $hypnosis_traits.devotion gte 1>>
		<<willpowerdifficulty `120 * $hypnosis_traits.devotion` `350 * $hypnosis_traits.devotion`>>
	<<else>>
		<<set $willpowerSuccess to 1>>
	<</if>>
<</widget>>

<<widget "gwylanKiss">>
	<<set $_devotionUp to typeof _args[0] is "number" ? _args[0] : 5>>
	<<if $_devotionUp isnot 0>>
		<<if $daily.gwylan.kiss>>
			<<hypnosisText "Nothing else in the world matters to you right now.">>
		<<else>>
			<<hypnosisText "You feel the world fade away for a moment, your doubts and troubles vanishing as everything shrinks down to just the two of you.">>
		<</if>>
		<<set $gwylanSeen.pushUnique("kiss_hypno")>><<set $daily.gwylan.kiss to true>>
		<<gwylanHypnosis "devotion" 5>>
		<<if !_devotionTrauma>>
			<<trauma -4>><<ltrauma>>
		<</if>>
	<</if>>
	<<set $_lustUp to 0 + $gwylanSeen.count("partners") + $gwylanSeen.count("romance")>>
	<<if $_lustUp>>
		<<npcincr Gwylan lust $_lustUp>><<glust>>
	<</if>>
	<<if $player.virginity.kiss is true>>
		<<if $_devotionUp or $_lustup>><br><</if>>
		<<takeKissVirginity "Gwylan" "romantic">>
	<</if>>
<</widget>>

<<widget "gwylanCommand">><<silently>>
	<<set $_gwylanCommand to _args[0]>>
	<<set $_hypnosis_level to _args[1] or 1>>
	<<if $hypnosis_traits.devotion gte $_hypnosis_level>>
		<<set $_gwylanCommand to '<span class="witch">' + $_gwylanCommand + '</span>'>>
	<</if>>
<</silently>><<print $_gwylanCommand>><</widget>>

<<widget "gwylanHypnoCanvas">>
	<<canvas-model-override "left_eye" "green">>
	<<canvas-model-override "right_eye" "green">>
	<<canvas-model-override "trauma" true>>
	<<canvas-model-override "eyes_half" true>>
	<<canvas-model-override "mouth" "cry">>
	<<if !$sexRitual?.bondage>>
		<<canvas-model-override "arm_left" "idle">>
		<<canvas-model-override "arm_right" "idle">>
	<</if>>
<</widget>>

<<widget "gwylanHypnoEffect">><<silently>>
	<<if $gwylanSeen.includes("hypnosis_intro")>>
		<<set $_plus to _args[0]>>
		<<switch $_plus>>
			<<case 3>><<set $_text_output to " | <span class='teal'>+ + + Hypnosis Potency</span>">>
			<<case 2>><<set $_text_output to " | <span class='teal'>+ + Hypnosis Potency</span>">>
			<<case 1>><<set $_text_output to " | <span class='teal'>+ Hypnosis Potency</span>">>
			<<case -1>><<set $_text_output to " | <span class='purple'>- Hypnosis Potency</span>">>
			<<case -2>><<set $_text_output to " | <span class='purple'>- - Hypnosis Potency</span>">>
			<<case -3>><<set $_text_output to " | <span class='purple'>- - - Hypnosis Potency</span>">>
			<<default>><<set $_text_output to " | <span class='teal'>+ Hypnosis Potency</span>">>
		<</switch>>
	<</if>>
<</silently>><<if $_text_output>><<print $_text_output>><</if>><</widget>>

<<widget "gwylanSong">>
	<<if !$gwylan.lureSong>><<exit>><</if>>
	<<run statusCheck("Gwylan")>>
	<<if _args[0] isnot "end">>
		<<switch $gwylan.lureSong>>
			<<case 1>>
				<<if $islander_language gte 100>>
					<span class="narration">
					<<if $rng gte 51 and ($wolfgirl gte 6 or $cat gte 6 or $cow gte 6 or $harpy gte 6 or $fox gte 6)>>
						<<if $wolfgirl gte 6>>
							Wild heart that beats <<if $gwylanSeen?.includes("partners")>>for<<else>>with<</if>> me<br>
							There lies a way to be<br>
							One with the waiting sea.
						<<elseif $cat gte 6>>
							Your curiosity<br>
							Will buoy us 'til we<br>
							May join the waiting sea.
						<<elseif $cow gte 6>>
							Your forced docility
							Won't halt our destiny;
							We'll join the waiting sea.
						<<elseif $harpy gte 6>>
							Bird of song, fly with me.<br>
							I'll bring you down to be<br>
							One with the waiting sea.
						<<else>>
							My dear kin, soon you'll see<br>
							<<if $auriga_scar>>
								Our black hearts stand ready<br>
							<<else>>
								Our hearts, a remedy<br>
							<</if>>
							To join the waiting sea.
						<</if>>
					<<else>>
						<<if $gwylanSeen?.includes("romance") and $rng lte 25>>
							Love, you could always see
						<<elseif $demon gte 6>>
							Passion guides you to see
						<<elseif $angel gte 6>>
							Virtue guides you to see
						<<elseif $fallenangel gte 4>>
							Forgiven hearts will see
						<<elseif $fallenangel gte 2 or $auriga_scar>>
							Your black heart yearns to see
						<<else>>
							It was in you to see
						<</if>><br>
						There lies a way to be<br>
						One with the waiting sea.
					<</if>>
					</span>
				<<else>>
					The words are in a language you don't recognise.
				<</if>>
			<<case 2>>
				<<if $islander_language gte 100>>
					<span class="narration">
					<<if _gwylanStatus.includes("badEndReady") or $gwylanSeen?.includes("romance") and $rng gte 51>>
						Feel my hands on your skin,<br>
						whispered name on the wind,<br>
						let our touch settle in.
					<<else>>
						Feel the salt on your skin,<br>
						whispered name on the wind,<br>
						let the light settle in.
					<</if>>
					</span>
				<<else>>
					<span class="blue">The song sounds like a lullaby.</span>
				<</if>>
			<<case 3>>
				<<if $islander_language gte 100>>
					<span class="narration">
					<<if _gwylanStatus.includes("badEndReady") or $gwylanSeen?.includes("romance") and $rng gte 51>>
						I'll soothe your tired bones,<br>
						A lover's word alone,<br>
						Like water shaping stone.
					<<else>>
						Embedded deep in bone,<br>
						Words maiden, mother, crone,<br>
						Like water carving stone.
					<</if>>
					</span>
				<<else>>
					<span class="purple">Your eyelids grow heavy.</span> <<tiredness 2>><<gtiredness>>
				<</if>>
			<<case 4>>
				<<if $islander_language gte 100>>
					<span class="narration">
					<<if _gwylanStatus.includes("badEndReady") or $gwylanSeen?.includes("romance") and $rng gte 51 or $auriga_scar>>
						Walk here with me, we'll find<br>
						all that's been lost in time,<br>
						this broken seal we'll bind.
					<<else>>
						Tread your path, sunwise to<br>
						Seek what's lost, please don't rue,<br>
						For still, it sings for you.
					<</if>>
					</span>
				<<else>>
					<span class="purple">Your eyelids grow heavy.</span> <<tiredness 2>><<gtiredness>>
				<</if>>
			<<case 5>>
				<<if $islander_language gte 100>>
					<span class="narration">
					<<if _gwylanStatus.includes("badEndReady") or $gwylanSeen?.includes("romance") and $rng gte 51 or $auriga_scar>>
						The river shifts its tide<br>
						for our names, cast aside,<br>
						lay unspoken, brookside.
					<<else>>
						Take root child, raise your shield.<br>
						Bear your name, unrevealed.<br>
						Rivers come. They will yield.
					<</if>>
					</span>
				<<else>>
					<span class="blue">The words of the song fade away, only the melody continuing. It sounds so familiar.</span>
				<</if>>
			<<default>>
				<span class="blue">The song's melody dances between the trees.</span>
		<</switch>>
		<<set $gwylan.lureSong++>>
	<<else>>
		<<if $islander_language gte 100>>
			<span class="narration">
			<<if _gwylanStatus.includes("badEndReady")>>
				Hush now, return to sleep.<br>
				Fall further, slumber deep.<br>
				<span class="red">At last, you're mine to keep.</span>
			<<else>>
				Awaken, rise from sleep.<br>
				The <<if $auriga_scar>>Dark Elk<<else>>darkness<</if>> shall not reap<br>
				That which the earth will keep.
			<</if>>
			</span>
		<<else>>
			<span class="blue">The singing stops.</span>
		<</if>>
	<</if>>
<</widget>>

