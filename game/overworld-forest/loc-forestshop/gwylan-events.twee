							<<else>>
								<span class="red">TODO: Robin</span>
							<</if>>
						<<case "fruity ale" "shandy" "autumn ale" "winter ale">>
							<<if !npcIsPregnant("Robin") and $robinmoney gte 7 and (_wouldBuy or _robin.trauma gte random(80, 105))>>
								<<set _isBuying to true>><<set _foodCost to 7>>
								<span class="red">TODO: Robin</span>
							<<elseif npcIsPregnant("Robin")>>
								<span class="red">TODO: Robin</span>
							<<else>>
								<span class="red">TODO: Robin</span>
							<</if>>
						<<case "fruit salad">>
							<<if $robinmoney gte 5 and _wouldBuy>>
								<<set _isBuying to true>><<set _foodCost to 5>>
								<span class="red">TODO: Robin</span>
							<<else>>
								<span class="red">TODO: Robin</span>
							<</if>>
						<<case "gingerbread">>
							<<if $robinmoney gte 6 and (_wouldBuy or (V.christmas and Time.monthDay is 25))>>
								<<set _isBuying to true>><<set _foodCost to 6>>
