									<<if $phase is "fruity ale">><<npcincr Robin dom 1>><</if>><<npcincr Robin love 1>>
									<<set $phase to "fruity ale">><<set $phase2 to 2>><<money -700 "cafe">>
								<</link>><<glove "Robin">><<if $phase is "fruity ale">><<gdom "Robin">><</if>>
