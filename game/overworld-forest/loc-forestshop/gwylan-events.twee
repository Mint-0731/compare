							<<set $phase2 to 7>><<set $robinmoney -= _foodCost>><<npcincr Robin dom 1>>
						<</link>><<gdom "Robin">><<if $phase is "deluxe cream bun">><<note "- - Robin's Money" "blue">><<else>><<note "- Robin's Money" "blue">><</if>>
						<br>
