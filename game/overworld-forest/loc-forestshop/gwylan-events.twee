									<<if $phase is "winter ale">><<npcincr Robin dom 1>><</if>><<npcincr Robin love 1>>
									<<set $phase to "winter ale">><<set $phase2 to 2>><<money -700 "cafe">>
								<</link>><<glove "Robin">><<if $phase is "winter ale">><<gdom "Robin">><</if>>
								<br>
							<<elseif Time.season is "spring">>
