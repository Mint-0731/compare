:: Widgets Nicknames [widget]
<<widget "underworld_nickname">><<silently>>
	<<if $fame.sex gte 400>>
		<<if $fame.prostitution gte 400>>
			<<if $fame.rape gte 400>>
				<<if $fame.bestiality gte 400>>
					<<if $fame.scrap gte 400>>
						<<if $fame.pimp gte 400>>
							<<if $player.gender_appearance is "m">>
								<<set _text_output to "우리 소년">>
							<<else>>
								<<set _text_output to "우리 소녀">>
							<</if>>
						<<else>>
							<<if $player.gender_appearance is "m">>
								<<set _text_output to "그 소년">>
							<<else>>
								<<set _text_output to "그 소녀">>
							<</if>>
						<</if>>
					<<else>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "장난감">>
						<<else>>
							<<set _text_output to "육변기">>
						<</if>>
					<</if>>
				<<else>>
					<<if $fame.scrap gte 400>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "파이크">>
						<<else>>
							<<set _text_output to "레이피어">>
						<</if>>
					<<else>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "울트라 걸레">>
						<<else>>
							<<set _text_output to "수퍼 걸레">>
						<</if>>
					<</if>>
				<</if>>
			<<else>>
				<<if $fame.bestiality gte 400>>
					<<if $fame.scrap gte 400>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "착유자">>
						<<else>>
							<<set _text_output to "우유 배달부">>
						<</if>>
					<<else>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "개 먹이">>
						<<else>>
							<<set _text_output to "개 간식">>
						<</if>>
					<</if>>
				<<else>>
					<<if $fame.scrap gte 400>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "방직공">>
						<<else>>
							<<set _text_output to "바늘">>
						<</if>>
					<<else>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "변태">>
						<<else>>
							<<set _text_output to "색녀">>
						<</if>>
					<</if>>
				<</if>>
			<</if>>
		<<else>>
			<<if $fame.rape gte 400>>
				<<if $fame.bestiality gte 400>>
					<<if $fame.scrap gte 400>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "늑대 전용 창녀">>
						<<else>>
							<<set _text_output to "늑대 전용 걸레">>
						<</if>>
					<<else>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "개 전용 창녀">>
						<<else>>
							<<set _text_output to "개 전용 걸레">>
						<</if>>
					<</if>>
				<<else>>
					<<if $fame.scrap gte 400>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "송곳">>
						<<else>>
							<<set _text_output to "난동자">>
						<</if>>
					<<else>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "공짜">>
						<<else>>
							<<set _text_output to "무료 걸레">>
						<</if>>
					<</if>>
				<</if>>
			<<else>>
				<<if $fame.bestiality gte 400>>
					<<if $fame.scrap gte 400>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "개 착정자">>
						<<else>>
							<<set _text_output to "늑대 전사">>
						<</if>>
					<<else>>
						<<if $fame.pimp gte 400>>
							<<set _text_output to "개 착유자">>
