	<<set $NPCName[_i].love = Math.clamp($NPCName[_i].love, -100, 100)>>
	<<set $NPCName[_i].dom = Math.clamp($NPCName[_i].dom, -50, 50)>>
	<<set _i to $NPCNameList.indexOf("Jordan")>>
	<<set $NPCName[_i].love = Math.clamp($NPCName[_i].love, -100, 100)>>
	<<set $NPCName[_i].dom = Math.clamp($NPCName[_i].dom, -50, 50)>>
