<<widget "npc_pillory">>
	한 남자가 도시 구속대에 갇혀있다.
	<<npc_pillory_release_schedule>>
	<br><br>
	<<endevent>>
<</widget>>

<<widget "npc_pillory_detail">>
	<<get_pillory_npc>>
	한 남자가 도시 구속대에 갇혀있다.
	<<npc_pillory_appearance>>
	<br><br>
	<<npc_pillory_abuse>>
	<<npc_pillory_release_schedule>>
	<br><br>
	<<endevent>>
<</widget>>

<<widget "npc_pillory_appearance">>
	<<update_npc_pillory_appearance>>
	/*Desc*/
	<<if Time.dayState is "night">>
		<<if $pillory.tenant.crowd gte 10>>
			술에 취한 엄청난 수의 군중들이,
		<<elseif $pillory.tenant.crowd gte 6>>
			많은 수의 떠들썩한 군중들이,
		<<elseif $pillory.tenant.crowd gte 4>>
			불길한 느낌의 군중들이,
		<<else>>
			적긴 하지만 불길한 느낌의 군중들이,
		<</if>>
	<<else>>
		<<if $pillory.tenant.crowd gte 10>>
			흥분해서 야유하고 있는 군중들이,
		<<elseif $pillory.tenant.crowd gte 6>>
			많은 수의 군중들이,
		<<elseif $pillory.tenant.crowd gte 4>>
			주변을 돌아다니던 호기심에 찬 무리들이,
		<<else>>
			작은 무리가,
		<</if>>
	<</if>>
	엎드린 상태로 구속대에 갇힌 남자를 둘러싸고 있다.
	<<if $pillory.tenant.broken gte 32>>
		그는 엄청난 충격을 받은 것 같고, 어쩌면  이미 겪은 학대로 영구히 망가졌을지도 모른다.
	<<elseif $pillory.tenant.broken gte 16>>
		그는 이미 겪은 학대로 인해 눈물을 흘리고 있다.
	<<elseif $pillory.tenant.broken gte 8>>
		그는 학대로 인해 흐느끼고 있다.
	<<elseif $pillory.tenant.broken gte 4>>
		그가 속이 상했다는 것은 눈에 보이지만, 어떻게든 숨기려고 하고 있다.
	<<else>>
		그는 반항적인 태도로, 태연한 척을 하고 있다.
	<</if>>
	<br>

	/*describe exposure*/
	<<if $pillory.tenant.upperexposed gte 3>>
		그의 가슴은 군중에게 완전히 노출되어 있다.
	<<if $pillory.tenant.spank gte 8>>
		그의 유두는 잔뜩 꼬집히고, 얻어맞고, 빨리고, 물리고 당겨진 탓에 붉게 부었다.
	<<elseif $pillory.tenant.spank gte 4>>
		그의 유두는 학대당해 아파 보인다.
	<<elseif $pillory.tenant.spank gte 1>>
		그의 유두에는 학대당한 흔적이 보인다.
	<</if>>
	<<elseif $pillory.tenant.upperexposed gte 2>>
		<<if $pronoun is "f">>
			그녀의 상의가 벗겨져, 오직 속옷만이 군중으로부터 그녀의 가슴을 가려주고 있다.
		<<else>>
			그의 상의가 벗겨져, 군중에게 가슴이 완전히 노출되었다.
		<<if $pillory.tenant.spank gte 8>>
			그의 유두는 잔뜩 꼬집히고, 얻어맞고, 물리고 당겨진 탓에 붉게 부었다.
		<<elseif $pillory.tenant.spank gte 4>>
			그의 유두는 학대당해 아파 보인다.
		<<elseif $pillory.tenant.spank gte 1>>
			그의 유두에는 학대당한 흔적이 보인다.
		<</if>>
	<<elseif $pillory.tenant.upperexposed gte 1>>
		그의 상의가 찢어져, 군중에게 <<if $pronoun is "f">>브라가<<else>>가슴이<</if>> 부분적으로 노출되어 있다.
	<</if>>
	<<if $pillory.tenant.lowerexposed gte 2>>
		그의 <<if $pillory.tenant.upperexposed gte 1>>엉덩이 또한 <<else>>엉덩이가<</if>>노출되어,
		<<if $pillory.tenant.person.gender is "f">>그녀의 질이
		<<else>>그의 페니스가
		<</if>>모두에게 보인다.
		<<if $pillory.tenant.spank gte 5>>그의 엉덩이는 거칠게
			<<if $pillory.tenant.fruit gte 5>>얻어맞은 것으로 보이고, 그의 <<if $pillory.tenant.face gte 1>>정액<<if $pillory.tenant.face gte 4>> 범벅인<<else>>이 묻은<</if>><</if>> 얼굴은 멍과 으깨진 과일로 엉망진창이다.
			<<else>>얻어맞은 것으로 보인다.
			<</if>>
		<<elseif $pillory.tenant.fruit gte 6>>그의 <<if $pillory.tenant.face gte 1>>정액<<if $pillory.tenant.face gte 4>> 범벅인<<else>>이 묻은<</if>><</if>> 얼굴은 멍과 으깨진 과일로 엉망진창이다.
		<<elseif $pillory.tenant.fruit gte 2>>그의 <<if $pillory.tenant.face gte 1>>정액<<if $pillory.tenant.face gte 4>> 범벅인<<else>>이 묻은<</if>><</if>> 얼굴은 멍과 으깨진 과일 때문에 바로 눈에 들어온다.
		<</if>>
		<<if $pillory.tenant.ass gte 1>>그의 엉덩이는 여러 번
			<<if $pillory.tenant.genital gte 2>>강간당했고,
				<<if $pillory.tenant.person.gender is "m">><<print either("노출된","학대당한","비참한")>> 페니스는 점액으로 뒤덮혀 있다.
				<<else>><<print either("노출된","붉어진","학대당한")>> 질에서는 정액이 <<if $pillory.tenant.genital gte 4>>흘러나온다<<else>>방울방울 떨어진다<</if>>.
				<</if>>
			<<else>>한 번 강간당했다.
			<</if>>
		<<elseif $pillory.tenant.genital gte 5>>그의 <<if $pillory.tenant.person.gender is "m">>페니스는<<else>>질은<</if>> 생으로 강간당했다.
		<<elseif $pillory.tenant.genital gte 2>>그는 여러 번 강간당했다.
		<</if>>
	<<elseif $pillory.tenant.lowerexposed gte 1>>
		그의 <<if $pronoun is "f">>드레스는 허리 위로 들춰져,<<else>>바지는 내려져,<</if>>
		군중에게 속옷을 노출하고 있다.
	<<elseif $pillory.tenant.wet is 2>>비로 인해 그의 옷은 속이 다 비친다.
	<<elseif $pillory.tenant.wet is 1>>그의 옷은 축축해서 반투명해진 상태이나, 점차 말라가고 있다.
	<</if>>
	<<if $pillory.tenant.upperexposed is 0 and $pillory.tenant.lowerexposed is 0 and $pillory.tenant.face is 0 and $pillory.tenant.fruit gte 1>>
		<<if $pillory.tenant.fruit gte 6>>그의 얼굴은 멍과 으깨진 과일로 엉망진창이다.
		<<elseif $pillory.tenant.fruit gte 2>>그의 얼굴은 멍과 으깨진 과일 때문에 바로 눈에 들어온다.
		<</if>>
	<</if>>
<</widget>>

<<widget "update_npc_pillory_appearance">>
	/* Event firing chance increases with time.
	last viewed is reset every visit, so a visit every 30 minutes has 50% chance to fire, while a visit every hour has 100%   */
	<<set $_lastViewed to new DateTime($pillory.tenant.lastViewed)>>
	<<set $_firechance to -Time.date.compareWith($_lastViewed, true)/TimeConstants.secondsPerHour>>
	<<rng>>
	<<if $rng lte 100*$_firechance>>

		/*Weather effects*/
		<<if Weather.precipitation is "rain">>
			<<set $pillory.tenant.wet to 2>>
		<<elseif $pillory.tenant.wet is 2>>
			<<set $pillory.tenant.wet to 1>>
		<<else>>
			<<set $pillory.tenant.wet to 0>>
		<</if>>

		/*Chance of abuse based on crowd and time passed*/
		<<if $pillory.tenant.crowd lte 1>><<set $pillory.tenant.crowd to 1>><</if>>
		<<set $_chance to Math.clamp($_firechance, 1, 24)>>
		 /* If you do not visit for a long time, there is a higher chance for at least one event to happen */
		<<if $_chance gte 1>><<set $_chance to $_chance**1.5>><</if>>
		<<set $_chance *= $pillory.tenant.crowd>>

		/*increased by spectacle*/
		<<set $_factor to ($pillory.tenant.upperexposed + $pillory.tenant.lowerexposed + $pillory.tenant.ass + $pillory.tenant.genital + $pillory.tenant.face/2 + $pillory.tenant.fruit/3 + $pillory.tenant.spank/3)>>
		<<if $pillory.tenant.lowerexposed gte 2>>
			<<set $_factor = Math.floor($_factor+$pillory.tenant.spank/3)>>
		<</if>>

		<<if Time.dayState is "night">>
			<<set $_factor += 3>>
		<</if>>
		<<if $pillory.tenant.wet is 2>>
			<<set $_factor += 4>>
		<</if>>
		<<set $_prob to Math.floor($_chance + $_factor)>>

		/*Out of sight changes to tenant */
		<<rng>>
		<<if $rng gte (30 - $_prob)>><<set $pillory.tenant.fruit += 1>><</if>>
		<<rng>>
		<<if $rng gte (50 - $_prob)>><<set $pillory.tenant.crowd += 1>><</if>>
		<<rng>>
		<<if $rng gte (50 - $_prob)>><<set $pillory.tenant.upperexposed += 1>><</if>>
		<<rng>>
		<<if $rng gte (70 - $_prob)>><<set $pillory.tenant.lowerexposed += 1>><</if>>
		<<rng>>
		<<if $rng gte (90 - $_prob)>><<set $pillory.tenant.crowd += 2>><</if>>
		<<rng>>
		<<if $rng gte (90 - $_prob)>><<set $pillory.tenant.upperexposed += 3>><</if>>
		<<rng>>
		<<if $rng gte (90 - $_prob)>><<set $pillory.tenant.fruit += 2>><<set $pillory.tenant.face += 1>><</if>>
		<<rng>>
		<<if $rng gte (90 - $_prob)>><<set $pillory.tenant.spank += 2>><<else>><<set $pillory.tenant.spank += 1>><</if>>
		<<rng>>
		<<if $rng gte (100 - $_prob)>><<set $pillory.tenant.lowerexposed += 2>><</if>>
		<<rng>>
		<<if ($pillory.tenant.special.name is "" or $pillory.tenant.person.virginity.vaginal isnot true or ($pillory.tenant.person.gender is "m" and $pillory.tenant.person.strapon is undefined)) and $rng gte (100 - $_prob)>>			
			<<set $pillory.tenant.genital += 1>>
		<</if>>
		<<rng>>
		<<if ($pillory.tenant.special.name is "" or $pillory.tenant.person.virginity.anal isnot true) and $settings.analEnabled and $rng gte (100 - $_prob)>>
			<<set $pillory.tenant.ass += 1>>
		<</if>>

		/*lock down exposure and replenish fruit */
		<<if $pillory.tenant.upperexposed gte 3>><<set $pillory.tenant.upperexposed to 3>><</if>>
		<<if $pillory.tenant.lowerexposed gt 2>><<set $pillory.tenant.lowerexposed to 2>><</if>>
		<<set $pillory.tenant.fruitstock to 3>>
		<<set $pillory.tenant.broken += Math.floor($pillory.tenant.ass + $pillory.tenant.genital + $pillory.tenant.face/2 + $pillory.tenant.fruit/3 + $pillory.tenant.spank/3)>>
	<</if>>
<</widget>>

<<widget "npc_pillory_abuse">>
	/* Event firing chance increases with time.
	last viewed is reset every visit, so a visit every 30 minutes has 50% chance to fire, while a visit every hour has 100%   */
	<<set $_lastViewed to new DateTime($pillory.tenant.lastViewed)>>
	<<set $_firechance to -Time.date.compareWith($_lastViewed, true)/TimeConstants.secondsPerHour>>
	<<rng>>
	<<if $rng lte 100*$_firechance>>
