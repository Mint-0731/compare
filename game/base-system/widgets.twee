	<<get_pillory_npc>>
	<<if $pillory.tenant.special.name is "">>
		<<set _out += "한 남자">>
	<<else>>
		<<set _out += $pillory.tenant.special.name>>
	<</if>>
	<</silently>><<print _out>>
<</widget>>

