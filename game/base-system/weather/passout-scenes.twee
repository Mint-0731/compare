:: Widgets Temperature Passout [widget]
/* This widget is run on its own after passout */
<<widget "passouttemperature">>
	<<cleareventpool>>
	<<outfitChecks>>
	<<set $passoutstat += 1>>
	<<set $passoutTimeStat to Time.date.timeStamp>>
	<<set $stress to Math.clamp($stress, 0, 8000)>>
	<<pass 60>>
	/* FROSTBITE */
	<<if _passout is "cold">>
		<<set Weather.bodyTemperature to Weather.tempSettings.minTemperature + 1.5>>
		<<if !["beach", "estate", "forest", "lake", "moor", "park", "sea", "tower", "wolf_cave"].includes($location)>>
			당신은 추위로 정신을 잃는다.
			<br><br>
		<</if>>
		<<switch $location>>
			<<case "asylum">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Asylum]]>><</link>>
				<</addinlineevent>>
			<<case "beach">>
				당신은 <<= Weather.precipitation is "rain" ? "축축한 모래 위에 쓰러진다. 비가 당신의 등을 때리자 당신은" : Weather.precipitation is "snow" ? "차가운 모래 위에 쓰러진다. 당신의 몸 위로 눈이 내리고 당신은" : "모래 위에 쓰러진다. 당신은">> 몸에 남아있는 작은 열을 보존하기 위해 몸을 웅크린다.
				<br><br>
				<<if ["rain", "snow"].includes(Weather.precipitation)>>
					당신은 최선을 다해 <<= $worn.handheld.type.includes("rainproof") ? "우산으로 몸을 가리" : "우산으로 몸을 보호하">>지만, 당신의 손가락은 추위로 마비되고, 팔이 옆으로 떨어진다.
					<<silently>><<water>><</silently>>
					<br><br>
				<</if>>

				당신은 추위로 정신을 잃는다.
				<br><br>

				<<if getRobinLocation() is "beach">>
					<<addinlineevent "beach" 1.25>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Hypothermia Robin]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "beach" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Hypothermia]]>><</link>>
				<</addinlineevent>>

				<<if $fame.good gte 400 or $fame.social gte 400>>
					<<addinlineevent "fame" 0.2>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Fame]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if dangerEvent() and !_fullyNaked>>
					<<addinlineevent "beach" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Hypothermia Molest]]>><<set $molestationstart to 1>><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "estate">>
				<<if !$estate>><<estate_init>><</if>> /* It's possible to trigger the $estate location passout on the link that unsets $estate */
				Your breath mists in the winter air. The <<= Weather.precipitation is "snow" ? "pristine snow looks soft and inviting" : "ground looks inviting">>. You take a few faltering steps. You sink down next to a car and close your eyes.
				<br><br>

				Just before you pass out, you
				<<if $farm.aggro gte 60>>
					<<addinlineevent "remy" 1>>
						<span class="red">hear the sound of spurs approaching.</span>
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Estate Remy Hot Cold]]>><</link>>
					<</addinlineevent>>
				<<elseif $wren_intro isnot undefined>>
					<<addinlineevent "wren" 1>>
						<span class="green">hear the sound of boots approaching.</span>
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Estate Wren Hot Cold]]>><<set $passoutReason to "hypothermia">><</link>>
					<</addinlineevent>>
				<<else>>
					<<addinlineevent "generic" 1>>
						hear the sound of someone approaching.
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Rescue]]>><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "farm">>
				<<if $bus.includes("farm")>>/* If not the Underground Farm */
					<<addinlineevent "molest" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Molest]]>><<set $molestationstart to 1>><</link>>
					<</addinlineevent>>
				<<else>>
					<<addinlineevent "livestock" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Livestock Hot Cold]]>><<set $passoutReason to "hypothermia">><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "forest">>
				당신이 한 걸음 한 걸음 빽빽한 숲을 뚫고 걸어갈 때 마다, 냉혹한 추위가 뼛속까지 파고든다. 당신의 몸은 벌벌 떨리고, <<if Weather.isFreezing>>당신의 숨결은 싸늘한 공기 속에서 입김이 되어 흩어지며, <</if>>당신이 힘겹게 걸음을 뗄 때마다 심장이 뛰어댄다. <<if Weather.isSnow>>발밑에 눈이 뽀득거리며 밟힌다.<</if>>
				<br><br>

				피로감이 당신을 짓누르고, 어둠이 당신의 시야에 스며들며 세상이 흐려진다. 당신은 추위와 피로에 압도된 채로 숲 바닥에 쓰러진다. 당신의 의식이 풀리는 동시에 땅이 당신의 눈앞에 빠른 속도로 가까워져 온다.
				<br><br>

				당신은 추위로 정신을 잃는다.
				<br><br>

				<<if $forest lte 25 and !isGwylanAbsent() and C.npc.Gwylan.state isnot "scorned">>
					<<addinlineevent "gwylan" .6>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Gwylan Hot Cold]]>><<set $passoutReason to "hypothermia">><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "wolf" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Wolves Hot Cold]]>><<set $passoutReason to "hypothermia">><</link>>
				<</addinlineevent>>

				<<addinlineevent "rescue" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Rescue]]>><</link>>
				<</addinlineevent>>
			<<case "wolf_cave">>
				당신은 체온을 유지하기 위해 최선을 다했지만, 추위가 너무 심했다. 의식이 희미해지고, 지면이 당신을 향해 빠르게 가까워진다.
				<br><br>

				<<addinlineevent "rescue" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Wolf Cave Hypothermia]]>><</link>>
				<</addinlineevent>>
			<<case "cabin">>
				<<addinlineevent "Eden" 2>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Eden Hot Cold]]>><<pass 60>><<set $passoutReason to "hypothermia">><</link>>
				<</addinlineevent>>
			<<case "tower">>
				<<addinlineevent "birdRescue" 1>>
					당신은 추위로 기절했다.
					<br><br>

					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Bird Hypothermia]]>><</link>>
				<</addinlineevent>>
			<<case "moor">>
					<<if $moormove is "horse">>
					<<addinlineevent "moorHorse" 2>>
						당신은 추위로 기절했다.
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Moor Horse]]>><</link>>
					<</addinlineevent>>
				<<else>>
					<<addinlineevent "birdRescue" 1.5>>
						<<if $syndromebird gte 1>>
							<<if Weather.temperature lte 4>>살을 에는 듯한 추위가 뼛속까지 스며들며, <</if>> 걷잡을 수 없이 후들거리는 몸으로, 당신은 황무지를 터벅터벅 걸어간다. 매 순간이 지날 때마다 당신의 몸은 점점 약해지고, 둔해져 간다.
							<br><br>

							당신의 팔다리가 무겁고 감각이 사라져간다. 당신은 <<= Weather.isSnow ? "눈 덮인" : "차가운">> 땅에 풀썩 쓰러진다. 주변 세상은 어둠 속으로 사라지고 대기 속 냉기가 당신을 완전히 감싼다.
							<br><br>

						당신은 추위로 기절했다.
							<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Bird Hypothermia]]>><</link>>
						<<else>>
							<<npc "Great Hawk">><<person1>>
							당신은 더 이상 나아가기에는 너무 지쳐, <<= Weather.isSnow ? "눈 덮인 땅" : "땅">>에 발을 헛디뎌 넘어진다. 당신의 입술은 <<= Weather.temperature lte 4 ? "차가운 공기" : "거친 호흡">> 탓에 갈라졌지만, 당신은 어떻게든 필사적인 도움을 외친다.
							<br><br>

							당신의 외침은 응답받는다. 거대 매가 허공을 가른다. <<hawkRescueApproachSentence>>
							<br><br>

							당신은 고개를 젖힌 채, 입술이 더욱 말라가는 동안 당신을 향해 날아오는 거대한 그림자를 물끄러미 바라본다.
							<br><br>

							<<link [[다음|Bird Rescue No Syndrome]]>><</link>>
						<</if>>
					<</addinlineevent>>

					<<addinlineevent "rescue" 1>>
						당신은 추위로 기절했다.
						<br><br>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Rescue]]>><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "prison">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Prison 2]]>><</link>>
				<</addinlineevent>>
			<<case "lake">>
				당신의 시야가 흐려진다. 당신은 몸을 단단히 감싸 따뜻하게 하려 하지만, 별 소용이 없다.
				<br><br>
				<<if $town_projects.diving gte 4 and (Time.schoolDay and Time.hour gte 16 and Time.hour lte 20 or !Time.schoolDay and Time.hour gte 6 and Time.hour lte 20)>>
					<<addinlineevent "winter" 0.75>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hot Cold Lake Office]]>><<set $passoutReason to "hypothermia">><</link>>
					<</addinlineevent>>
				<</if>>

				<<if !Time.schoolDay and ["snow", "rain"].includes(Weather.precipitation) and Time.dayState is "day">>
					<<addinlineevent "mason" 0.25>>
							<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Mason Hypothermia]]>><<set $phase to ["lakeunderwater", "lake_ruin", "lake_ruin_deep"].includes($bus) ? "underwater" : 1>><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "danger" 1.25>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Lake Gangbang]]>><</link>>
				<</addinlineevent>>
			<<case "school">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|School Passout]]>><<set $passoutReason to "hypothermia">><</link>>
				<</addinlineevent>>
			<<case "sea">>
				차가운 바닷물이 당신의 마지막 체온을 빼앗는다. 당신의 팔다리는 수영을 계속할 수 없을 정도로 무거워지고, 이내 가라앉기 시작하며 당신은 정신을 잃는다.
				<br><br>

				<<addinlineevent "pirates" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Pirates Hot Cold]]>><<set $passoutReason to "hypothermia">><</link>>
				<</addinlineevent>>
			<<case "tentworld">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Tentacle World]]>><</link>>
				<</addinlineevent>>
			<<case "park">>
				당신은 휘청거리며 앞으로 한 발짝 내디지만, 계속 가기에는 너무 지쳐서, 차가운 바닥에 푹 쓰러진다.
				<br><br>
				/* Park events needed - adding default ones now to prevent empty passages */
				<<if getRobinLocation() is "park" and !$daily.robin.passout>>
					<<addinlineevent "park" 1.25>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Robin Hypothermia Park]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "rescue" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Rescue]]>><</link>>
				<</addinlineevent>>
				<<case "island">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Island Passout]]>><</link>>
				<</addinlineevent>>
			<<default>>
				/* Generic events */
				<<addinlineevent "ambulance" 0.1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Ambulance rescue]]>><<set $passoutReason to "hypothermia">><</link>>
				<</addinlineevent>>

				<<addinlineevent "molest" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Molest]]>><<set $molestationstart to 1>><</link>>
				<</addinlineevent>>

				<<addinlineevent "rescue" 1.1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Rescue]]>><</link>>
				<</addinlineevent>>

				<<if $fame.good gte 400 or $fame.social gte 400>>
					<<addinlineevent "fame" 0.2>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hypothermia Fame]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if $location is "town" and $bus is "danube">>
					<<addinlineevent "danube" 1.5>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Danube Street]]>><<set $phase2 to _passout>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if (($location is "town" and $bus is "high") or $location is "office" or $location is "avery_skyscraper") and $officejobintro is 1 and Time.hour gte 6 and Time.hour lte 21>>
					<<addinlineevent "office" 2>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Office]]>><<set $phase2 to _passout>><</link>>
					<</addinlineevent>>
				<</if>>
			<</switch>>
	/* HEATSTROKE */
	<<elseif _passout is "heat">>
		<<set Weather.bodyTemperature to Weather.tempSettings.maxTemperature - 1>>
		<<if !["beach", "estate", "forest", "lake", "moor", "sea", "wolf_cave"].includes($location)>>
			당신은 무더위로 인해 쓰러진다.
			<br><br>
		<</if>>
		<<switch $location>>
			<<case "alley">>
				<<if Weather.temperature gte 27 and _top and !Time.schoolDay and $bullytimer gte $rng and C.npc.Whitney.init is 1 and !["dungeon", "pillory"].includes(C.npc.Whitney.state) and $daily.whitney.park is undefined>>
					<<addinlineevent "default" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Alley Heatstroke Whitney]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if _underwear>>
					<<addinlineevent "icecube" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Ice Cube]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if !_fullyNaked>>
					<<addinlineevent "strip" .5>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Strip]]>><<set $molestationstart to 1>><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "rescue" .5>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Rescue]]>><</link>>
				<</addinlineevent>>

                <<addinlineevent "kiss" 1>>
                    <<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Kiss]]>><</link>>
                <</addinlineevent>>
			<<case "asylum">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Asylum]]>><</link>>
				<</addinlineevent>>
			<<case "beach" "seabeach">>
				<<if $location is "seabeach">>
					차가운 물 속에서도 여전히 뜨거운 열기가 당신에게 달라붙는다. 당신은 현기증을 느끼고는 얕은 물에 무릎을 꿇으며 쓰러진다. 당신의 몸은 지쳤다. 당신은 눈을 감는다.
				<<else>>
					가슴이 울렁거린다. 당신은 뜨거운 모래 위에 쓰러진다. 너무 심한 더위로 당신의 시야가 어두워진다.
				<</if>>
				<br><br>
				<<addinlineevent "waves" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Heatstroke]]>><</link>>
				<</addinlineevent>>

				<<if getRobinLocation() is "beach" and $location isnot "seabeach" and !$daily.robin.passout and $robin.timer.hurt lt 1>>
					<<addinlineevent "lemonade" 1.25>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Heatstroke Lemonade]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if dangerEvent() and !Weather.overcast>>
					<<addinlineevent "students" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Heatstroke Students]]>><</link>>
					<</addinlineevent>>
					<<if !_fullyNaked and Weather.precipitation is "none">>
						<<addinlineevent "wetShirt" 1>>
							<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Heatstroke Wet Shirt]]>><</link>>
						<</addinlineevent>>
					<</if>>
				<<else>>
					<<addinlineevent "rescue" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Beach Heatstroke Rescue]]>><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "estate">>

				You can see heat radiating off the tops of the cars. Sweat pours down your forehead, stinging your eyes. You stagger to a patch of shade and collapse in a heap.
				<br><br>

				Just before you pass out, you
				<<if $farm.aggro gte 60>>
					<<addinlineevent "remy" 1>>
						<span class="red">hear the sound of spurs approaching.</span>
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Estate Remy Hot Cold]]>><<estate_end>><</link>>
					<</addinlineevent>>
				<<elseif $wren_intro isnot undefined>>
					<<addinlineevent "wren" 1>>
						<span class="green">hear the sound of boots approaching.</span>
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Estate Wren Hot Cold]]>><<set $passoutReason to "hyperthermia">><</link>>
					<</addinlineevent>>
				<<else>>
					<<addinlineevent "generic" 1>>
						hear the sound of someone approaching.
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Rescue]]>><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "farm">>
				<<if $bus.includes("farm")>>/* If not the Underground Farm */
					<<addinlineevent "generic" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Rescue]]>><</link>>
					<</addinlineevent>>
					<<if !_fullyNaked>>
						<<addinlineevent "strip" 1>>
							<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Strip]]>><<set $molestationstart to 1>><</link>>
						<</addinlineevent>>
					<</if>>
				<<else>>
					<<addinlineevent "livestock" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Livestock Hot Cold]]>><<set $passoutReason to "hyperthermia">><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "forest">>
				걸음마다 머리를 찌르는 듯한 두통을 느끼며 당신은 울창한 숲속을 지나간다. <<if !Weather.overcast>>집요한 햇빛이 구름을 뚫고 빠져나온다.<</if>> 이마에서는 땀이 뚝뚝 떨어지고, 심장은 고동치는 채로 당신은 빽빽한 덤불을 뚫고 앞으로 나아가려 애쓴다.
				<br><br>

				피로감이 당신을 짓누르고, 어둠이 당신의 시야에 스며들며 세상이 흐려진다. 당신은 더위와 피로에 압도된 채로 숲 바닥에 쓰러진다. 당신의 의식이 풀리는 동시에 땅이 당신의 눈앞에 빠른 속도로 가까워져 온다.
				<br><br>

				당신은 무더위로 인해 쓰러진다.
				<br><br>

				<<if $forest lte 25 and !isGwylanAbsent() and C.npc.Gwylan.state isnot "scorned">>
					<<addinlineevent "gwylan" .6>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Gwylan Hot Cold]]>><<set $passoutReason to "hyperthermia">><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "mud" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Mud]]>><</link>>
				<</addinlineevent>>

				<<addinlineevent "wolf" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Wolves Hot Cold]]>><<set $passoutReason to "hyperthermia">><</link>>
				<</addinlineevent>>

				<<addinlineevent "rescue" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Rescue]]>><</link>>
				<</addinlineevent>>
				<<case "wolf_cave">>
				당신의 이마에서 땀이 비 오듯 쏟아진다. 눈이 따갑지만, 너무 지쳐서 닦아낼 힘조차 없다. 열기가 너무 심하다. 당신은 비틀거리며 동굴 근처 그늘진 곳으로 가서 털썩 주저앉는다.
				<br><br>

				<<addinlineevent "rescue" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Wolf Cave Heatstroke]]>><</link>>
				<</addinlineevent>>
			<<case "lake">>
				폭염이 당신을 사로잡는다. 당신의 머리가 빙빙 돌고 당신의 시야가 흐려진다.
				<br><br>

				<<if $town_projects.diving gte 4 and (Time.schoolDay and Time.hour gte 16 and Time.hour lte 20 or !Time.schoolDay and Time.hour gte 6 and Time.hour lte 20)>>
					<<addinlineevent "winter" 0.75>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Hot Cold Lake Office]]>><<set $passoutReason to "hyperthermia">><</link>>
					<</addinlineevent>>
				<</if>>

				<<if !Time.schoolDay and ["snow", "rain"].includes(Weather.precipitation) and Time.dayState is "day">>
					<<addinlineevent "mason" 0.25>>
							<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Mason Hyperthermia]]>><<set $phase to ["lakeunderwater", "lake_ruin", "lake_ruin_deep"].includes($bus) ? "underwater" : 1>><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "mud" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Mud]]>><</link>>
				<</addinlineevent>>
			<<case "cabin">>
				<<addinlineevent "Eden" 2>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Eden Hot Cold]]>><<pass 60>><<set $passoutReason to "hyperthermia">><</link>>
				<</addinlineevent>>
			<<case "tower">>
				<<addinlineevent "birdRescue" 1.5>>
					당신은 무더위로 인해 쓰러진다.
					<br><br>

					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Bird Heatstroke]]>><</link>>
				<</addinlineevent>>
			<<case "moor">>
				<<if $moormove is "horse">>
					<<addinlineevent "moorHorse" 2>>
						당신은 무더위로 인해 쓰러진다.
						<br><br>

						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Moor Horse]]>><</link>>
					<</addinlineevent>>
				<<else>>
					<<addinlineevent "birdRescue" 1.5>>
						<<if $syndromebird gte 1>>
							<<npc "Great Hawk">><<person1>>
							황무지를 터벅터벅 걸어갈 때면 집요한 태양이 내리쬔다. 울렁거리는 두통이 당신의 머리를 덮쳐온다. 욕지기가 파도처럼 당신의 배를 휩쓸고, 걷잡을 수 없이 맥박이 요동친다. 당신은 더위에 압도된다.
							<br><br>

							당신은 무릎을 꿇은 채, 바싹 마른 땅을 꽉 움켜쥐며 고통을 경감시키려 필사적으로 노력한다. 땅은 아득히 멀게만 느껴진다. 세상은 빙빙 돌며 어둠에 삼켜진다.
							<br><br>

							당신은 무더위로 인해 쓰러진다.
							<br><br>

							<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Bird Heatstroke]]>><</link>>
						<<else>>
							<<npc "Great Hawk">><<person1>>
							당신은 땅에 발을 헛디뎌 넘어진다. 더 이상 나아갈 수가 없다. 당신의 입술은 더위로 바싹 말랐지만, 당신은 어떻게든 필사적인 도움을 외친다.
							<br><br>

							당신의 외침은 응답받는다. 거대 매가 허공을 가른다. <<hawkRescueApproachSentence>>
							<br><br>

							당신은 고개를 젖힌 채, 입술이 더욱 말라가는 동안 당신을 향해 날아오는 거대한 그림자를 물끄러미 바라본다.
							<br><br>
							<<link [[다음|Bird Rescue No Syndrome]]>><</link>>
						<</if>>
					<</addinlineevent>>

						<<addinlineevent "rescue" 1>>
						당신은 무더위로 인해 쓰러진다.
						<br><br>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Rescue]]>><</link>>
					<</addinlineevent>>
				<</if>>
			<<case "prison">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Prison 2]]>><</link>>
				<</addinlineevent>>
			<<case "sea">>
				사방이 물임에도 불구하고 더위가 너무 심하다. 수영을 계속하기엔 팔다리가 너무 무겁다. 몸이 가라앉기 시작하며 당신은 정신을 잃는다.
				<br><br>

				<<addinlineevent "pirates" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Pirates Hot Cold]]>><<set $passoutReason to "hyperthermia">><</link>>
				<</addinlineevent>>
			<<case "school">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|School Passout]]>><<set $passoutReason to "hyperthermia">><</link>>
				<</addinlineevent>>
			<<case "tentworld">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Tentacle World]]>><</link>>
				<</addinlineevent>>
			<<case "park">>
				<<if isInPark("whitney")>>
					<<addinlineevent "default" 2>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Park Heatstroke Whitney]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if $wolfgirl gte 6 or $cat gte 6>>
					<<addinlineevent "animals" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Animals]]>><</link>>
					<</addinlineevent>>
				<</if>>

				<<addinlineevent "delinquents" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Delinquents]]>><</link>>
				<</addinlineevent>>

				<<addinlineevent "flash" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Flash]]>><</link>>
				<</addinlineevent>>
				<<case "island">>
				<<addinlineevent "default" 1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Island Passout]]>><</link>>
				<</addinlineevent>>
			<<default>>
				/* Generic events */
				<<addinlineevent "ambulance" 0.1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Ambulance rescue]]>><<set $passoutReason to "hyperthermia">><</link>>
				<</addinlineevent>>

				<<if !_fullyNaked>>
					<<addinlineevent "strip" 1>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Strip]]>><<set $molestationstart to 1>><</link>>
					<</addinlineevent>>
				<</if>>

                <<addinlineevent "kiss" 1>>
                    <<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Kiss]]>><</link>>
                <</addinlineevent>>

				<<addinlineevent "rescue" 1.1>>
					<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Heatstroke Rescue]]>><</link>>
				<</addinlineevent>>

				<<if $location is "town" and $bus is "danube">>
					<<addinlineevent "danube" 1.5>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Danube Street]]>><<set $phase2 to _passout>><</link>>
					<</addinlineevent>>
				<</if>>

				<<if (($location is "town" and $bus is "high") or $location is "office" or $location is "avery_skyscraper") and $officejobintro is 1 and Time.hour gte 6 and Time.hour lte 21>>
					<<addinlineevent "office" 2>>
						<<link [[모든 것이 암흑 속으로 사라져간다...|Passout Office]]>><<set $phase2 to _passout>><</link>>
					<</addinlineevent>>
				<</if>>
		<</switch>>
	<</if>>
	<<runeventpool>>
<</widget>>

/* Determines clothes player may be given after passing out of cold */
<<widget "hypothermiaClothes">>
	<<outfitChecks>><<set _wet to $upperwetstage gte 3 or $lowerwetstage gte 3 or $underupperwetstage gte 3 or $underlowerwetstage gte 3>>
	<<set _gender to $player.gender_appearance>>
	<<set _clothes to []>>
	<<set _warmClothes to []>>

	<<if _fullyNaked>>
		<<set _warmClothes to "some clothes">>
	<<elseif _wet>>
		<<dry_full>><<upperstrip>><<lowerstrip>>
		<<set _warmClothes to "dry clothes">>
	<<elseif !_bottom>>
		<<set _warmClothes to "some trousers">>
	<<elseif $debug is 1 and $worn.over_upper.name is "naked" and $rng gte 46>>
		<<set _warmClothes to "a jacket">>
	<<elseif $worn.upper.warmth lt 6>>
		<<set _warmClothes to _shirtless ? "a shirt" : "something warmer">>
	<<elseif !$worn.neck.cursed>>
		<<set _warmClothes to "a scarf">>
	<<elseif $worn.head.warmth lt 3>>
		<<set _warmClothes to "a hat">>
	<</if>>

	<<if $debug is 1 and $worn.over_upper.name is "naked" and $rng gt 100>>
		/* outerwearToDo: Give players a jacket that's suitably warm. Not the froggy coat. Rng to allow for the possibility that they'll get another article of clothing instead -- rng should normally be gte 45, I just wanted to make this impossible to get. */
		<<set $_slot to "over_upper">>
		<<set $_jacket to ["froggy coat"]>>
		<<overupperwear $_jacket.random()>>
	<<elseif $worn.upper.warmth lt 6>>
		<<set $_slot to "upper">>
		<<set $_upper to ["puffer jacket", "turtleneck jumper", "cable knit turtleneck", "ghost jumper"]>>
		<<if $player.gender_appearance is "m" or $settings.forcedCrossdressingEnabled>>
			<<set $_upper.push("punk leather jacket", "leather jacket", "letterman jacket")>>
		<</if>>
		<<if $player.gender_appearance is "f" or $settings.forcedCrossdressingEnabled>>
			<<set $_upper.push("heart jumper", "girl's sweater")>>
		<</if>>
		<<set $_item to $_upper.random()>>
		<<upperstrip>>
		<<switch $_item>>
			<<case "ghost jumper">><<upperwear $_item "white" "neon blue">>
			<<case "heart jumper">><<upperwear $_item "lilac" "pink">>
			<<case "skull jumper">><<upperwear $_item "black" "red">>
			<<default>><<upperwear $_item>>
		<</switch>>
		<<set _crossdress to ($worn.upper.gender is "f" and $player.gender_appearance is "m") or ($worn.upper.gender is "m" and $player.gender_appearance is "f")>>
	<<elseif !$worn.neck.cursed>>
		<<set $_slot to "neck">>
		<<set $_item to "scarf">>
		<<neckwear $_item>>
	<<elseif $worn.head.warmth lt 3>>
		<<set _costume to $christmas is 1 or $halloween is 1>>
		<<set $_slot to "head">>
		<<set $_item to $christmas is 1 ? "christmas hat" : $halloween is 1 ? "bat beanie" : "beanie">>
		<<headwear $_item>>
	<</if>>
	<<set _text_output to setup.clothes[$_slot][clothesIndex($_slot, $worn[$_slot])].word is "n" ? `a pair of ${$worn[$_slot].name}` : setup.clothes[$_slot][clothesIndex($_slot, $worn[$_slot])].word + " " + $worn[$_slot].name >>
	<<set _clothes.push(_text_output)>>

	<<outfitChecks>>
	<<if _bottomExposed>>
		<<set $_slot to "lower">>
		<<set $_item to either("khakis", "trousers", "jeans", "sweatpants")>>
		<<lowerwear $_item>>
		<<set _text_output to setup.clothes[$_slot][clothesIndex($_slot, $worn.lower)].word is "n" ? `a pair of ${$worn[$_slot].name}` : setup.clothes[$_slot][clothesIndex($_slot, $worn.lower)].word + " " + $worn[$_slot].name >>
		<<set _clothes.push(_text_output)>>
	<</if>>
<</widget>>

/*
To get the previous major area passage, use: $safePassage (for links in the last passage, unless we want to link the player elsewhere)
*/

/* Generic passouts */
:: Passout Hypothermia Molest
<<if $molestationstart is 1>>
	당신은 당신의 위에 <<generate1>>남자가 올라타 있는 것을 발견하고 잠에서 깬다. "일어났구나, 자기," 그가 중얼거린다. "네가 상당히 지독하게 떨고 있더라고, 그래서 몸을 녹여줄 방법이 없을지 생각해 봤어. 내가 몸에 열을 발생시키는 좋은 방법을 알고 있는데 말이지..." 그는 음탕하게 몸을 비비며 당신을 내려다본다.
	<br><br>
	<<set $molestationstart to 0>>
	<<controlloss>>
	<<violence 1>>
	<<neutral 1>>
	<<molested>>
	<<maninit>>
	<<set $enemyanger to 0>>
	<<set $encounterDialogue to "cold">>
<</if>>

<<effects>>
<<effectsman>><<man>>
<<stateman>>
<br><br>
<<actionsman>>
<<if _combatend>>
	<span id="next"><<link [[다음|Passout Hypothermia Molest Finish]]>><</link>></span><<nexttext>>
<<else>>
	<span id="next"><<link [[다음|Passout Hypothermia Molest]]>><</link>></span><<nexttext>>
<</if>>

:: Passout Hypothermia Molest Finish
<<effects>>
<<set Weather.bodyTemperature++>>
<<if $enemyarousal gte $enemyarousalmax>>
	<<ejaculation>>
	남자는 만족스러운 신음과 함께 몸을 밀어붙이고는, 당신을 향해 싱긋 웃는다. "자, 몸이 다 데워졌네. 나처럼 착한 사마리아인이 도와주다니, 너는 참 운이 좋구나." 그는 낄낄 웃더니 떠나기 전에 거들먹거리며 당신의 뺨을 가볍게 토닥인다. <<tearful>> 당신은 일어서서 이를 딱딱거리며 양손을 비빈다.

	<<endcombat>>
	<<clotheson>>
<<elseif $enemyhealth lte 0>>
	당신이 그를 마지막으로 <<= $submissive lte 850 ? "공격적으로" : "필사적으로">> 밀쳐내자 그는 투덜거린다. "망할, 쌍년아!" 당신이 허둥지둥 도망치자 그가 당신의 뒤로 소리친다. "누군가가 도와주는 걸 원치 않았으면 그렇게 돌아다니지 말았어야지!" <<tearful>> 당신은 그로부터 전력으로 도망친다. 적어도 그 운동은 당신의 혈액 순환을 돕고 당신을 추위로부터 벗어나게 할 것이다. <<athletics 1>>
	<br><br>
	<<clotheson>>
	<<endcombat>>
<</if>>

<<link [[다음|$safePassage]]>><<endevent>><<set $eventskip to 1>><</link>>


/* Generic heatstroke passout: dangerous */
:: Passout Heatstroke Strip

<<if $molestationstart is 1>>
	당신은 당신의 위에 <<generate1>>남자가 올라타 있는 것을 발견하고 잠에서 깬다. "일어났구나, 화끈한 친구." 그가 아양 떨듯 말한다. "열사병 걸렸지, 응? 내가 도와줄게." 그가 당신의 옷을 잡아당기기 시작한다.
	<br><br>
	<<set $molestationstart to 0>>
	<<controlloss>>
	<<violence 1>>
	<<molested>>
	<<set $enemyno to 1>><<set $enemynomax to 1>>
	<<maninit>>
	<<npcstripall>>
	<<npcidlegenitals>>
	<<set $encounterDialogue to "hotStrip">>
<</if>>

<<effects>>
<<effectsman>><<man>>
<br><br>
<<stateman>>
<<actionsman>>

<<outfitChecks>>
<<if _fullyNaked or $enemyarousal gte $enemyarousalmax or $enemyhealth lte 0>>
	<span id="next"><<link [[다음|Passout Heatstroke Strip Finish]]>><</link>></span><<nexttext>>
<<else>>
	<span id="next"><<link [[다음|Passout Heatstroke Strip]]>><</link>></span><<nexttext>>
<</if>>

:: Passout Heatstroke Strip Finish
<<effects>>
<<outfitChecks>>
<<set Weather.bodyTemperature-->>
<<if _fullyNaked>>
	남자는 당신의 옷을 마지막 하나까지 전부 벗겨낸다. 그는 당신의 나체에 눈을 부릅뜬다. "좋아," 그가 감격하듯 말한다. 그는 당신의 옷을 자신의 팔 밑에 집어넣으며 일어선다. "자, 충분히 시원해질 거야."
	<br><br>

	<<tearful>> 당신은 여전히 열사병으로 허약한 채로 일어나려고 애쓴다. 당신은 그를 <<= $submissive lte 850 ? "불결한" : "애원하는">> 눈으로 쳐다본다.
	<br><br>

	"뭐야, 고맙다는 말도 안 하는 거야?" 남자는 혀를 차고 고개를 흔든다. "글쎄, 나는 이걸 내 선행에 대한 보상으로 가지고 가야 할 것 같은데. 시원하게 있으라고, 소녀야."
	<<if $beauty gte ($beautymax / 7) * 4>>
		그는 잠깐 멈칫한다. "뭐, 그게 가능하다면 말이지만. 너는 제법 <i>핫</i>하니까 말야, 그러기가 쉽지 않을 것 같네." 그는 자신의 말장난에 낄낄 웃으며 떠난다.
	<<else>>
		그는 당신에게 윙크한다. "어쨌든 너처럼 귀여운 소녀는 옷을 입고 돌아다니면 안 돼."
	<</if>>
