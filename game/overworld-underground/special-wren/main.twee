	당신은 고개를 끄덕이고 재빨리 자리를 뜬다.
<<elseif $alarm is 1 and $rescue is 1>>
	<<loadNPC 1 "wren_heist_guard_1">><<loadNPC 2 "wren_heist_guard_2">>
